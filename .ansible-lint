---
kinds:
  - playbook: "**/playbooks/tasks/security-scan.yml"
  - playbook: "**/collections/ansible_collections/lv3/platform/playbooks/tasks/security-scan.yml"
exclude_paths:
  - .ansible/
  - .git/
  - .local/
  - molecule/
  - playbooks/_includes/
  - playbooks/services/
  - playbooks/vars/
  - collections/ansible_collections/lv3/platform/roles/docker_runtime/molecule/
  - collections/ansible_collections/lv3/platform/playbooks/_includes/
  - collections/ansible_collections/lv3/platform/playbooks/services/
skip_list:
  - command-instead-of-module
  - command-instead-of-shell
  - name[play]
  - no-handler
  - run-once
  - var-naming
  - yaml
