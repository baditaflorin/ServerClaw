      "title": "Runtime Assurance Scope",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "### LV3 Log Canary\n\nThis dashboard proves that the production Loki path can still ingest and query its own recurring canary stream.\n\nRunbook: [Log Queryability Canary](https://docs.lv3.org/runbooks/log-queryability-canary/)",
        "mode": "markdown"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Canary Target Up",
      "datasource": {
        "type": "prometheus",
        "uid": "lv3-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"loki-canary\"})",
          "legendFormat": "up"
        }
      ]
    },
