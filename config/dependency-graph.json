  "edges": [
    {
      "from": "alertmanager",
      "to": "mattermost",
      "type": "soft",
      "description": "Alertmanager forwards warning, info, and mirrored critical notifications into Mattermost channels, but operators can still inspect active alerts directly if chat delivery is degraded."
    },
    {
      "from": "alertmanager",
      "to": "ntfy",
      "type": "soft",
      "description": "Critical paging depends on ntfy delivery, but Mattermost still provides a lower-fidelity fallback notification path."
    },
    {
      "from": "api_gateway",
      "to": "keycloak",
      "type": "hard",
      "description": "The unified API gateway validates caller JWTs against Keycloak before serving authenticated platform routes."
    },
    {
      "from": "api_gateway",
      "to": "nginx_edge",
      "type": "soft",
      "description": "Public access to api.lv3.org depends on the shared edge publication path, but the internal gateway remains reachable directly."
    },
    {
      "from": "changelog_portal",
      "to": "nginx_edge",
      "type": "hard",
      "description": "The changelog portal is served as generated static content on nginx-lv3."
    },
    {
      "from": "docs_portal",
      "to": "nginx_edge",
      "type": "hard",
      "description": "The generated developer portal is published as static content on nginx-lv3."
    },
    {
      "from": "gitea",
      "to": "docker_build",
      "type": "soft",
      "description": "Gitea Actions jobs are delegated to the dedicated runner on docker-build-lv3, but repository hosting remains available without the runner."
    },
    {
      "from": "gitea",
      "to": "keycloak",
      "type": "soft",
      "description": "Operator SSO into Gitea prefers Keycloak, while the repo-managed bootstrap admin remains the break-glass fallback."
    },
    {
      "from": "gitea",
      "to": "openbao",
      "type": "startup_only",
      "description": "Gitea loads its mirrored database, webhook, and OIDC client secrets from the OpenBao sidecar before startup."
    },
    {
      "from": "gitea",
      "to": "postgres",
      "type": "hard",
      "description": "Gitea persists repositories, metadata, and issue state in Postgres."
    },
    {
      "from": "grafana",
      "to": "keycloak",
      "type": "soft",
      "description": "Grafana uses Keycloak for the preferred SSO path, but local admin remains the break-glass fallback."
    },
    {
      "from": "grafana",
      "to": "nginx_edge",
      "type": "soft",
      "description": "Public access to grafana.lv3.org depends on the shared NGINX edge; private reachability remains available if the edge is degraded."
    },
    {
      "from": "keycloak",
      "to": "postgres",
      "type": "hard",
      "description": "Keycloak stores realm, client, and session state in Postgres."
    },
    {
      "from": "keycloak",
      "to": "openbao",
      "type": "startup_only",
      "description": "Keycloak reads its mirrored database and bootstrap secrets through the OpenBao agent before startup."
    },
    {
      "from": "keycloak",
      "to": "step_ca",
      "type": "startup_only",
      "description": "Keycloak depends on the internal certificate authority when repo-managed internal TLS material is refreshed."
    },
    {
      "from": "keycloak",
      "to": "nginx_edge",
      "type": "soft",
      "description": "Public reachability for sso.lv3.org depends on the shared edge publication path."
    },
    {
      "from": "mail_platform",
      "to": "openbao",
      "type": "startup_only",
      "description": "The mail gateway runtime is rendered from secrets mirrored locally by the OpenBao sidecar."
    },
    {
      "from": "mail_platform",
      "to": "nginx_edge",
      "type": "soft",
      "description": "The published mail.lv3.org informational surface is exposed through the shared NGINX edge."
    },
    {
      "from": "mattermost",
      "to": "postgres",
      "type": "hard",
      "description": "Mattermost stores channels, users, and message history in Postgres."
    },
    {
      "from": "mattermost",
      "to": "openbao",
      "type": "startup_only",
      "description": "Mattermost starts from OpenBao-rendered runtime secrets mirrored into its compose environment."
    },
    {
      "from": "netbox",
      "to": "postgres",
      "type": "hard",
      "description": "NetBox stores all inventory, topology, and IPAM data in Postgres."
    },
    {
      "from": "netbox",
      "to": "openbao",
      "type": "startup_only",
      "description": "NetBox receives its database and Redis credentials from the OpenBao agent before the application containers start."
    },
    {
      "from": "open_webui",
      "to": "keycloak",
      "type": "soft",
      "description": "Open WebUI can be configured for Keycloak OIDC, but the current runtime can still fall back to local login if OIDC is unavailable."
    },
    {
      "from": "open_webui",
      "to": "openbao",
      "type": "startup_only",
      "description": "Open WebUI consumes mirrored runtime secrets and optional OIDC client credentials from the OpenBao sidecar."
    },
    {
      "from": "ops_portal",
      "to": "api_gateway",
      "type": "hard",
      "description": "The interactive operations portal depends on the unified API gateway for governed platform actions and live status reads."
    },
    {
      "from": "ops_portal",
      "to": "keycloak",
      "type": "hard",
      "description": "ops.lv3.org is gated behind oauth2-proxy and Keycloak-backed browser authentication."
    },
    {
      "from": "ops_portal",
      "to": "nginx_edge",
      "type": "hard",
      "description": "The generated portal is published as static content on nginx-lv3."
    },
    {
      "from": "platform_context_api",
      "to": "openbao",
      "type": "startup_only",
      "description": "The platform context API loads its bearer token and runtime configuration from OpenBao-rendered environment files."
    },
    {
      "from": "platform_context_api",
      "to": "step_ca",
      "type": "reads_from",
      "description": "The indexed corpus includes step-ca ADR and runbook content for operator query grounding."
    },
    {
      "from": "status_page",
      "to": "nginx_edge",
      "type": "hard",
      "description": "The public status page is published at status.lv3.org through the shared NGINX edge hostname."
    },
    {
      "from": "status_page",
      "to": "uptime_kuma",
      "type": "hard",
      "description": "The public status page is rendered by the Uptime Kuma runtime and cannot function if that service is unavailable."
    },
    {
      "from": "windmill",
      "to": "postgres",
      "type": "hard",
      "description": "Windmill persists workflow metadata, run history, and state in Postgres."
    },
    {
      "from": "windmill",
      "to": "openbao",
      "type": "startup_only",
      "description": "Windmill workers and the server runtime load mirrored secrets from the OpenBao agent before the containers start."
    }
  ]
}
