        "headers": {
          "Host": "status.lv3.org"
        },
        "validate_tls": false
      },
      "uptime_kuma": {
        "enabled": false,
        "reason": "The status page should not recursively monitor itself from the same Uptime Kuma instance; independent coverage is delegated to Uptime Robot."
      }
    },
    "mail_platform": {
      "service_name": "mail-platform",
      "owning_vm": "docker-runtime-lv3",
      "role": "mail_platform_runtime",
      "verify_file": "roles/mail_platform_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "http",
        "description": "The private mail gateway health endpoint responds.",
        "timeout_seconds": 60,
        "retries": 1,
        "delay_seconds": 0,
        "url": "http://127.0.0.1:8081/healthz",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "command",
        "description": "The mail gateway can list the managed notification profiles over the authenticated API.",
        "timeout_seconds": 60,
        "retries": 1,
        "delay_seconds": 0,
        "argv": [
          "python3",
          "-c",
          "from pathlib import Path; import sys, urllib.request; api_key = Path('/etc/lv3/mail-platform/gateway-api-key').read_text(encoding='utf-8').strip(); request = urllib.request.Request('http://127.0.0.1:8081/v1/profiles', headers={'X-API-Key': api_key}); response = urllib.request.urlopen(request, timeout=60); sys.exit(0 if response.status == 200 else 1)"
        ],
        "success_rc": 0
      },
      "tls_certificate_ids": ["mail-platform-edge"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Mail Platform Gateway Private",
          "type": "http",
          "url": "http://10.10.10.20:8081/healthz",
          "description": "Private mail gateway health endpoint on docker-runtime-lv3.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 10,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
