{
  "schema_version": "1.0.0",
  "services": {
    "nginx_edge": {
      "service_name": "nginx-edge",
      "owning_vm": "nginx-lv3",
      "role": "nginx_edge_publication",
      "verify_file": "roles/nginx_edge_publication/tasks/verify.yml",
      "liveness": {
        "kind": "systemd",
        "description": "The nginx edge unit is active on the public edge guest.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "unit": "nginx",
        "expected_state": "active"
      },
      "readiness": {
        "kind": "http",
        "description": "The managed nginx.lv3.org host header is served over HTTPS.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "url": "https://127.0.0.1/",
        "method": "GET",
        "expected_status": [200],
        "headers": {
          "Host": "nginx.lv3.org"
        },
        "validate_tls": false
      },
      "tls_certificate_ids": ["nginx-edge-public"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "NGINX Edge Public",
          "type": "http",
          "url": "https://nginx.lv3.org",
          "description": "Public landing page served by the NGINX edge VM.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 10,
          "accepted_statuscodes": ["200-399"]
        }
      }
    },
    "grafana": {
      "service_name": "grafana",
      "owning_vm": "monitoring-lv3",
      "role": "monitoring_vm",
      "verify_file": "roles/monitoring_vm/tasks/verify.yml",
      "liveness": {
        "kind": "http",
        "description": "Grafana responds on its local health endpoint.",
        "timeout_seconds": 60,
        "retries": 20,
        "delay_seconds": 3,
        "url": "http://127.0.0.1:3000/api/health",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "Grafana serves its local health endpoint after provisioning completes.",
        "timeout_seconds": 60,
        "retries": 1,
        "delay_seconds": 0,
        "url": "http://127.0.0.1:3000/api/health",
        "method": "GET",
        "expected_status": [200]
      },
      "tls_certificate_ids": ["grafana-edge"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Grafana Public",
          "type": "http",
          "url": "https://grafana.lv3.org",
          "description": "Grafana publication through the NGINX edge VM.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 10,
          "accepted_statuscodes": ["200-399"]
        }
      }
    },
    "alertmanager": {
      "service_name": "alertmanager",
      "owning_vm": "monitoring-lv3",
      "role": "alertmanager_runtime",
      "verify_file": "roles/alertmanager_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "http",
        "description": "Alertmanager responds on its local health endpoint.",
        "timeout_seconds": 60,
        "retries": 20,
        "delay_seconds": 3,
        "url": "http://127.0.0.1:9093/-/healthy",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "Alertmanager responds on its local readiness endpoint after routing config loads.",
        "timeout_seconds": 60,
        "retries": 20,
        "delay_seconds": 3,
        "url": "http://127.0.0.1:9093/-/ready",
        "method": "GET",
        "expected_status": [200]
      },
      "uptime_kuma": {
        "enabled": false,
        "reason": "Alertmanager is private-only and its operator value is already covered by role verification on monitoring-lv3."
      }
    },
    "keycloak": {
      "service_name": "keycloak",
      "owning_vm": "docker-runtime-lv3",
      "role": "keycloak_runtime",
      "verify_file": "roles/keycloak_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "http",
        "description": "The Keycloak management liveness endpoint responds on the loopback management port.",
        "timeout_seconds": 120,
        "retries": 24,
        "delay_seconds": 5,
        "url": "http://127.0.0.1:19000/health/live",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "The Keycloak realm discovery endpoint responds locally with the expected issuer metadata.",
        "timeout_seconds": 120,
        "retries": 24,
        "delay_seconds": 5,
        "url": "http://127.0.0.1:18080/realms/lv3/.well-known/openid-configuration",
        "method": "GET",
        "expected_status": [200]
      },
      "tls_certificate_ids": ["keycloak-edge"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Keycloak OIDC Discovery",
          "type": "http",
          "url": "https://sso.lv3.org/realms/lv3/.well-known/openid-configuration",
          "description": "Shared SSO discovery endpoint published through the NGINX edge VM.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 5,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
    "api_gateway": {
      "service_name": "api-gateway",
      "owning_vm": "docker-runtime-lv3",
      "role": "api_gateway_runtime",
      "verify_file": "roles/api_gateway_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "http",
        "description": "The local API gateway health endpoint responds on docker-runtime-lv3.",
        "timeout_seconds": 90,
        "retries": 18,
        "delay_seconds": 5,
        "url": "http://127.0.0.1:8083/healthz",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "The authenticated aggregate health endpoint rejects anonymous requests while the gateway is serving traffic.",
        "timeout_seconds": 90,
        "retries": 1,
        "delay_seconds": 0,
        "url": "http://127.0.0.1:8083/v1/health",
        "method": "GET",
        "expected_status": [401]
      },
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Platform API Gateway Public",
          "type": "http",
          "url": "https://api.lv3.org/healthz",
          "description": "Public edge entrypoint for the unified LV3 API gateway.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 5,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
    "ops_portal": {
      "service_name": "ops-portal",
      "owning_vm": "docker-runtime-lv3",
      "role": "ops_portal_runtime",
      "verify_file": "roles/ops_portal_runtime/tasks/verify.yml",
