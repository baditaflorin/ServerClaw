        "delay_seconds": 5,
        "url": "http://10.10.10.20:8092/health",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "The interactive ops portal renders its dashboard shell locally after startup.",
        "timeout_seconds": 120,
        "retries": 24,
        "delay_seconds": 5,
        "url": "http://10.10.10.20:8092/",
        "method": "GET",
        "expected_status": [200]
      },
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Ops Portal Public",
          "type": "http",
          "url": "https://ops.lv3.org/health",
          "description": "Interactive ops portal health endpoint published through the NGINX edge VM.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 5,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
    "proxmox_ui": {
      "service_name": "proxmox-ui",
      "owning_vm": "proxmox_florin",
      "role": null,
      "verify_file": null,
      "liveness": {
        "kind": "tcp",
        "description": "The Proxmox UI listener accepts TCP connections on the host bridge.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "host": "10.10.10.1",
        "port": 8006
      },
      "readiness": {
        "kind": "http",
        "description": "The Proxmox API version endpoint responds on the management listener.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "url": "https://10.10.10.1:8006/api2/json/version",
        "method": "GET",
        "expected_status": [200],
        "validate_tls": false
      },
      "tls_certificate_ids": ["proxmox-ui", "proxmox-edge-page"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Proxmox UI Port",
          "type": "port",
          "hostname": "10.10.10.1",
          "port": 8006,
          "description": "Internal Proxmox UI listener on the host bridge address.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
    "docker_runtime": {
      "service_name": "docker-runtime",
      "owning_vm": "docker-runtime-lv3",
      "role": "docker_runtime",
      "verify_file": "roles/docker_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "systemd",
        "description": "The Docker daemon is active on docker-runtime-lv3.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "unit": "docker",
        "expected_state": "active"
      },
      "readiness": {
        "kind": "command",
        "description": "The local Docker Engine API returns server metadata.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "argv": ["docker", "info", "--format", "{{.ServerVersion}}"],
        "success_rc": 0
      },
      "tls_certificate_ids": ["docker-runtime-edge"],
      "uptime_kuma": {
        "enabled": false,
        "reason": "Docker daemon health is enforced by the role verify task and does not expose a dedicated external HTTP surface."
      }
    },
    "docker_build": {
      "service_name": "docker-build",
      "owning_vm": "docker-build-lv3",
      "role": null,
      "verify_file": null,
      "liveness": {
        "kind": "tcp",
        "description": "SSH is reachable on the Docker build VM.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "host": "10.10.10.30",
        "port": 22
      },
      "readiness": {
        "kind": "tcp",
        "description": "The Docker build VM is ready enough to accept routine operator SSH sessions.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "host": "10.10.10.30",
        "port": 22
      },
      "tls_certificate_ids": ["build-edge"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Docker Build SSH",
          "type": "port",
          "hostname": "10.10.10.30",
          "port": 22,
          "description": "SSH reachability for the Docker build VM.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "accepted_statuscodes": ["200-299"]
        }
      }
    },
    "uptime_kuma": {
      "service_name": "uptime-kuma",
      "owning_vm": "docker-runtime-lv3",
      "role": "uptime_kuma_runtime",
      "verify_file": "roles/uptime_kuma_runtime/tasks/verify.yml",
      "liveness": {
        "kind": "command",
        "description": "The Uptime Kuma container is running on docker-runtime-lv3.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "argv": ["docker", "ps", "--filter", "name=uptime-kuma", "--filter", "status=running", "--format", "{{.Names}}"],
        "success_rc": 0
      },
      "readiness": {
        "kind": "http",
        "description": "The Uptime Kuma web UI responds on the local listener.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "url": "http://127.0.0.1:3001",
        "method": "GET",
        "expected_status": [200]
      },
      "tls_certificate_ids": ["uptime-kuma-edge"],
      "uptime_kuma": {
        "enabled": true,
        "monitor": {
          "name": "Uptime Kuma Public",
          "type": "http",
          "url": "https://uptime.lv3.org",
          "description": "Public Uptime Kuma entrypoint through the NGINX edge.",
          "interval": 60,
          "retryInterval": 60,
          "maxretries": 0,
          "maxredirects": 10,
          "accepted_statuscodes": ["200-399"]
        }
      }
    },
    "status_page": {
      "service_name": "status-page",
      "owning_vm": "docker-runtime-lv3",
      "role": null,
      "verify_file": null,
      "liveness": {
        "kind": "http",
        "description": "The Uptime Kuma status page slug responds on the local runtime listener.",
        "timeout_seconds": 30,
        "retries": 1,
        "delay_seconds": 0,
        "url": "http://127.0.0.1:3001/status/lv3-platform",
        "method": "GET",
        "expected_status": [200]
      },
      "readiness": {
        "kind": "http",
        "description": "The public status page route responds through the shared edge host header.",
