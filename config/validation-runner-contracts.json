  "runners": {
    "controller-local-validation": {
      "description": "Operator-local fallback runner for gate and validation replay commands started through remote_exec.sh.",
      "execution_surface": "controller_local",
      "cpu_architectures": [
        "arm64",
        "x86_64"
      ],
      "emulation_support": [],
      "container_runtime": {
        "engine": "docker",
        "supported": true
      },
      "required_tools": [
        "docker",
        "git",
        "python3",
        "tar"
      ],
      "network_reachability_class": "controller_local",
      "scratch_cleanup_guarantee": "controller-local workspace state remains isolated beneath .local and may be cleared between runs",
      "supported_validation_lanes": [
        "workstream-surfaces",
        "agent-standards",
        "documentation-index",
        "generated-docs",
        "generated-portals",
        "ansible-lint",
