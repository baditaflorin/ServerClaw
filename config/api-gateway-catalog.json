{
  "$schema": "docs/schema/api-gateway-catalog.schema.json",
  "schema_version": "1.0.0",
  "services": [
    {
      "id": "grafana",
      "name": "Grafana",
      "upstream": "http://10.10.10.40:3000",
      "gateway_prefix": "/v1/grafana",
      "auth": "keycloak_jwt",
      "required_role": "platform-operator",
      "strip_prefix": true,
      "timeout_seconds": 15,
      "healthcheck_path": "/api/health"
    },
    {
      "id": "keycloak",
      "name": "Keycloak",
      "upstream": "http://10.10.10.20:18080",
