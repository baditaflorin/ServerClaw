      "auth": "keycloak_jwt",
      "required_role": "platform-operator",
      "strip_prefix": true,
      "timeout_seconds": 15,
      "healthcheck_path": "/realms/lv3/.well-known/openid-configuration"
    },
    {
      "id": "mail_platform",
