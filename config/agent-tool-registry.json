        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "output_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_version",
          "platform_version",
          "observed_check_date",
          "os",
          "proxmox",
          "guest_count",
          "public_services",
          "latest_receipt_ids"
        ],
        "properties": {
          "repo_version": {
            "type": "string"
          },
          "platform_version": {
            "type": "string"
          },
          "observed_check_date": {
            "type": "string"
          },
          "os": {
            "type": "object"
          },
          "proxmox": {
            "type": "object"
          },
          "guest_count": {
            "type": "integer",
            "minimum": 0
