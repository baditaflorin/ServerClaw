      "name": "browser-run-session",
      "title": "Browser Run Session",
      "description": "Execute one bounded Playwright browser session through the private ADR 0261 browser-runner runtime and return structured outputs plus artifact metadata.",
      "category": "execute",
      "transport": "http",
      "endpoint": "service://browser_runner/sessions",
      "auth": "private browser-runner runtime or governed Dify tool bridge",
