{
  "$schema": "docs/schema/certificate-catalog.schema.json",
  "schema_version": "1.0.0",
  "certificates": [
    {
      "id": "backup-pbs-ui",
      "service_id": "backup_pbs",
      "status": "lan_only",
      "summary": "Proxmox Backup Server HTTPS endpoint on the backup VM. LAN-only \u2014 not reachable from the Tailscale controller; excluded from automated validation.",
      "expected_issuer": "any",
      "endpoint": {
        "host": "10.10.10.60",
        "port": 8007,
        "server_name": "10.10.10.60"
      },
      "policy": {
        "warn_days": 21,
        "critical_days": 14
      },
      "renewal": {
        "agent": "pbs-self-managed",
        "managed_by_repo": false,
        "notes": "The PBS appliance manages its own HTTPS certificate lifecycle today."
      }
    },
    {
      "id": "openbao-proxy",
      "service_id": "openbao",
      "status": "active",
      "summary": "OpenBao HTTPS endpoint exposed through the Proxmox host Tailscale proxy.",
      "expected_issuer": "step-ca",
      "endpoint": {
        "host": "100.64.0.1",
        "port": 8200,
        "server_name": "100.64.0.1"
      },
      "policy": {
        "warn_hours": 6,
        "critical_hours": 2
      },
      "renewal": {
        "agent": "systemd-step-issue",
        "managed_by_repo": true,
        "host": "docker-runtime",
        "unit_name": "lv3-openbao-cert-renew",
        "on_calendar": "*:0/15",
        "randomized_delay_seconds": 60,
        "reload_command": "docker compose --file /opt/openbao/docker-compose.yml restart openbao"
      },
      "material": {
        "certificate_file": "/opt/openbao/tls/server.crt",
        "key_file": "/opt/openbao/tls/server.key",
        "root_file": "/opt/step-ca/home/certs/root_ca.crt",
        "subject": "100.64.0.1",
        "sans": [
          "10.10.10.20",
          "100.64.0.1"
        ],
        "ca_url": "https://10.10.10.20:9000",
        "provisioner": "services",
        "password_file": "/opt/step-ca/secrets/services-password.txt",
        "not_after": "24h"
      }
    },
    {
      "id": "portainer-proxy",
      "service_id": "portainer",
      "status": "tls_pending",
      "summary": "Portainer HTTPS endpoint exposed through the Proxmox host Tailscale proxy. TLS handshake fails (Cipher: NONE) \u2014 Portainer serves a self-signed cert incompatible with modern TLS stacks; excluded from validation until cert is replaced with step-ca material.",
      "expected_issuer": "any",
      "endpoint": {
        "host": "100.64.0.1",
        "port": 9444,
        "server_name": "100.64.0.1"
      },
      "policy": {
        "warn_days": 21,
        "critical_days": 14
      },
      "renewal": {
        "agent": "portainer-self-managed",
        "managed_by_repo": false,
        "host": "docker-runtime",
        "notes": "Portainer still serves its container-local certificate. A follow-up ADR can replace it with step-ca-managed material."
      }
    },
    {
      "id": "proxmox-ui",
      "service_id": "proxmox_ui",
      "status": "active",
      "summary": "Proxmox manager HTTPS certificate on the host listener.",
      "expected_issuer": "letsencrypt",
      "endpoint": {
        "host": "100.64.0.1",
        "port": 8006,
        "server_name": "proxmox.example.com"
      },
      "policy": {
        "warn_days": 21,
        "critical_days": 14
      },
      "renewal": {
        "agent": "proxmox-acme",
        "managed_by_repo": false,
        "host": "proxmox-host",
        "notes": "Renewed by the Proxmox ACME integration on the host."
      }
    },
    {
      "id": "step-ca-proxy",
      "service_id": "step_ca",
      "status": "active",
      "summary": "step-ca HTTPS endpoint exposed through the Proxmox host Tailscale proxy.",
      "expected_issuer": "step-ca",
      "endpoint": {
        "host": "100.64.0.1",
        "port": 9443,
        "server_name": "localhost"
      },
      "policy": {
        "warn_hours": 6,
        "critical_hours": 2
      },
      "renewal": {
        "agent": "step-ca-self",
        "managed_by_repo": false,
        "host": "docker-runtime",
        "notes": "The CA bootstrap certificate remains a step-ca-managed special case and is only inventoried here."
      }
    },
    {
      "id": "vaultwarden-private",
      "service_id": "vaultwarden",
