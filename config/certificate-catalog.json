        "port": 443,
        "server_name": "build.lv3.org"
      },
      "policy": {
        "warn_days": 21,
        "critical_days": 14
      },
      "renewal": {
        "agent": "certbot-dns-hetzner",
        "managed_by_repo": false,
        "host": "nginx-lv3",
        "notes": "Renewed by Certbot on the shared public edge VM."
      },
      "material": {
        "bundle_path": "/etc/letsencrypt/live/lv3-edge/fullchain.pem"
      }
