        "reload_command": "docker compose --file /opt/vaultwarden/docker-compose.yml restart vaultwarden"
      },
      "material": {
        "certificate_file": "/opt/vaultwarden/tls/server.crt",
        "key_file": "/opt/vaultwarden/tls/server.key",
        "root_file": "/opt/step-ca/home/certs/root_ca.crt",
        "subject": "vault.example.com",
        "sans": [
          "vault.example.com",
          "10.10.10.20",
          "100.118.189.95",
          "127.0.0.1",
          "localhost"
        ],
        "ca_url": "https://10.10.10.20:9000",
        "provisioner": "services",
        "password_file": "/opt/step-ca/secrets/services-password.txt",
        "not_after": "24h"
      }
    },
