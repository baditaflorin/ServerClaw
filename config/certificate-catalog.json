    {
      "id": "backup-pbs-ui",
      "service_id": "backup_pbs",
      "status": "active",
      "summary": "Proxmox Backup Server HTTPS endpoint on the backup VM.",
      "expected_issuer": "any",
      "endpoint": {
        "host": "10.10.10.60",
        "port": 8007,
        "server_name": "10.10.10.60"
      },
      "policy": {
        "warn_days": 21,
        "critical_days": 14
      },
      "renewal": {
        "agent": "pbs-self-managed",
        "managed_by_repo": false,
        "notes": "The PBS appliance manages its own HTTPS certificate lifecycle today."
      }
    },
    {
      "id": "build-edge",
      "service_id": "docker_build",
      "status": "active",
      "summary": "Shared NGINX edge certificate served for build.lv3.org.",
