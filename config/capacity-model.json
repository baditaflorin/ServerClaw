  "runtime_pool_memory": {
    "host_free_memory_floor_gb": 20,
    "measurement_and_control": {
      "metrics_source": "prometheus",
      "control_surface": "nomad-autoscaler"
    },
    "pools": [
      {
        "id": "runtime-control",
        "baseline_ram_gb": 12,
        "max_ram_gb": 16,
        "admission_priority": 1,
        "notes": "Control-plane capacity is reserved first and now anchors the dedicated runtime-control-lv3 guest before lower-priority runtime pools can expand."
      },
      {
        "id": "runtime-general",
        "baseline_ram_gb": 12,
        "max_ram_gb": 20,
        "admission_priority": 2,
        "notes": "Operator and support services use the runtime-general lane first; later migrations can consume this governed envelope without re-arguing the pool budget."
      },
      {
        "id": "runtime-ai",
        "baseline_ram_gb": 16,
        "max_ram_gb": 28,
        "admission_priority": 3,
        "notes": "Bursty document, notebook, and inference-adjacent workloads may expand last and only inside the approved runtime-ai envelope."
      }
    ]
  },
  "reservations": [
    {
      "id": "ephemeral-pool",
      "kind": "ephemeral_pool",
      "status": "reserved",
      "capacity_class": "preview_burst",
      "vmid_range": {
        "start": 910,
        "end": 979
      },
      "max_concurrent_vms": 5,
      "reserved": {
        "ram_gb": 20,
        "vcpu": 8,
        "disk_gb": 216
      },
      "notes": "Shared peak reservation for ADR 0106 ephemeral fixtures and ADR 0186 prewarmed fixture spares so transient test VMs and warm-pool refills cannot silently consume production headroom."
    },
    {
      "id": "recovery-drill-pool",
      "kind": "planned_growth",
      "status": "reserved",
      "capacity_class": "recovery_reserved",
      "reserved": {
        "ram_gb": 4,
        "vcpu": 2,
        "disk_gb": 48
      },
      "notes": "Protected headroom for restore and disaster-recovery rehearsals. Declared drills may borrow preview_burst before any break-glass use of ha_reserved."
    }
  ],
