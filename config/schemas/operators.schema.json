{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config/schemas/operators.schema.json",
  "title": "Operator roster",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "operators"
  ],
  "properties": {
    "$schema": {
      "const": "config/schemas/operators.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "operators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operator"
      }
    }
  },
  "$defs": {
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "email",
        "role",
        "status",
        "keycloak",
        "ssh",
        "openbao",
        "tailscale",
        "audit"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "operator",
            "viewer"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ]
        },
        "notes": {
          "type": "string"
        },
        "keycloak": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "username",
            "realm_roles",
            "groups",
            "enabled"
          ],
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1
            },
            "realm_roles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "ssh": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "principal",
            "certificate_ttl_hours",
            "public_keys"
          ],
          "properties": {
            "principal": {
              "type": "string",
              "minLength": 1
            },
            "certificate_ttl_hours": {
              "type": "integer",
              "minimum": 1
            },
            "public_keys": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/publicKey"
              }
            }
          }
        },
        "openbao": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "entity_name",
            "policies"
          ],
          "properties": {
            "entity_name": {
              "type": "string",
              "minLength": 1
            },
            "policies": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "tailscale": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "login_email",
            "tags"
          ],
          "properties": {
            "login_email": {
              "type": "string",
              "format": "email"
            },
            "device_name": {
              "type": "string",
              "minLength": 1
            },
            "device_id": {
              "type": "string",
              "minLength": 1
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "onboarded_at",
            "onboarded_by"
          ],
          "properties": {
            "onboarded_at": {
              "type": "string",
              "format": "date-time"
            },
            "onboarded_by": {
              "type": "string",
              "minLength": 1
            },
            "offboarded_at": {
              "type": "string",
              "format": "date-time"
            },
            "offboarded_by": {
              "type": "string",
              "minLength": 1
            },
            "last_reviewed_at": {
              "type": "string",
              "format": "date-time"
            },
            "last_reviewed_by": {
              "type": "string",
              "minLength": 1
            },
            "last_seen_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "publicKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "public_key",
        "fingerprint"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "public_key": {
          "type": "string",
          "minLength": 1
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^SHA256:[A-Za-z0-9+/]+$"
        }
      }
    }
  }
}
