{
  "lint-ansible": {
    "image": "registry.lv3.org/check-runner/ansible:2.17.10",
    "command": "ansible-lint playbooks roles",
    "working_dir": "/workspace",
    "timeout_seconds": 300,
    "cache_mounts": ["ansible_collections"]
  },
  "lint-yaml": {
    "image": "registry.lv3.org/check-runner/ansible:2.17.10",
    "command": "find . -path ./.git -prune -o -type f \\( -name '*.yml' -o -name '*.yaml' \\) -print0 | xargs -0 yamllint -c .yamllint",
    "working_dir": "/workspace",
    "timeout_seconds": 120,
    "cache_mounts": ["ansible_collections"]
  },
  "validate-schemas": {
    "image": "registry.lv3.org/check-runner/python:3.12.10",
    "command": "python scripts/validate_repository_data_models.py --validate && python scripts/platform_manifest.py --check",
    "working_dir": "/workspace",
    "timeout_seconds": 180,
    "cache_mounts": ["pip"]
  },
  "type-check": {
    "image": "registry.lv3.org/check-runner/python:3.12.10",
    "command": "mypy scripts/parallel_check.py config/windmill/scripts/check-runner-rebuild.py tests/test_parallel_check.py",
    "working_dir": "/workspace",
    "timeout_seconds": 120,
    "cache_mounts": ["pip"]
  },
  "security-scan": {
    "image": "registry.lv3.org/check-runner/security:2026.03.23",
    "command": "trivy fs --skip-dirs .git --skip-dirs .worktrees --exit-code 1 --severity HIGH,CRITICAL .",
    "working_dir": "/workspace",
    "timeout_seconds": 240
  },
  "tofu-validate": {
    "image": "registry.lv3.org/check-runner/infra:2026.03.23",
    "command": "if [ -d tofu ]; then tofu -chdir=tofu/environments/production init -backend=false -input=false >/dev/null && tofu -chdir=tofu/environments/production validate && tofu -chdir=tofu/environments/staging init -backend=false -input=false >/dev/null && tofu -chdir=tofu/environments/staging validate; else echo 'No tofu configuration present'; fi",
    "working_dir": "/workspace",
    "timeout_seconds": 120,
    "cache_mounts": ["packer_plugins"]
  },
  "packer-validate": {
    "image": "registry.lv3.org/check-runner/infra:2026.03.23",
    "command": "if [ -d packer ] && find packer -name '*.pkr.hcl' -print -quit | grep -q .; then packer validate packer; else echo 'No packer templates present'; fi",
    "working_dir": "/workspace",
    "timeout_seconds": 120,
    "cache_mounts": ["packer_plugins"]
  }
}
