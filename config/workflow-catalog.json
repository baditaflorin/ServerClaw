{
  "schema_version": "1.0.0",
  "workflows": {
    "validate": {
      "description": "Run the repository validation pipeline used before merge to main.",
      "lifecycle_status": "active",
      "preferred_entrypoint": {
        "kind": "make_target",
        "target": "validate",
        "command": "make validate"
      },
      "preflight": {
        "required": false
      },
      "validation_targets": [],
      "live_impact": "repo_only",
      "owner_runbook": "docs/runbooks/validate-repository-automation.md",
      "implementation_refs": [
        "Makefile",
        "scripts/controller_automation_toolkit.py",
        "scripts/validate_repo.sh",
        "scripts/generate_status_docs.py",
        "scripts/validate_repository_data_models.py",
        ".github/workflows/validate.yml"
      ],
      "outputs": [
        "Repository validation result across syntax, YAML, Ansible lint, shell, JSON, canonical data-model, and generated-document checks."
      ],
      "verification_commands": [
        "make validate"
      ]
    },
    "generate-status-docs": {
      "description": "Regenerate the README status fragments that are derived from canonical repository state.",
      "lifecycle_status": "active",
      "preferred_entrypoint": {
        "kind": "make_target",
        "target": "generate-status-docs",
        "command": "make generate-status-docs"
      },
      "preflight": {
        "required": false
      },
      "validation_targets": [
        "validate-data-models",
        "validate-generated-docs"
      ],
      "live_impact": "repo_only",
      "owner_runbook": "docs/runbooks/generate-status-documents.md",
      "implementation_refs": [
        "Makefile",
        "README.md",
        "scripts/controller_automation_toolkit.py",
        "scripts/generate_status_docs.py",
        "versions/stack.yaml",
        "workstreams.yaml"
      ],
      "outputs": [
        "Generated README platform status, version summary, document index, and merged-workstream sections refreshed from canonical repository state."
      ],
      "verification_commands": [
        "make generate-status-docs",
        "make validate-generated-docs"
      ]
    },
    "install-proxmox": {
      "description": "Install Proxmox VE on the Debian host from the repo-managed package path.",
      "lifecycle_status": "active",
      "preferred_entrypoint": {
        "kind": "make_target",
        "target": "install-proxmox",
        "command": "make install-proxmox"
      },
      "preflight": {
        "required": true,
        "required_secret_ids": [
          "bootstrap_ssh_private_key"
        ]
      },
      "validation_targets": [
        "validate",
        "syntax-check"
      ],
      "live_impact": "host_live",
      "owner_runbook": "docs/runbooks/install-proxmox.md",
      "implementation_refs": [
        "Makefile",
        "playbooks/site.yml",
        "roles/proxmox_repository/tasks/main.yml",
        "roles/proxmox_platform/tasks/main.yml"
      ],
      "outputs": [
        "Proxmox package repositories and core platform packages converged on the host."
      ],
      "verification_commands": [
        "make syntax-check",
        "ssh -i /Users/live/Documents/GITHUB_PROJECTS/proxmox_florin_server/.local/ssh/hetzner_llm_agents_ed25519 -o IdentitiesOnly=yes ops@100.118.189.95 'pveversion'"
      ]
    },
