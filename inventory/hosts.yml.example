# =============================================================================
# ServerClaw Platform — Inventory Template for Forks
# =============================================================================
# Copy this file to inventory/hosts.yml and customize for your deployment.
#
# Replace:
#   - Host names (e.g., nginx → nginx-yourname)
#   - IP addresses to match your network topology
#   - The Proxmox host entry to match your server
#
# See ADR 0386 for the full bootstrap guide.
# =============================================================================

all:
  vars:
    playbook_execution_env: "{{ env | default('production') }}"
    playbook_execution_allowed_envs:
      - production
      - staging
    playbook_execution_host_patterns:
      proxmox_hosts:
        production: "proxmox_hosts:&production"
      lv3_guests:
        production: "lv3_guests:&production"
      postgres_guests:
        production: "postgres_guests:&production"
      backup_guests:
        production: "backup_guests:&production"
      nginx_edge:
        production: nginx-yourname       # <-- CHANGE: your nginx host
      docker_runtime:
        production: docker-runtime-yourname  # <-- CHANGE
      runtime_control:
        production: runtime-control-yourname # <-- CHANGE
      postgres:
        production: postgres-yourname    # <-- CHANGE
      backup:
        production: backup-yourname      # <-- CHANGE
      monitoring:
        production: monitoring-yourname  # <-- CHANGE
      docker_build:
        production: docker-build-yourname # <-- CHANGE

  children:
    production:
      hosts:
        your-proxmox-host:               # <-- CHANGE: your Proxmox hostname
        nginx-yourname:                   # <-- CHANGE
        docker-runtime-yourname:          # <-- CHANGE
        docker-build-yourname:            # <-- CHANGE
        monitoring-yourname:              # <-- CHANGE
        postgres-yourname:                # <-- CHANGE
        backup-yourname:                  # <-- CHANGE
        runtime-control-yourname:         # <-- CHANGE

    platform:
      children:
        proxmox_hosts:
        lv3_guests:
        postgres_guests:
        backup_guests:

    proxmox_hosts:
      hosts:
        your-proxmox-host:               # <-- CHANGE
          # Your server's IP or Tailscale address
          ansible_host: 203.0.113.10     # <-- CHANGE: your server IP
          ansible_user: ops
          ansible_become: true
          ansible_become_method: sudo

    lv3_guests:
      hosts:
        # --- Edge / Ingress ---
        nginx-yourname:                   # <-- CHANGE
          ansible_host: 10.10.10.10       # Internal VM IP (customize subnet if needed)
          deployment_environment: production

        # --- Application Runtime ---
        docker-runtime-yourname:          # <-- CHANGE
          ansible_host: 10.10.10.20
          deployment_environment: production

        # --- Build Server ---
        docker-build-yourname:            # <-- CHANGE
          ansible_host: 10.10.10.30
          deployment_environment: production

        # --- Monitoring ---
        monitoring-yourname:              # <-- CHANGE
          ansible_host: 10.10.10.40
          deployment_environment: production

        # --- Database ---
        postgres-yourname:                # <-- CHANGE
          ansible_host: 10.10.10.50
          deployment_environment: production

        # --- Backup ---
        backup-yourname:                  # <-- CHANGE
          ansible_host: 10.10.10.60
          deployment_environment: production

        # --- Control Plane ---
        runtime-control-yourname:         # <-- CHANGE
          ansible_host: 10.10.10.92
          deployment_environment: production

    postgres_guests:
      hosts:
        postgres-yourname:                # <-- CHANGE

    backup_guests:
      hosts:
        backup-yourname:                  # <-- CHANGE
          ansible_host: 10.10.10.60
