services:
  step-ca:
    image: {{ step_ca_image }}
    container_name: step-ca
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          curl -fsS https://127.0.0.1:{{ step_ca_api_port }}{{ step_ca_healthcheck_path }}
          --cacert {{ step_ca_home }}/certs/root_ca.crt >/dev/null
      interval: 30s
      timeout: 15s
      retries: 3
      start_period: 10s
    environment:
      STEPPATH: {{ step_ca_home }}
    entrypoint:
      - /usr/local/bin/step-ca
    command:
      - {{ step_ca_home }}/config/ca.json
      - --password-file
      - {{ step_ca_ca_password_file }}
    ports:
      - "{{ step_ca_api_port }}:{{ step_ca_api_port }}"
    volumes:
      - {{ step_ca_home }}:{{ step_ca_home }}
      - {{ step_ca_password_dir }}:{{ step_ca_password_dir }}
    healthcheck:
      test:
        - CMD-SHELL
        - step ca health --ca-url https://127.0.0.1:{{ step_ca_api_port }} --root {{ step_ca_home }}/certs/root_ca.crt 2>/dev/null | grep -q ok
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
