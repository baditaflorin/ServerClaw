# LibreChat runtime environment — generated by Ansible
HOST=0.0.0.0
PORT={{ librechat_container_port }}
MONGO_URI=mongodb://{{ librechat_mongo_container_name }}:27017/LibreChat
MEILI_HOST=http://{{ librechat_meilisearch_container_name }}:7700
NO_INDEX=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true
JWT_SECRET={{ librechat_jwt_secret }}
JWT_REFRESH_SECRET={{ librechat_jwt_refresh_secret }}
CREDS_KEY={{ librechat_creds_key }}
CREDS_IV={{ librechat_creds_iv }}
DOMAIN_CLIENT=https://chat.lv3.org
DOMAIN_SERVER=https://chat.lv3.org
{% if librechat_enable_oidc | bool %}
OPENID_ISSUER={{ librechat_oidc_issuer }}
OPENID_CLIENT_ID={{ librechat_oidc_client_id }}
OPENID_CLIENT_SECRET={{ librechat_oidc_client_secret | default('') }}
OPENID_CALLBACK_URL={{ librechat_oidc_callback_url }}
OPENID_SCOPE=openid email profile
OPENID_SESSION_SECRET={{ librechat_oidc_session_secret }}
OPENID_BUTTON_LABEL={{ librechat_oidc_button_label }}
{% endif %}
OLLAMA_BASE_URL={{ librechat_ollama_base_url }}
ANTHROPIC_API_KEY={{ librechat_anthropic_api_key }}
OPENAI_API_KEY={{ librechat_openai_api_key }}
DEBUG_LOGGING=false
