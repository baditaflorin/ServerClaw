# LibreChat configuration — generated by Ansible
# Do not edit manually; re-converge with make converge-librechat.
version: 1.2.1
cache: true

endpoints:
  ollama:
    # Direct connection to Ollama — no intermediary proxy
    baseURL: "{{ librechat_ollama_base_url }}"
    models:
      default:
        - gemma4:e4b
      fetch: true
    titleConvo: true
    titleModel: gemma4:e4b

  anthropic:
    # Direct Anthropic API — key injected via env
    models:
      default:
        - claude-sonnet-4-20250514
        - claude-haiku-4-5-20251001
        - claude-opus-4-20250115
      fetch: true
    titleConvo: true
    titleModel: claude-sonnet-4-20250514

registration:
  socialLogins:
    - openid

# System prompt as a preset — replaces the fragile Ollama model creation hack
presets:
  - title: ServerClaw
    description: LV3 platform assistant with full system context
    default: true
    endpoint: ollama
    model: gemma4:e4b
    promptPrefix: |
      {% raw %}{% include '/app/system-prompt.md' %}{% endraw %}
