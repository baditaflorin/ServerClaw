# LibreChat configuration — generated by Ansible
# Do not edit manually; re-converge with make converge-librechat.
#
# System prompt injection uses modelSpecs with enforce: false, prioritize: true.
# Each model gets a preset with promptPrefix containing the ServerClaw identity.
# Agents endpoint enabled with tool calling via the LV3 platform API gateway.
version: 1.2.1
cache: true

endpoints:
  agents:
    disableBuilder: false
    recursionLimit: 25
    maxRecursionLimit: 50
    capabilities:
      - actions
      - tools
      - artifacts
      - web_search
      - deferred_tools
      - context
      - ocr

  custom:
    - name: Ollama
      apiKey: "unused"
      baseURL: "{{ librechat_ollama_base_url }}/v1"
      models:
        default:
          - {{ librechat_ollama_default_model }}
        fetch: true
      titleConvo: true
      titleModel: {{ librechat_ollama_default_model }}
      promptPrefix: |
        {{ librechat_system_prompt_content | indent(8) }}

  openAI:
    models:
{% for model in librechat_openai_models %}
      - {{ model }}
{% endfor %}
    titleConvo: true
    titleModel: {{ librechat_openai_models[1] | default(librechat_openai_models[0]) }}

  anthropic:
    models:
{% for model in librechat_anthropic_models %}
      - {{ model }}
{% endfor %}
    titleConvo: true
    titleModel: {{ librechat_anthropic_models[0] }}

modelSpecs:
  enforce: false
  prioritize: true
  list:
{% for model in librechat_anthropic_models %}
    - name: "{{ model }}"
      label: "{{ model }}"
      preset:
        endpoint: "anthropic"
        model: "{{ model }}"
        promptPrefix: |
          {{ librechat_system_prompt_content | indent(10) }}
{% endfor %}
{% for model in librechat_openai_models %}
    - name: "{{ model }}"
      label: "{{ model }}"
      preset:
        endpoint: "openAI"
        model: "{{ model }}"
        promptPrefix: |
          {{ librechat_system_prompt_content | indent(10) }}
{% endfor %}
    - name: "{{ librechat_ollama_default_model }}"
      label: "{{ librechat_ollama_default_model }}"
      preset:
        endpoint: "Ollama"
        model: "{{ librechat_ollama_default_model }}"
        promptPrefix: |
          {{ librechat_system_prompt_content | indent(10) }}

actions:
  allowedDomains:
    - "{{ librechat_api_gateway_host }}"

registration:
  socialLogins:
    - openid
