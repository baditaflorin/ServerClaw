# LibreChat configuration — generated by Ansible
# Do not edit manually; re-converge with make converge-librechat.
version: 1.2.1
cache: true

endpoints:
  custom:
    - name: Ollama
      apiKey: "unused"
      baseURL: "{{ librechat_ollama_base_url }}/v1"
      models:
        default:
          - gemma4:e4b
        fetch: true
      titleConvo: true
      titleModel: gemma4:e4b

  openAI:
    models:
      default:
        - gpt-4o
        - gpt-4o-mini
        - o3-mini
      fetch: true
    titleConvo: true
    titleModel: gpt-4o-mini

  anthropic:
    models:
      default:
        - claude-sonnet-4-20250514
        - claude-haiku-4-5-20251001
        - claude-opus-4-20250115
      fetch: true
    titleConvo: true
    titleModel: claude-sonnet-4-20250514

registration:
  socialLogins:
    - openid
