services:
{% if librechat_enable_openbao_agent | bool %}
  openbao-agent:
    image: {{ librechat_openbao_agent_image }}
    container_name: {{ librechat_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ librechat_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ librechat_openbao_agent_dir }}:/openbao-agent:ro
      - {{ librechat_env_file | dirname }}:{{ librechat_env_file | dirname }}
{% endif %}

  mongodb:
    image: {{ librechat_mongo_image }}
    container_name: {{ librechat_mongo_container_name }}
    restart: unless-stopped
    volumes:
      - {{ librechat_mongo_data_dir }}:/data/db
    command: mongod --noauth
    healthcheck:
      test:
        - CMD
        - mongosh
        - --eval
        - "db.adminCommand('ping')"
      interval: 30s
      timeout: 10s
      retries: 3

  meilisearch:
    image: {{ librechat_meilisearch_image }}
    container_name: {{ librechat_meilisearch_container_name }}
    restart: unless-stopped
    environment:
      MEILI_NO_ANALYTICS: "true"
    volumes:
      - {{ librechat_meilisearch_data_dir }}:/meili_data
    healthcheck:
      test:
        - CMD-SHELL
        - "curl -sf http://localhost:7700/health || exit 1"
      interval: 30s
      timeout: 10s
      retries: 3

  librechat:
    image: {{ librechat_image }}
    container_name: {{ librechat_container_name }}
    restart: unless-stopped
    depends_on:
      mongodb:
        condition: service_healthy
      meilisearch:
        condition: service_healthy
{% if librechat_enable_openbao_agent | bool %}
      openbao-agent:
        condition: service_healthy
{% endif %}
    env_file:
      - {{ librechat_env_file }}
    ports:
      - "{{ ansible_host }}:{{ librechat_internal_port }}:{{ librechat_container_port }}"
      - "127.0.0.1:{{ librechat_internal_port }}:{{ librechat_container_port }}"
    volumes:
      - {{ librechat_config_file }}:/app/librechat.yaml:ro
      - {{ librechat_system_prompt_file }}:/app/system-prompt.md:ro
      - {{ librechat_data_dir }}/images:/app/client/public/images
      - {{ librechat_data_dir }}/logs:/app/api/logs
{% if librechat_extra_hosts | length > 0 %}
    extra_hosts:
{% for host in librechat_extra_hosts %}
      - "{{ host }}"
{% endfor %}
{% endif %}
    healthcheck:
      test:
        - CMD-SHELL
        - "curl -sf http://localhost:{{ librechat_container_port }}/api/health || exit 1"
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
