{# compose_macros.j2 — Plane-specific Docker Compose Jinja2 macros #}
{# Adapted from common/templates/compose_macros.j2 (ADR 0368) #}
{# Uses direct variable references instead of vars[] to avoid ansible-core 2.20 deprecation #}

{% macro openbao_sidecar(prefix) %}
  openbao-agent:
    image: {{ plane_openbao_agent_image }}
    container_name: {{ plane_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ plane_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ plane_openbao_agent_dir }}:/openbao-agent:ro
      - {{ plane_env_file | dirname }}:{{ plane_env_file | dirname }}
{% endmacro %}

{% macro healthcheck(type, port, path="/", interval=10, timeout=5, retries=12, start_period=None) %}
    healthcheck:
      test:
        - CMD-SHELL
{% if type == "wget" %}
        - wget --no-verbose --tries=1 --spider http://127.0.0.1:{{ port }}{{ path }} || exit 1
{% elif type == "curl" %}
        - curl -fsS http://127.0.0.1:{{ port }}{{ path }} > /dev/null || exit 1
{% elif type == "pg_isready" %}
        - pg_isready -U {{ path }} -d {{ path }}
{% elif type == "redis" %}
        - redis-cli ping | grep -q PONG
{% elif type == "file_exists" %}
        - test -s {{ path }}
{% endif %}
      interval: {{ interval }}s
      timeout: {{ timeout }}s
      retries: {{ retries }}
{% if start_period is not none %}
      start_period: {{ start_period }}s
{% endif %}
{% endmacro %}

{% macro logging(max_size="10m", max_file="3") %}
    logging:
      driver: json-file
      options:
        max-size: "{{ max_size }}"
        max-file: "{{ max_file }}"
{% endmacro %}

{% macro service_network() %}
networks:
  lv3_service_net:
    external: true
{% endmacro %}

{% macro hairpin_hosts() %}
{% if platform_hairpin_nat_hosts | default([]) | length > 0 %}
    extra_hosts:
{% for entry in platform_hairpin_nat_hosts %}
      - "{{ entry.hostname }}:{{ entry.address }}"
{% endfor %}
{% endif %}
{% endmacro %}
