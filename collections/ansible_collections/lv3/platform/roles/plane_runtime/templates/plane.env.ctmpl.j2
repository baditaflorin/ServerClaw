APP_RELEASE={{ plane_app_release }}
APP_DOMAIN={{ plane_service_topology.public_hostname }}
WEB_URL={{ plane_public_base_url }}
DEBUG=0
CORS_ALLOWED_ORIGINS={{ plane_public_base_url }}
API_BASE_URL=http://api:8000
PGHOST={{ plane_database_host }}
PGDATABASE={{ plane_database_name }}
POSTGRES_USER={{ plane_database_user }}
POSTGRES_PASSWORD=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.DATABASE_PASSWORD ]][[ end ]]
POSTGRES_DB={{ plane_database_name }}
POSTGRES_PORT=5432
DATABASE_URL=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.DATABASE_URL ]][[ end ]]
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.RABBITMQ_PASSWORD ]][[ end ]]
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.RABBITMQ_PASSWORD | urlquery ]][[ end ]]@plane-mq:5672/plane
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.RABBITMQ_PASSWORD ]][[ end ]]
RABBITMQ_DEFAULT_VHOST=plane
SECRET_KEY=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.SECRET_KEY ]][[ end ]]
LIVE_SERVER_SECRET_KEY=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.LIVE_SERVER_SECRET_KEY ]][[ end ]]
AWS_ACCESS_KEY_ID={{ plane_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.AWS_SECRET_ACCESS_KEY ]][[ end ]]
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME={{ plane_s3_bucket_name }}
BUCKET_NAME={{ plane_s3_bucket_name }}
MINIO_ROOT_USER={{ plane_minio_root_user }}
MINIO_ROOT_PASSWORD=[[ with secret "kv/data/{{ plane_openbao_secret_path }}" ]][[ .Data.data.AWS_SECRET_ACCESS_KEY ]][[ end ]]
USE_MINIO=1
MINIO_ENDPOINT_SSL=0
FILE_SIZE_LIMIT=5242880
LISTEN_HTTP_PORT=80
SITE_ADDRESS=:80
GUNICORN_WORKERS={{ plane_gunicorn_workers }}
