{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("jupyterhub") }}

  minio:
    image: {{ jupyterhub_minio_image }}
    container_name: {{ jupyterhub_minio_container_name }}
    restart: unless-stopped
    command:
      - server
      - --console-address
      - :9001
      - /data
    environment:
      MINIO_ROOT_USER: {{ jupyterhub_minio_root_user }}
      MINIO_ROOT_PASSWORD: {{ jupyterhub_minio_root_password }}
    volumes:
      - {{ jupyterhub_minio_data_dir }}:/data
    healthcheck:
      test:
        - CMD-SHELL
        - curl -fsS http://127.0.0.1:9000/minio/health/live >/dev/null
      interval: 10s
      timeout: 5s
      retries: 12

  jupyterhub:
    image: {{ jupyterhub_hub_image_name }}:latest
    container_name: {{ jupyterhub_container_name }}
    restart: unless-stopped
    depends_on:
      minio:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
    extra_hosts:
{% for item in jupyterhub_public_hostname_overrides %}
      - "{{ item.hostname }}:{{ item.address }}"
{% endfor %}
    env_file:
      - {{ jupyterhub_env_file }}
    ports:
      - "{{ ansible_host }}:{{ jupyterhub_internal_port }}:8000"
      - "127.0.0.1:{{ jupyterhub_internal_port }}:8000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ jupyterhub_config_file }}:/srv/jupyterhub/jupyterhub_config.py:ro
      - {{ jupyterhub_hub_data_dir }}:/data
    healthcheck:
      test:
        - CMD
        - python
        - -c
        - import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/hub/health', timeout=5)
      interval: 10s
      timeout: 5s
      retries: 24

networks:
  default:
    name: {{ jupyterhub_compose_network_name }}
