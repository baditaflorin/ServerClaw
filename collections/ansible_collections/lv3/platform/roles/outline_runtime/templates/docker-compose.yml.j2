{% from 'compose_macros.j2' import openbao_sidecar, redis_service %}
services:
{{ openbao_sidecar("outline") }}

{{ redis_service(
  "outline",
  data_dir_key=None,
  append_only=false,
  extra_command_args=["--maxmemory-policy", "noeviction"],
  healthcheck_retries=12,
  healthcheck_grep="PONG"
) }}

  outline:
    image: {{ outline_image }}
    container_name: {{ outline_container_name }}
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
    extra_hosts:
{% for item in outline_public_hostname_overrides %}
      - "{{ item.hostname }}:{{ item.address }}"
{% endfor %}
    env_file:
      - {{ outline_env_file }}
    ports:
      - "{{ ansible_host }}:{{ outline_internal_port }}:3000"
      - "127.0.0.1:{{ outline_internal_port }}:3000"
    healthcheck:
      test:
        - CMD-SHELL
        - wget --no-verbose --tries=1 --spider http://127.0.0.1:3000/_health || exit 1
      interval: 10s
      timeout: 5s
      retries: 24
