{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("vikunja") }}

  vikunja:
    image: {{ vikunja_image }}
    container_name: {{ vikunja_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ vikunja_env_file }}
    ports:
      - "{{ ansible_host }}:{{ vikunja_internal_port }}:{{ vikunja_container_port }}"
      - "127.0.0.1:{{ vikunja_internal_port }}:{{ vikunja_container_port }}"
    volumes:
      - {{ vikunja_files_dir }}:/var/lib/vikunja/files

  vikunja-webhook-bridge:
    image: {{ vikunja_bridge_image }}
    container_name: {{ vikunja_bridge_container_name }}
    restart: unless-stopped
    depends_on:
      vikunja:
        condition: service_started
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ vikunja_env_file }}
    command:
      - python
      - /app/vikunja-webhook-bridge.py
    healthcheck:
      test:
        - CMD-SHELL
        - python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:{{ vikunja_bridge_port }}/healthz', timeout=5).read()"
      interval: 10s
      timeout: 5s
      retries: 12
    volumes:
      - {{ vikunja_site_dir }}/vikunja-webhook-bridge.py:/app/vikunja-webhook-bridge.py:ro
