{% macro openbao_sidecar(
  prefix,
  service_name='openbao-agent',
  image_key='openbao_agent_image',
  container_name_key='openbao_agent_container_name',
  env_file_key='env_file',
  agent_dir_key='openbao_agent_dir',
  user='0:0',
  network_mode='host',
  restart='unless-stopped',
  agent_dir_mount_target='/openbao-agent',
  agent_dir_mount_mode='ro',
  env_dir_mount_target=None,
  env_dir_mount_mode='',
  config_path='/openbao-agent/agent.hcl',
  entrypoint=None,
  command=None,
  healthcheck_command=None,
  healthcheck_interval=10,
  healthcheck_timeout=3,
  healthcheck_retries=12,
  cap_add=None,
  security_opt=None,
  extra_environment=None,
  extra_hosts=None
) %}
{%- set image = lookup('vars', prefix ~ '_' ~ image_key) -%}
{%- set container_name = lookup('vars', prefix ~ '_' ~ container_name_key) -%}
{%- set env_file = lookup('vars', prefix ~ '_' ~ env_file_key) -%}
{%- set agent_dir = lookup('vars', prefix ~ '_' ~ agent_dir_key) -%}
{%- set env_dir = env_file | dirname -%}
{%- set env_dir_mount_target = env_dir_mount_target or env_dir -%}
{%- set command = command or ['agent', '-config=' ~ config_path] -%}
{%- set healthcheck_command = healthcheck_command or ('test -s ' ~ env_file) -%}
  {{ service_name }}:
    image: {{ image }}
    container_name: {{ container_name }}
    user: "{{ user }}"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
{% if extra_environment %}
{% for key, value in extra_environment.items() %}
      {{ key }}: {{ value | to_json }}
{% endfor %}
{% endif %}
{% if entrypoint %}
    entrypoint:
{% for part in entrypoint %}
      - {{ part | to_json }}
{% endfor %}
{% endif %}
    command:
{% for part in command %}
      - {{ part | to_json }}
{% endfor %}
{% if network_mode %}
    network_mode: {{ network_mode }}
{% endif %}
    restart: {{ restart }}
{% if extra_hosts %}
    extra_hosts:
{% for host in extra_hosts %}
      - "{{ host }}"
{% endfor %}
{% endif %}
    healthcheck:
      test:
        - CMD-SHELL
        - {{ healthcheck_command | to_json }}
      interval: {{ healthcheck_interval }}s
      timeout: {{ healthcheck_timeout }}s
      retries: {{ healthcheck_retries }}
{% if cap_add %}
    cap_add:
{% for capability in cap_add %}
      - {{ capability }}
{% endfor %}
{% endif %}
{% if security_opt %}
    security_opt:
{% for option in security_opt %}
      - {{ option }}
{% endfor %}
{% endif %}
    volumes:
      - {{ agent_dir }}:{{ agent_dir_mount_target }}{{ (':' + agent_dir_mount_mode) if agent_dir_mount_mode else '' }}
      - {{ env_dir }}:{{ env_dir_mount_target }}{{ (':' + env_dir_mount_mode) if env_dir_mount_mode else '' }}
{% endmacro %}

{% macro redis_service(
  prefix,
  service_name='redis',
  image_key='redis_image',
  container_name_key='redis_container_name',
  password_key='redis_password',
  data_dir_key='redis_dir',
  user=None,
  requirepass=true,
  use_valkey=false,
  append_only=true,
  restart='unless-stopped',
  env_file_key=None,
  extra_command_args=None,
  healthcheck_command=None,
  healthcheck_interval=5,
  healthcheck_timeout=5,
  healthcheck_retries=10,
  healthcheck_grep='-q PONG',
  include_logging=false
) %}
{%- set redis_image = lookup('vars', prefix ~ '_' ~ image_key) -%}
{%- set redis_container_name = lookup('vars', prefix ~ '_' ~ container_name_key) -%}
{%- set redis_password = lookup('vars', prefix ~ '_' ~ password_key) if requirepass else None -%}
{%- set redis_dir = lookup('vars', prefix ~ '_' ~ data_dir_key) if data_dir_key else None -%}
{%- set env_file = lookup('vars', prefix ~ '_' ~ env_file_key) if env_file_key else None -%}
  {{ service_name }}:
    image: {{ redis_image }}
    container_name: {{ redis_container_name }}
{% if user %}
    user: "{{ user }}"
{% endif %}
    restart: {{ restart }}
{% if env_file %}
    env_file:
      - {{ env_file }}
{% endif %}
    command:
{% if use_valkey %}
      - valkey-server
{% else %}
      - redis-server
{% endif %}
{% if requirepass %}
      - --requirepass
      - {{ redis_password }}
{% endif %}
{% if append_only %}
      - --appendonly
      - "yes"
{% endif %}
{% if extra_command_args %}
{% for part in extra_command_args %}
      - {{ part | to_json }}
{% endfor %}
{% endif %}
    healthcheck:
      test:
        - CMD-SHELL
{% if healthcheck_command %}
        - {{ healthcheck_command | to_json }}
{% elif requirepass %}
        - {{ ('redis-cli -a "' ~ redis_password ~ '" ping | grep ' ~ healthcheck_grep) | to_json }}
{% else %}
        - {{ ('redis-cli ping | grep ' ~ healthcheck_grep) | to_json }}
{% endif %}
      interval: {{ healthcheck_interval }}s
      timeout: {{ healthcheck_timeout }}s
      retries: {{ healthcheck_retries }}
{% if redis_dir %}
    volumes:
      - {{ redis_dir }}:/data
{% endif %}
{% if include_logging %}
{{ logging() }}
{% endif %}
{% endmacro %}

{% macro healthcheck(type, port, path="/", interval=10, timeout=5, retries=12, start_period=None) %}
    healthcheck:
      test:
        - CMD-SHELL
{% if type == "wget" %}
        - wget --no-verbose --tries=1 --spider http://127.0.0.1:{{ port }}{{ path }} || exit 1
{% elif type == "curl" %}
        - curl -fsS http://127.0.0.1:{{ port }}{{ path }} > /dev/null || exit 1
{% elif type == "pg_isready" %}
        - pg_isready -U {{ path }} -d {{ path }}
{% elif type == "redis" %}
        - redis-cli ping | grep -q PONG
{% elif type == "file_exists" %}
        - test -s {{ path }}
{% endif %}
      interval: {{ interval }}s
      timeout: {{ timeout }}s
      retries: {{ retries }}
{% if start_period is not none %}
      start_period: {{ start_period }}s
{% endif %}
{% endmacro %}

{% macro logging(max_size="10m", max_file="3") %}
    logging:
      driver: json-file
      options:
        max-size: "{{ max_size }}"
        max-file: "{{ max_file }}"
{% endmacro %}

{% macro service_network() %}
networks:
  lv3_service_net:
    external: true
{% endmacro %}

{% macro hairpin_hosts() %}
{% if platform_hairpin_nat_hosts | default([]) | length > 0 %}
    extra_hosts:
{% for entry in platform_hairpin_nat_hosts %}
      - "{{ entry.hostname }}:{{ entry.address }}"
{% endfor %}
{% endif %}
{% endmacro %}
