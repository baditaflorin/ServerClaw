pid_file = "/tmp/openbao-agent.pid"

vault {
  address = "{{ common_openbao_systemd_credentials_openbao_address | default('http://127.0.0.1:' ~ (openbao_http_port | string), true) }}"
}

auto_auth {
  method "approle" {
    mount_path = "auth/approle"

    config = {
      role_id_file_path                   = "/openbao-agent/{{ common_openbao_systemd_credentials_role_id_file | basename }}"
      secret_id_file_path                 = "/openbao-agent/{{ common_openbao_systemd_credentials_secret_id_file | basename }}"
      remove_secret_id_file_after_reading = false
    }
  }
{% if common_openbao_systemd_credentials_token_file | default('') | length > 0 %}
  sink "file" {
    config = {
      path = "{{ common_openbao_systemd_credentials_token_file }}"
      mode = 384
    }
  }
{% endif %}
}

template_config {
  exit_on_retry_failure         = true
  static_secret_render_interval = "5m"
}

template {
  source               = "/openbao-agent/{{ common_openbao_systemd_credentials_agent_template_file | basename }}"
  destination          = "{{ common_openbao_systemd_credentials_credential_file }}"
  create_dest_dirs     = true
  perms                = 384
  backup               = false
  error_on_missing_key = true
  left_delimiter       = "[["
  right_delimiter      = "]]"
}
