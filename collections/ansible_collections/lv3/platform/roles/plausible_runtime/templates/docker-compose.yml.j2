{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("plausible") }}

  plausible-db:
    image: {{ plausible_postgres_image }}
    container_name: {{ plausible_db_container_name }}
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ plausible_database_name }}
      POSTGRES_USER: {{ plausible_database_user }}
      POSTGRES_PASSWORD_FILE: /run/secrets/database-password
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U {{ plausible_database_user }} -d {{ plausible_database_name }}
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s
    secrets:
      - database-password
    volumes:
      - plausible-db-data:/var/lib/postgresql/data

  plausible-events-db:
    image: {{ plausible_clickhouse_image }}
    container_name: {{ plausible_clickhouse_container_name }}
    restart: unless-stopped
    environment:
      CLICKHOUSE_SKIP_USER_SETUP: "1"
    ulimits:
      nofile:
        soft: 262144
        hard: 262144
    healthcheck:
      test:
        - CMD-SHELL
        - wget --no-verbose --tries=1 -O - http://127.0.0.1:8123/ping || exit 1
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s
    volumes:
      - plausible-event-data:/var/lib/clickhouse
      - plausible-event-logs:/var/log/clickhouse-server
      - {{ plausible_clickhouse_config_dir }}/logs.xml:/etc/clickhouse-server/config.d/logs.xml:ro
      - {{ plausible_clickhouse_config_dir }}/ipv4-only.xml:/etc/clickhouse-server/config.d/ipv4-only.xml:ro
      - {{ plausible_clickhouse_config_dir }}/low-resources.xml:/etc/clickhouse-server/config.d/low-resources.xml:ro
      - {{ plausible_clickhouse_config_dir }}/default-profile-low-resources-overrides.xml:/etc/clickhouse-server/users.d/default-profile-low-resources-overrides.xml:ro

  plausible:
    image: {{ plausible_runtime_image }}
    container_name: {{ plausible_container_name }}
    restart: unless-stopped
    command:
      - sh
      - -c
      - /entrypoint.sh db createdb && /entrypoint.sh db migrate && /entrypoint.sh run
    depends_on:
      plausible-db:
        condition: service_healthy
      plausible-events-db:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ plausible_env_file }}
    ports:
      - "{{ ansible_host }}:{{ plausible_internal_port }}:8000"
      - "127.0.0.1:{{ plausible_internal_port }}:8000"
    ulimits:
      nofile:
        soft: 65535
        hard: 65535
    volumes:
      - plausible-data:/var/lib/plausible

secrets:
  database-password:
    file: {{ plausible_database_password_remote_file }}

volumes:
  plausible-db-data:
    name: plausible-db-data
  plausible-event-data:
    name: plausible-event-data
  plausible-event-logs:
    name: plausible-event-logs
  plausible-data:
    name: plausible-data
