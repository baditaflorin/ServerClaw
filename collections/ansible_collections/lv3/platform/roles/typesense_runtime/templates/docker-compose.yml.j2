services:
  openbao-agent:
    image: {{ typesense_openbao_agent_image }}
    container_name: {{ typesense_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ typesense_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ typesense_openbao_agent_dir }}:/openbao-agent:ro
      - {{ typesense_env_file | dirname }}:{{ typesense_env_file | dirname }}

  typesense:
    image: {{ typesense_image }}
    container_name: {{ typesense_container_name }}
    restart: unless-stopped
    env_file:
      - {{ typesense_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    ports:
      - "{{ typesense_port }}:8108"
    volumes:
      - typesense-data:/data

volumes:
  typesense-data: null
