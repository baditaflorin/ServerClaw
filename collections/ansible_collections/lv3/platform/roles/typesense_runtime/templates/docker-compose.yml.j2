{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("typesense") }}

  typesense:
    image: {{ typesense_image }}
    container_name: {{ typesense_container_name }}
    restart: unless-stopped
    env_file:
      - {{ typesense_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    ports:
      - "{{ typesense_port }}:8108"
    volumes:
      - typesense-data:/data

volumes:
  typesense-data: null
