{% from 'compose_macros.j2' import openbao_sidecar %}
version: "3.9"

services:
{{ openbao_sidecar(
  "minio",
  network_mode=None,
  agent_dir_mount_target="/vault",
  agent_dir_mount_mode="rw",
  env_dir_mount_mode="rw",
  entrypoint=["/bin/sh", "-lc"],
  command=["vault agent -config=/vault/agent.hcl"],
  extra_environment={
    "BAO_ADDR": "http://host.docker.internal:" ~ openbao_http_port,
    "BAO_SKIP_VERIFY": "true"
  },
  extra_hosts=["host.docker.internal:host-gateway"]
) }}

  minio:
    image: {{ minio_image }}
    container_name: {{ minio_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ minio_env_file }}
    command:
      - server
      - /data
      - --console-address
      - :9001
    ports:
      - "{{ minio_api_port }}:9000"
      - "{{ minio_console_port }}:9001"
    volumes:
      - {{ minio_data_dir }}:/data
