map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location /.well-known/acme-challenge/ {
        root {{ public_edge_acme_root }};
        allow all;
        try_files $uri =404;
    }

    location / {
{% if public_edge_tls_enabled %}
        return 308 https://nginx.lv3.org$request_uri;
{% else %}
        return 302 http://nginx.lv3.org$request_uri;
{% endif %}
    }
}

{% for site in public_edge_sites %}
{% set protected_site = public_edge_authenticated_sites.get(site.hostname) %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ site.hostname }}{% if site.aliases is defined and site.aliases | length > 0 %} {{ site.aliases | join(' ') }}{% endif %};

{% if site.noindex | default(false) %}
    add_header X-Robots-Tag "noindex" always;
{% endif %}

    root {{ public_edge_static_root }};

    location /.well-known/acme-challenge/ {
        root {{ public_edge_acme_root }};
        allow all;
        try_files $uri =404;
    }

{% if public_edge_tls_enabled or protected_site %}
    location / {
        return 308 https://$host$request_uri;
    }
{% elif site.kind == 'static_dir' %}
    root {{ public_edge_generated_static_root }}/{{ site.source_dir }};

    location / {
        try_files $uri $uri/ /index.html;
    }
{% elif site.kind == 'proxy' %}
    location / {
        proxy_pass {{ site.upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
    }
{% else %}
    location / {
        default_type text/html;
        try_files /{{ site.slug }}.html =404;
    }
{% endif %}
}
{% if public_edge_tls_enabled %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ site.hostname }}{% if site.aliases is defined and site.aliases | length > 0 %} {{ site.aliases | join(' ') }}{% endif %};

{% if site.noindex | default(false) %}
    add_header X-Robots-Tag "noindex" always;
{% endif %}

    ssl_certificate /etc/letsencrypt/live/{{ public_edge_cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ public_edge_cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

{% if protected_site %}
{% for path in protected_site.unauthenticated_paths | default([]) %}
    location = {{ path }} {
        proxy_pass {{ site.upstream }}{{ path }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
    }
{% endfor %}

    location /oauth2/ {
        proxy_pass {{ protected_site.auth_proxy_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header X-Auth-Request-Redirect $scheme://$host$request_uri;
    }

    location = /oauth2/auth {
        proxy_pass {{ protected_site.auth_proxy_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header Content-Length "";
        proxy_pass_request_body off;
    }

    location @oauth2_signin {
        return 302 /oauth2/sign_in?rd=$scheme://$host$request_uri;
    }
{% endif %}

{% if site.kind == 'proxy' %}
    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
        auth_request_set $auth_access_token $upstream_http_x_auth_request_access_token;
        proxy_set_header X-Auth-Request-User $auth_user;
        proxy_set_header X-Auth-Request-Email $auth_email;
        proxy_set_header X-Forwarded-Access-Token $auth_access_token;
{% endif %}
        proxy_pass {{ site.upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
    }
{% elif site.kind == 'static_dir' %}
    root {{ public_edge_generated_static_root }}/{{ site.source_dir }};

    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
{% endif %}
        try_files $uri $uri/ /index.html;
    }
{% else %}
    root {{ public_edge_static_root }};

    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
{% endif %}
        default_type text/html;
        try_files /{{ site.slug }}.html =404;
    }
{% endif %}
}
{% endif %}

{% endfor %}
