    # Intercept oauth2-proxy 500s at the callback endpoint (ADR 0376).
    # A 500 here means Keycloak invalidated the auth code (e.g. after a restart).
    # The browser holds a stale session cookie with already-used codes and will
    # keep replaying them — it cannot recover on its own.  We expire the cookie
    # server-side (Max-Age=0) so the next request starts a clean OIDC flow.
    location = /oauth2/callback {
        proxy_pass {{ protected_site.auth_proxy_upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header X-Auth-Request-Redirect $scheme://$host$request_uri;
        proxy_intercept_errors on;
        error_page 500 = @oauth2_stale_session_reset;
    }

    location @oauth2_stale_session_reset {
        # Expire the oauth2-proxy session cookie AND the CSRF cookie.
        # The CSRF cookie holds the PKCE code_verifier (oauth2-proxy uses S256).
        # If only the session cookie is expired, the stale code_verifier persists,
        # oauth2-proxy sends the wrong verifier to Keycloak → "Code not valid" on
        # every subsequent login attempt until the user manually clears cookies.
        add_header Set-Cookie "{{ public_edge_session_authority.cookie_name }}=; Path=/; Domain={{ public_edge_session_authority.cookie_domain }}; Max-Age=0; Expires=Thu, 01 Jan 1970 00:00:01 GMT; HttpOnly; Secure; SameSite=Lax" always;
        add_header Set-Cookie "{{ public_edge_session_authority.cookie_name }}_csrf=; Path=/; Domain={{ public_edge_session_authority.cookie_domain }}; Max-Age=0; Expires=Thu, 01 Jan 1970 00:00:01 GMT; HttpOnly; Secure; SameSite=Lax" always;
        add_header Cache-Control "no-store" always;
        # Redirect to Keycloak logout — this kills the Keycloak server-side session AND
        # clears the sso.{{ platform_domain }} browser cookie.  Without this step, Keycloak auto-logs the
        # user back in using its own still-valid session, generates a new code, which is
        # immediately "already used" → 500 → redirect loop.
        # post_logout_redirect_uri=/ is always registered; ops.{{ platform_domain }}/ then bounces through
        # oauth2-proxy which starts a fresh OIDC flow automatically.
        return 302 {{ public_edge_session_authority.keycloak_logout_url }}?post_logout_redirect_uri={{ ("https://" ~ public_edge_session_authority.authority_hostname ~ "/") | urlencode }}&client_id={{ public_edge_session_authority.ops_portal_client_id | urlencode }};
    }

    location @oauth2_signin {
        return 302 /oauth2/sign_in?rd=$scheme://$host$request_uri;
    }

    location @lv3_shared_logout_without_session {
        return 302 {{ oauth2_proxy_sign_out_url(public_edge_session_authority.shared_proxy_cleanup_url) }};
    }

    location @lv3_forbidden {
