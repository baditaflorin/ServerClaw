{% macro crawl_policy_headers() -%}
    add_header X-Robots-Tag "{{ public_edge_robots_meta_content }}" always;
{%- endmacro %}
{% macro robots_txt_location() -%}
    location = /robots.txt {
        root {{ public_edge_static_root }};
        default_type text/plain;
        add_header X-Robots-Tag "{{ public_edge_robots_meta_content }}" always;
        try_files /robots.txt =404;
    }
{%- endmacro %}
map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

{% macro render_security_headers(site, tls_enabled) -%}
{% if site.security_headers_enabled | default(true) %}
{% set security_headers = public_edge_security_headers_default | combine(public_edge_security_headers_overrides.get(site.hostname, {}), recursive=True) %}
{% if tls_enabled and security_headers.strict_transport_security is defined and security_headers.strict_transport_security is not none %}
    add_header Strict-Transport-Security "{{ security_headers.strict_transport_security }}" always;
{% endif %}
{% if security_headers.cross_origin_resource_policy is defined and security_headers.cross_origin_resource_policy is not none %}
    add_header Cross-Origin-Resource-Policy "{{ security_headers.cross_origin_resource_policy }}" always;
{% endif %}
{% if security_headers.x_content_type_options is defined and security_headers.x_content_type_options is not none %}
    add_header X-Content-Type-Options "{{ security_headers.x_content_type_options }}" always;
{% endif %}
{% if security_headers.x_frame_options is defined and security_headers.x_frame_options is not none %}
    add_header X-Frame-Options "{{ security_headers.x_frame_options }}" always;
{% endif %}
{% if security_headers.referrer_policy is defined and security_headers.referrer_policy is not none %}
    add_header Referrer-Policy "{{ security_headers.referrer_policy }}" always;
{% endif %}
{% if security_headers.permissions_policy is defined and security_headers.permissions_policy is not none %}
    add_header Permissions-Policy "{{ security_headers.permissions_policy }}" always;
{% endif %}
{% if security_headers.content_security_policy is defined and security_headers.content_security_policy is not none %}
    add_header Content-Security-Policy "{{ security_headers.content_security_policy }}" always;
{% endif %}
{% if security_headers.x_robots_tag is defined and security_headers.x_robots_tag is not none %}
    add_header X-Robots-Tag "{{ security_headers.x_robots_tag }}" always;
{% endif %}
{% endif %}
{%- endmacro %}

{% macro hide_upstream_security_headers(site) -%}
{% if not site.preserve_upstream_security_headers | default(false) %}
        proxy_hide_header Strict-Transport-Security;
        proxy_hide_header Cross-Origin-Resource-Policy;
        proxy_hide_header X-Content-Type-Options;
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Referrer-Policy;
        proxy_hide_header Permissions-Policy;
        proxy_hide_header Content-Security-Policy;
        proxy_hide_header X-Robots-Tag;
{% endif %}
{%- endmacro %}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

{{ crawl_policy_headers() }}
{{ robots_txt_location() }}

    location /.well-known/acme-challenge/ {
        root {{ public_edge_acme_root }};
        allow all;
        try_files $uri =404;
    }

    location / {
{% if public_edge_tls_enabled %}
        return 308 https://{{ public_edge_probe_hostname }}$request_uri;
{% else %}
        return 302 http://{{ public_edge_probe_hostname }}$request_uri;
{% endif %}
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ public_edge_apex_hostname }};

{{ crawl_policy_headers() }}
{{ robots_txt_location() }}

    location /.well-known/acme-challenge/ {
        root {{ public_edge_acme_root }};
        allow all;
        try_files $uri =404;
    }

    location / {
{% if public_edge_tls_enabled %}
        return 308 https://{{ public_edge_probe_hostname }}$request_uri;
{% else %}
        return 302 http://{{ public_edge_probe_hostname }}$request_uri;
{% endif %}
    }
}

{% if public_edge_tls_enabled %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ public_edge_apex_hostname }};

{{ crawl_policy_headers() }}
{{ robots_txt_location() }}

    ssl_certificate /etc/letsencrypt/live/{{ public_edge_cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ public_edge_cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    location / {
        return 308 https://{{ public_edge_probe_hostname }}$request_uri;
    }
}
{% endif %}

{% for site in public_edge_sites %}
{% set protected_site = public_edge_authenticated_sites[site.hostname] if site.hostname in public_edge_authenticated_sites else none %}
{% set proxy_hide_headers = site.proxy_hide_headers | default([]) %}
{% set blocked_exact_paths = site.blocked_exact_paths | default([]) %}
{% set server_sent_events = site.server_sent_events | default(false) %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ site.hostname }}{% if site.aliases is defined and site.aliases | length > 0 %} {{ site.aliases | join(' ') }}{% endif %};

{% if site.crawl_policy_enabled | default(true) %}
{{ crawl_policy_headers() }}
{{ robots_txt_location() }}
{% endif %}
{{ render_security_headers(site, false) }}

    root {{ public_edge_static_root }};

    location /.well-known/acme-challenge/ {
        root {{ public_edge_acme_root }};
        allow all;
        try_files $uri =404;
    }

{% if public_edge_tls_enabled or protected_site %}
    location / {
        return 308 https://$host$request_uri;
    }
{% elif site.kind == 'static_dir' %}
    root {{ public_edge_generated_static_root }}/{{ site.source_dir }};

    location / {
        try_files $uri $uri/ /index.html;
    }
{% elif site.kind == 'proxy' %}
{% if site.root_proxy_path is defined %}
    location = / {
        proxy_pass {{ site.upstream }}{{ site.root_proxy_path }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if server_sent_events %}
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
{% else %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_redirect http:// https://;
        proxy_buffering off;
        proxy_read_timeout 300s;
{% endif %}
    }

{% endif %}
    location / {
        proxy_pass {{ site.upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if server_sent_events %}
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
{% else %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_redirect http:// https://;
        proxy_buffering off;
        proxy_read_timeout 300s;
{% endif %}
    }
{% else %}
    location / {
        default_type text/html;
        try_files /{{ site.slug }}.html =404;
    }
{% endif %}
}
{% if public_edge_tls_enabled %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ site.hostname }}{% if site.aliases is defined and site.aliases | length > 0 %} {{ site.aliases | join(' ') }}{% endif %};

{% if site.crawl_policy_enabled | default(true) %}
{{ crawl_policy_headers() }}
{{ robots_txt_location() }}
{% endif %}
{{ render_security_headers(site, true) }}

    ssl_certificate /etc/letsencrypt/live/{{ public_edge_cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ public_edge_cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

{% if protected_site %}
{% for path in protected_site.unauthenticated_paths | default([]) %}
    location = {{ path }} {
        proxy_pass {{ site.upstream }}{{ path }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% for header_name in proxy_hide_headers %}
        proxy_hide_header {{ header_name }};
{% endfor %}
    }
{% endfor %}
{% for path in protected_site.unauthenticated_prefix_paths | default([]) %}
    location ^~ {{ path }} {
        proxy_pass {{ site.upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
{% for header_name in proxy_hide_headers %}
        proxy_hide_header {{ header_name }};
{% endfor %}
    }
{% endfor %}

    location /oauth2/ {
        proxy_pass {{ protected_site.auth_proxy_upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header X-Auth-Request-Redirect $scheme://$host$request_uri;
    }

    location = /oauth2/auth {
        proxy_pass {{ protected_site.auth_proxy_upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header Content-Length "";
        proxy_pass_request_body off;
    }

    location @oauth2_signin {
        return 302 /oauth2/sign_in?rd=$scheme://$host$request_uri;
    }
{% endif %}

{% if site.kind == 'proxy' %}
{% for blocked_path in blocked_exact_paths %}
    location = {{ blocked_path.path }} {
        return {{ blocked_path.status | default(404) }};
    }
{% endfor %}
{% if site.root_proxy_path is defined %}
    location = / {
        proxy_pass {{ site.upstream }}{{ site.root_proxy_path }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if server_sent_events %}
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
{% else %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_redirect http:// https://;
        proxy_buffering off;
        proxy_read_timeout 300s;
{% endif %}
{% for header_name in proxy_hide_headers %}
        proxy_hide_header {{ header_name }};
{% endfor %}
    }

{% endif %}
    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
        auth_request_set $auth_access_token $upstream_http_x_auth_request_access_token;
        proxy_set_header X-Auth-Request-User $auth_user;
        proxy_set_header X-Auth-Request-Email $auth_email;
        proxy_set_header X-Forwarded-Access-Token $auth_access_token;
{% endif %}
        proxy_pass {{ site.upstream }};
        proxy_http_version 1.1;
{{ hide_upstream_security_headers(site) }}
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if server_sent_events %}
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
{% else %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_redirect http:// https://;
        proxy_buffering off;
        proxy_read_timeout 300s;
{% endif %}
{% for header_name in proxy_hide_headers %}
        proxy_hide_header {{ header_name }};
{% endfor %}
    }
{% elif site.kind == 'static_dir' %}
    root {{ public_edge_generated_static_root }}/{{ site.source_dir }};

    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
{% endif %}
        try_files $uri $uri/ /index.html;
    }
{% else %}
    root {{ public_edge_static_root }};

    location / {
{% if protected_site %}
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_signin;
        auth_request_set $auth_user $upstream_http_x_auth_request_user;
        auth_request_set $auth_email $upstream_http_x_auth_request_email;
{% endif %}
        default_type text/html;
        try_files /{{ site.slug }}.html =404;
    }
{% endif %}
}
{% endif %}

{% endfor %}
