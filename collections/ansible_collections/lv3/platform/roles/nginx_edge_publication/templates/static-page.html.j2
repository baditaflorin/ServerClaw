<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="{{ public_edge_robots_meta_content }}">
  <title>{{ item.title }}</title>
{% set tracked_domain = public_edge_plausible_tracked_sites.get(item.hostname, '') if public_edge_plausible_tracked_sites is mapping else '' %}
{% if tracked_domain | length > 0 and public_edge_plausible_base_url | default('') | length > 0 %}
  <script defer data-domain="{{ tracked_domain }}" data-api="{{ public_edge_plausible_base_url }}/api/event" src="{{ public_edge_plausible_base_url }}/js/script.js"></script>
{% endif %}
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #162032;
      --muted: #59657a;
      --accent: #1e6ee8;
      --border: #dbe3f0;
    }

    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top, #ffffff 0%, var(--bg) 55%);
      color: var(--text);
    }

    main {
      max-width: 760px;
      margin: 8vh auto;
      padding: 2rem;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      box-shadow: 0 20px 40px rgba(22, 32, 50, 0.08);
    }

    .eyebrow {
      color: var(--accent);
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0.4rem 0 1rem;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
    }

    p {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.6;
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    .action {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.8rem 1.1rem;
      border-radius: 999px;
      background: var(--accent);
      color: #fff;
      font-weight: 600;
    }

    .meta {
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.95rem;
    }
  </style>
</head>
<body>
  <main>
    <section class="card">
      <div class="eyebrow">{{ item.hostname }}</div>
      <h1>{{ item.title }}</h1>
      <p>{{ item.description }}</p>
{% if item.action_url is defined %}
      <a class="action" href="{{ item.action_url }}">{{ item.action_label | default(item.action_url) }}</a>
{% endif %}
      <div class="meta">{{ item.meta }}</div>
    </section>
  </main>
</body>
</html>
