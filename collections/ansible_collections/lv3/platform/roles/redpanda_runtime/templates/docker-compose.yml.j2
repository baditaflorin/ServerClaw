services:
  openbao-agent:
    image: {{ redpanda_openbao_agent_image }}
    container_name: {{ redpanda_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ redpanda_compose_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ redpanda_openbao_agent_dir }}:/openbao-agent:ro
      - {{ redpanda_compose_env_file | dirname }}:{{ redpanda_compose_env_file | dirname }}

  redpanda:
    image: {{ redpanda_image }}
    container_name: {{ redpanda_container_name }}
    restart: unless-stopped
    network_mode: host
    depends_on:
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ redpanda_compose_env_file }}
    entrypoint:
      - /bin/bash
    command:
      - /etc/redpanda/start-redpanda.sh
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          rpk cluster info
          -X brokers=127.0.0.1:{{ redpanda_loopback_kafka_port }}
          -X user=$$REDPANDA_ADMIN_USER
          -X pass=$$REDPANDA_ADMIN_PASSWORD
          -X sasl.mechanism=$$REDPANDA_SASL_MECHANISM
          >/dev/null 2>&1
      interval: 15s
      timeout: 10s
      retries: 12
    volumes:
      - {{ redpanda_config_dir }}:/etc/redpanda
      - redpanda-data:/var/lib/redpanda/data

volumes:
  redpanda-data:
    name: {{ redpanda_volume_name }}
