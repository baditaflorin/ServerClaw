services:
  openbao-agent:
    image: {{ mail_platform_openbao_agent_image }}
    container_name: {{ mail_platform_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ mail_platform_gateway_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ mail_platform_openbao_agent_dir }}:/openbao-agent:ro
      - {{ mail_platform_gateway_env_file | dirname }}:{{ mail_platform_gateway_env_file | dirname }}

  stalwart:
    image: {{ mail_platform_stalwart_image }}
    container_name: {{ mail_platform_stalwart_container_name }}
    restart: unless-stopped
    volumes:
      - {{ mail_platform_stalwart_dir }}:/opt/stalwart
    ports:
      - "25:25"
      - "587:587"
      - "993:993"
      - "8080:8080"
      - "{{ ansible_host }}:{{ mail_platform_internal_submission_port }}:{{ mail_platform_internal_submission_port }}"

  mail-gateway:
    build: {{ mail_platform_gateway_app_dir }}
    container_name: {{ mail_platform_gateway_container_name }}
    restart: unless-stopped
    env_file:
      - {{ mail_platform_gateway_env_file }}
    volumes:
      - {{ mail_platform_gateway_data_dir }}:/data
      - {{ mail_platform_gateway_profiles_file }}:{{ mail_platform_gateway_profiles_container_file }}:ro
    ports:
      - "{{ mail_platform_gateway_bind_port }}:8081"
    depends_on:
      openbao-agent:
        condition: service_healthy
      stalwart:
        condition: service_started
