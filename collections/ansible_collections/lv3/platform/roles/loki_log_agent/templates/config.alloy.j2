logging {
  level  = "info"
  format = "logfmt"
}

{% if loki_log_agent_postgres_audit_enabled %}
{% set approved_roles_pattern = '^(?:' ~ (loki_log_agent_postgres_audit_approved_roles | map('regex_escape') | join('|')) ~ ')$' %}
{% endif %}

loki.write "lv3" {
  endpoint {
    url = "{{ loki_log_agent_loki_push_url }}"
  }
}

{% if loki_log_agent_journal_enabled %}
loki.relabel "journal" {
  forward_to = [loki.write.lv3.receiver]

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }

  rule {
    source_labels = ["__journal__systemd_unit"]
    regex         = "falco(?:-modern-bpf)?\\.service"
    replacement   = "falco"
    target_label  = "job"
  }

  rule {
    source_labels = ["__journal__systemd_unit"]
    regex         = "falco(?:-modern-bpf)?\\.service"
    replacement   = "falco"
    target_label  = "service"
  }

  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }

  rule {
    source_labels = ["__journal_syslog_identifier"]
    target_label  = "syslog_identifier"
  }
}

loki.source.journal "system" {
  forward_to    = [loki.write.lv3.receiver]
  max_age       = "{{ loki_log_agent_journal_max_age }}"
  relabel_rules = loki.relabel.journal.rules
  labels = {
    host        = "{{ loki_log_agent_hostname }}",
    node_role   = "{{ loki_log_agent_role }}",
    environment = "{{ loki_log_agent_environment }}",
    lane        = "{{ loki_log_agent_lane }}",
    source      = "journal",
  }
}
{% endif %}
{% if loki_log_agent_nginx_logs_enabled %}
loki.source.file "nginx_access" {
  targets = [
{% for log_path in loki_log_agent_nginx_access_logs %}
    {
      __path__     = "{{ log_path }}",
      host         = "{{ loki_log_agent_hostname }}",
      node_role    = "{{ loki_log_agent_role }}",
      service      = "nginx",
      environment  = "{{ loki_log_agent_environment }}",
      lane         = "{{ loki_log_agent_lane }}",
      source       = "file",
      log_type     = "access",
    },
{% endfor %}
  ]
  forward_to = [loki.write.lv3.receiver]
  file_match {
    enabled = true
  }
}

loki.source.file "nginx_error" {
  targets = [
{% for log_path in loki_log_agent_nginx_error_logs %}
    {
      __path__     = "{{ log_path }}",
      host         = "{{ loki_log_agent_hostname }}",
      node_role    = "{{ loki_log_agent_role }}",
      service      = "nginx",
      environment  = "{{ loki_log_agent_environment }}",
      lane         = "{{ loki_log_agent_lane }}",
      source       = "file",
      log_type     = "error",
    },
{% endfor %}
  ]
  forward_to = [loki.write.lv3.receiver]
  file_match {
    enabled = true
  }
}
{% endif %}
{% if loki_log_agent_docker_logs_enabled %}
discovery.docker "containers" {
  host             = "{{ loki_log_agent_docker_host }}"
  refresh_interval = "{{ loki_log_agent_docker_refresh_interval }}"
}

loki.relabel "docker" {
  forward_to = [loki.write.lv3.receiver]

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    replacement   = "$1"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "compose_project"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }
}

loki.source.docker "containers" {
  host          = "{{ loki_log_agent_docker_host }}"
  targets       = discovery.docker.containers.targets
  relabel_rules = loki.relabel.docker.rules
  forward_to    = [loki.write.lv3.receiver]
  labels = {
    host        = "{{ loki_log_agent_hostname }}",
    node_role   = "{{ loki_log_agent_role }}",
    environment = "{{ loki_log_agent_environment }}",
    lane        = "{{ loki_log_agent_lane }}",
    source      = "docker",
  }
}
{% endif %}
{% if loki_log_agent_postgres_audit_enabled %}
loki.process "postgres_audit" {
  forward_to = [loki.write.lv3.receiver]

  stage.regex {
    expression = "^(?P<log_ts>[^\\[]+)\\[(?P<pid>\\d+)\\]\\s+(?:(?P<db_role>[^@\\s]+)@(?P<db>\\S+)\\s+)?(?P<message>.*)$"
  }

  stage.labels {
    values = {
      db      = "",
      db_role = "",
    }
  }

  stage.match {
    selector      = "{job=\"postgres-audit\"} |~ \"AUDIT:\""
    pipeline_name = "postgres_audit_lines"

    stage.regex {
      source     = "message"
      expression = "^[A-Z]+:\\s+AUDIT:\\s+(?P<audit_type>SESSION|OBJECT),(?P<statement_id>[^,]+),(?P<substatement_id>[^,]+),(?P<command_class>[^,]+),(?P<command>[^,]*),(?P<object_type>[^,]*),(?P<object_name>[^,]*),"
    }

    stage.labels {
      values = {
        audit_type    = "",
        command       = "",
        command_class = "",
        object_type   = "",
      }
    }

    stage.metrics {
      metric.counter {
        name              = "postgres_audit_events_total"
        description       = "PostgreSQL audit events parsed from pgaudit log lines"
        prefix            = ""
        match_all         = true
        action            = "inc"
        max_idle_duration = "24h"
      }
    }
  }

  stage.match {
    selector      = "{job=\"postgres-audit\"} |~ \"connection authorized:\""
    pipeline_name = "postgres_connection_authorized"

    stage.regex {
      source     = "message"
      expression = "^[A-Z]+:\\s+connection authorized:\\s+user=(?P<connection_role>\\S+)\\s+database=(?P<connection_db>\\S+).*"
    }

    stage.labels {
      values = {
        db      = "connection_db",
        db_role = "connection_role",
      }
    }

    stage.metrics {
      metric.counter {
        name              = "postgres_connection_authorized_total"
        description       = "Authorized PostgreSQL connection events parsed from server logs"
        prefix            = ""
        match_all         = true
        action            = "inc"
        max_idle_duration = "24h"
      }
    }

    stage.match {
      selector = "{db_role!~\"{{ approved_roles_pattern }}\"}"

      stage.metrics {
        metric.counter {
          name              = "postgres_unknown_connection_events_total"
          description       = "Authorized PostgreSQL connection events from roles outside the approved login-role catalog"
          prefix            = ""
          match_all         = true
          action            = "inc"
          max_idle_duration = "24h"
        }
      }
    }
  }
}

loki.source.file "postgres_audit" {
  targets = [
{% for log_path in loki_log_agent_postgres_audit_paths %}
    {
      __path__     = "{{ log_path }}",
      host         = "{{ loki_log_agent_hostname }}",
      node_role    = "{{ loki_log_agent_role }}",
      service      = "postgres",
      job          = "postgres-audit",
      environment  = "{{ loki_log_agent_environment }}",
      lane         = "{{ loki_log_agent_lane }}",
      source       = "file",
      log_type     = "postgresql",
    },
{% endfor %}
  ]
  forward_to = [loki.process.postgres_audit.receiver]
  file_match {
    enabled = true
  }
}
{% endif %}
{% for scrape in loki_log_agent_file_scrapes %}
loki.source.file "{{ scrape.name }}" {
  targets = [
{% for log_path in scrape.paths %}
    {
      __path__     = "{{ log_path }}",
      host         = "{{ loki_log_agent_hostname }}",
      node_role    = "{{ loki_log_agent_role }}",
      environment  = "{{ loki_log_agent_environment }}",
      lane         = "{{ loki_log_agent_lane }}",
{% for label_key, label_value in scrape.labels.items() %}
      {{ label_key }} = "{{ label_value }}",
{% endfor %}
    },
{% endfor %}
  ]
  forward_to = [loki.write.lv3.receiver]
  file_match {
    enabled = true
  }
}
{% endfor %}
