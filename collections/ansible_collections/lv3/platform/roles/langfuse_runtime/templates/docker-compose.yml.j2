services:
  openbao-agent:
    image: {{ langfuse_openbao_agent_image }}
    container_name: {{ langfuse_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ langfuse_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ langfuse_openbao_agent_dir }}:/openbao-agent:ro
      - {{ langfuse_env_file | dirname }}:{{ langfuse_env_file | dirname }}

  clickhouse:
    image: {{ langfuse_clickhouse_image }}
    container_name: {{ langfuse_clickhouse_container_name }}
    restart: unless-stopped
    user: "101:101"
    environment:
      CLICKHOUSE_DB: default
      CLICKHOUSE_USER: {{ langfuse_clickhouse_user }}
      CLICKHOUSE_PASSWORD: {{ langfuse_clickhouse_password }}
    healthcheck:
      test:
        - CMD-SHELL
        - wget --no-verbose --tries=1 --spider http://127.0.0.1:8123/ping || exit 1
      interval: 5s
      timeout: 5s
      retries: 10
    volumes:
      - {{ langfuse_clickhouse_data_dir }}:/var/lib/clickhouse
      - {{ langfuse_clickhouse_log_dir }}:/var/log/clickhouse-server

  redis:
    image: {{ langfuse_redis_image }}
    container_name: {{ langfuse_redis_container_name }}
    restart: unless-stopped
    user: "{{ langfuse_redis_uid }}:{{ langfuse_redis_gid }}"
    command:
      - redis-server
      - --requirepass
      - {{ langfuse_redis_password }}
      - --maxmemory-policy
      - noeviction
    healthcheck:
      test:
        - CMD-SHELL
        - redis-cli -a "{{ langfuse_redis_password }}" ping | grep PONG
      interval: 5s
      timeout: 5s
      retries: 10
    volumes:
      - {{ langfuse_redis_data_dir }}:/data

  langfuse-worker:
    image: {{ langfuse_worker_image }}
    container_name: {{ langfuse_worker_container_name }}
    restart: unless-stopped
    depends_on:
      clickhouse:
        condition: service_healthy
      redis:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ langfuse_env_file }}
    extra_hosts:
      - "sso.lv3.org:{{ hostvars['nginx-lv3'].ansible_host }}"

  langfuse-web:
    image: {{ langfuse_web_image }}
    container_name: {{ langfuse_web_container_name }}
    restart: unless-stopped
    depends_on:
      clickhouse:
        condition: service_healthy
      redis:
        condition: service_healthy
      langfuse-worker:
        condition: service_started
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ langfuse_env_file }}
    extra_hosts:
      - "sso.lv3.org:{{ hostvars['nginx-lv3'].ansible_host }}"
    ports:
      - "{{ ansible_host }}:{{ langfuse_internal_port }}:3000"
      - "127.0.0.1:{{ langfuse_internal_port }}:3000"
    healthcheck:
      test:
        - CMD-SHELL
        - wget --no-verbose --tries=1 --spider http://127.0.0.1:3000/api/public/health || exit 1
      interval: 10s
      timeout: 5s
      retries: 20
