services:
{% if litellm_enable_openbao_agent | bool %}
  openbao-agent:
    image: {{ litellm_openbao_agent_image }}
    container_name: {{ litellm_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ litellm_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ litellm_openbao_agent_dir }}:/openbao-agent:ro
      - {{ litellm_env_file | dirname }}:{{ litellm_env_file | dirname }}
{% endif %}

  litellm:
    image: {{ litellm_image }}
    container_name: {{ litellm_container_name }}
    restart: unless-stopped
{% if litellm_enable_openbao_agent | bool %}
    depends_on:
      openbao-agent:
        condition: service_healthy
{% endif %}
    env_file:
      - {{ litellm_env_file }}
    volumes:
      - {{ litellm_config_file }}:/app/config.yaml:ro
    ports:
      - "{{ ansible_host }}:{{ litellm_internal_port }}:{{ litellm_container_port }}"
      - "127.0.0.1:{{ litellm_internal_port }}:{{ litellm_container_port }}"
    command:
      - --config
      - /app/config.yaml
      - --port
      - "{{ litellm_container_port }}"
    healthcheck:
      test:
        - CMD-SHELL
        - "curl -sf http://localhost:{{ litellm_container_port }}/health/liveliness || exit 1"
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
