# LiteLLM Proxy configuration — generated from config/llm-gateway/model-catalog.yaml
# Do not edit manually; re-converge with make converge-litellm.

model_list:
  # Ollama local models
  - model_name: gemma4:e4b
    litellm_params:
      model: ollama/gemma4:e4b
      api_base: {{ litellm_ollama_base_url }}

  - model_name: nomic-embed-text
    litellm_params:
      model: ollama/nomic-embed-text
      api_base: {{ litellm_ollama_base_url }}

  # OpenAI-compatible aliases (for consumers that send gpt-* model names)
  - model_name: gpt-4o-mini
    litellm_params:
      model: ollama/gemma4:e4b
      api_base: {{ litellm_ollama_base_url }}

  - model_name: gpt-4.1-mini
    litellm_params:
      model: ollama/gemma4:e4b
      api_base: {{ litellm_ollama_base_url }}

  - model_name: text-embedding-3-small
    litellm_params:
      model: ollama/nomic-embed-text
      api_base: {{ litellm_ollama_base_url }}

  # Anthropic Claude models
  - model_name: claude-sonnet-4-20250514
    litellm_params:
      model: anthropic/claude-sonnet-4-20250514
      api_key: os.environ/ANTHROPIC_API_KEY

  - model_name: claude-haiku-4-5-20251001
    litellm_params:
      model: anthropic/claude-haiku-4-5-20251001
      api_key: os.environ/ANTHROPIC_API_KEY

  - model_name: claude-opus-4-20250115
    litellm_params:
      model: anthropic/claude-opus-4-20250115
      api_key: os.environ/ANTHROPIC_API_KEY

litellm_settings:
  drop_params: true
  set_verbose: false
  num_retries: 2
  request_timeout: 600
  fallbacks:
    - gemma4:e4b:
        - model: ollama/qwen2.5:7b
          api_base: {{ litellm_ollama_base_url }}

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
