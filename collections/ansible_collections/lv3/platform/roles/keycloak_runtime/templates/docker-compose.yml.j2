{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("keycloak") }}

  keycloak:
    image: {{ keycloak_image }}
    restart: unless-stopped
    command:
      - start
    env_file:
      - {{ keycloak_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    networks:
      - default
{% if keycloak_mail_platform_docker_network_name | length > 0 %}
      - mail-platform
{% endif %}
    ports:
      - "{{ ansible_host }}:{{ keycloak_internal_http_port }}:8080"
      - "127.0.0.1:{{ keycloak_local_http_port }}:8080"
      - "127.0.0.1:{{ keycloak_local_management_port }}:9000"

{% if keycloak_mail_platform_docker_network_name | length > 0 %}
networks:
  mail-platform:
    external: true
    name: {{ keycloak_mail_platform_docker_network_name }}
{% endif %}
