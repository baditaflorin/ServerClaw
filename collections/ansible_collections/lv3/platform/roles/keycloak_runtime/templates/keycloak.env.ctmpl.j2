KEYCLOAK_IMAGE={{ keycloak_image }}
KC_DB=postgres
KC_DB_URL_HOST={{ keycloak_database_host }}
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE={{ keycloak_database_name }}
KC_DB_USERNAME={{ keycloak_database_user }}
KC_DB_PASSWORD=[[ with secret "kv/data/{{ keycloak_openbao_secret_path }}" ]][[ .Data.data.KC_DB_PASSWORD ]][[ end ]]
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true
KC_HTTP_ENABLED=true
KC_PROXY_HEADERS=xforwarded
KC_CACHE=local
KC_HOSTNAME={{ keycloak_public_base_url }}
KC_HOSTNAME_STRICT=true
KC_BOOTSTRAP_ADMIN_USERNAME={{ keycloak_bootstrap_admin_username }}
KC_BOOTSTRAP_ADMIN_PASSWORD=[[ with secret "kv/data/{{ keycloak_openbao_secret_path }}" ]][[ .Data.data.KC_BOOTSTRAP_ADMIN_PASSWORD ]][[ end ]]
