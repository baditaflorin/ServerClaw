services:
  ops-portal:
    build:
      context: {{ ops_portal_build_context_dir }}
      network: host
    image: {{ ops_portal_service_image_name }}:latest
    container_name: {{ ops_portal_container_name }}
    restart: unless-stopped
    network_mode: {{ ops_portal_network_mode }}
    command:
      - uvicorn
      - ops_portal.app:app
      - --host
      - 0.0.0.0
      - --port
      - "{{ ops_portal_container_port }}"
      - --proxy-headers
      - --forwarded-allow-ips
      - "*"
    env_file:
      - {{ ops_portal_env_file }}
    volumes:
      - {{ ops_portal_data_dir }}:/srv/ops-portal/data:ro
    healthcheck:
      test:
        - CMD
        - python
        - -c
        - import urllib.request; urllib.request.urlopen('http://127.0.0.1:{{ ops_portal_container_port }}/health', timeout=5)
      interval: 30s
      timeout: 5s
      retries: 3
