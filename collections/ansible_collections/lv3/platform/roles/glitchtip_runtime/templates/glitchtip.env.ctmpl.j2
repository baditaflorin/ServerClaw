ALLOWED_HOSTS={{ glitchtip_service_topology.public_hostname }},{{ ansible_host }},127.0.0.1,localhost
DATABASE_URL=[[ with secret "kv/data/{{ glitchtip_openbao_secret_path }}" ]][[ .Data.data.DATABASE_URL ]][[ end ]]
VALKEY_URL=[[ with secret "kv/data/{{ glitchtip_openbao_secret_path }}" ]][[ .Data.data.VALKEY_URL ]][[ end ]]
SECRET_KEY=[[ with secret "kv/data/{{ glitchtip_openbao_secret_path }}" ]][[ .Data.data.SECRET_KEY ]][[ end ]]
GLITCHTIP_DOMAIN={{ glitchtip_public_base_url }}
PORT=8000
ENABLE_USER_REGISTRATION=false
ENABLE_ORGANIZATION_CREATION=false
ENABLE_ADMIN=true
DEFAULT_FROM_EMAIL={{ glitchtip_default_from_email }}
DEFAULT_REPLY_TO_EMAIL={{ glitchtip_default_reply_to_email }}
EMAIL_URL=[[ with secret "kv/data/{{ glitchtip_openbao_secret_path }}" ]][[ .Data.data.EMAIL_URL ]][[ end ]]
GLITCHTIP_INSTANCE_NAME={{ glitchtip_instance_name }}
MEDIA_ROOT=/code/uploads
