ALLOWED_HOSTS={{ glitchtip_service_topology.public_hostname }},{{ ansible_host }},127.0.0.1,localhost
DATABASE_URL=postgresql://{{ glitchtip_database_user }}:{{ glitchtip_database_password | urlencode }}@{{ glitchtip_database_host }}:5432/{{ glitchtip_database_name }}
VALKEY_URL=redis://:{{ glitchtip_valkey_password | urlencode | replace('/', '%2F') }}@valkey:6379/0
SECRET_KEY={{ glitchtip_secret_key }}
GLITCHTIP_DOMAIN={{ glitchtip_public_base_url }}
PORT=8000
ENABLE_USER_REGISTRATION=false
ENABLE_ORGANIZATION_CREATION=false
ENABLE_ADMIN=true
DEFAULT_FROM_EMAIL={{ glitchtip_default_from_email }}
DEFAULT_REPLY_TO_EMAIL={{ glitchtip_default_reply_to_email }}
EMAIL_URL={{ glitchtip_mail_url_scheme }}://{{ glitchtip_mail_username | urlencode }}:{{ glitchtip_mail_submission_password | urlencode }}@{{ glitchtip_mail_host }}:{{ glitchtip_mail_port }}
GLITCHTIP_INSTANCE_NAME={{ glitchtip_instance_name }}
MEDIA_ROOT=/code/uploads
