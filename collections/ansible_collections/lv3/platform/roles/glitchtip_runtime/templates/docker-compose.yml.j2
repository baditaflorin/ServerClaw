{% from 'compose_macros.j2' import openbao_sidecar, redis_service %}
services:
{{ openbao_sidecar("glitchtip") }}

{{ redis_service(
  "glitchtip",
  service_name="valkey",
  image_key="valkey_image",
  container_name_key="valkey_container_name",
  password_key="valkey_password",
  data_dir_key=None,
  use_valkey=true,
  append_only=false,
  healthcheck_retries=12,
  healthcheck_grep="PONG"
) }}

  glitchtip:
    image: {{ glitchtip_image }}
    container_name: {{ glitchtip_container_name }}
    restart: unless-stopped
    command:
      - ./bin/run-all-in-one.sh
    depends_on:
      valkey:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ glitchtip_env_file }}
    ports:
      - "{{ ansible_host }}:{{ glitchtip_internal_port }}:8000"
      - "127.0.0.1:{{ glitchtip_internal_port }}:8000"
    volumes:
      - {{ glitchtip_uploads_dir }}:/code/uploads
    healthcheck:
      test:
        - CMD
        - python
        - -c
        - import urllib.request; urllib.request.urlopen("http://127.0.0.1:8000/api/0/internal/health/", timeout=5).read()
      interval: 10s
      timeout: 5s
      retries: 24
