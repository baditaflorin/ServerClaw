# Neko Remote Desktop Runtime Environment
# Generated by ansible neko_runtime role
# Generated at: {{ ansible_date_time.iso8601 }}

# Service Identity
SERVICE_NAME=neko
SERVICE_ROLE=neko_runtime
NEKO_VERSION={{ neko_runtime_image_tag }}

# Deployment Context (for debugging and audit)
DEPLOYMENT_HOST={{ inventory_hostname }}
DEPLOYMENT_TIMESTAMP={{ ansible_date_time.iso8601 }}
DEPLOYMENT_USER=ansible

# Network Configuration
NEKO_LISTEN_PORT={{ neko_runtime_port }}
NEKO_DATA_DIR={{ neko_runtime_data_dir }}

# Browser Configuration
NEKO_BROWSER_ENGINE={{ neko_runtime_browser }}
NEKO_DISPLAY_WIDTH={{ (neko_runtime_res.split('x'))[0] }}
NEKO_DISPLAY_HEIGHT={{ (neko_runtime_res.split('x'))[1] }}

# Session Configuration
NEKO_MAX_CONCURRENT_SESSIONS={{ neko_runtime_max_connections }}
{% if neko_runtime_password %}
NEKO_PASSWORD={{ neko_runtime_password }}
{% else %}
# NEKO_PASSWORD=<not configured (public access)>
{% endif %}

# WebRTC Configuration
{% if neko_runtime_stun_server %}
NEKO_STUN_SERVER={{ neko_runtime_stun_server }}
{% else %}
# NEKO_STUN_SERVER=<using Neko defaults>
{% endif %}

{% if neko_runtime_turn_servers | length > 0 %}
NEKO_TURN_SERVERS={{ neko_runtime_turn_servers | join(',') }}
{% else %}
# NEKO_TURN_SERVERS=<none configured>
{% endif %}

# Resource Limits
NEKO_CPU_LIMIT={{ neko_runtime_cpu_limit }}
NEKO_MEMORY_LIMIT={{ neko_runtime_memory_limit }}

# Health Check
NEKO_HEALTHCHECK_INTERVAL={{ neko_runtime_healthcheck_interval }}
NEKO_HEALTHCHECK_TIMEOUT={{ neko_runtime_healthcheck_timeout }}
NEKO_HEALTHCHECK_RETRIES={{ neko_runtime_healthcheck_retries }}

# Logging
NEKO_LOG_DRIVER={{ neko_runtime_log_driver }}
NEKO_LOG_MAX_SIZE={{ neko_runtime_log_max_size }}
NEKO_LOG_MAX_FILE={{ neko_runtime_log_max_file }}

# Architecture References (for troubleshooting)
# Signalling Path: Operator → NGINX (TLS) → runtime-comms:{{ neko_runtime_port }}
# Media Path: Neko (UDP 50000-60000) ← Proxmox host forwarding ← Operator
# See ADR 0380 for full architecture and firewall configuration
