---
# Neko instance: {{ _inst_name }} ({{ _inst_email }})
# Generated by neko_runtime role — do not edit manually

version: '3.8'

services:
  neko-{{ _inst_name }}:
    image: "{{ neko_runtime_image_name }}:{{ neko_runtime_image_tag }}"
    container_name: "neko-{{ _inst_name }}"
    restart: "{{ _inst_restart }}"

    # Host networking: required for WebRTC UDP media streams
    # UDP range {{ _inst_udp_range }} is assigned exclusively to this instance
    network_mode: host

    environment:
      NEKO_SERVER_BIND: "0.0.0.0:{{ _inst_port }}"
      NEKO_BROWSER: "{{ _inst_browser }}"
      NEKO_SCREEN_WIDTH: "{{ (_inst_res.split('x'))[0] }}"
      NEKO_SCREEN_HEIGHT: "{{ (_inst_res.split('x'))[1] }}"
      NEKO_MAX_CONNECTIONS: "{{ _inst_max_connections }}"
      # UDP ephemeral port range assigned to this instance (avoids conflicts)
      NEKO_EPR: "{{ _inst_udp_range }}"
      NEKO_LOG_LEVEL: "info"
      # Each instance needs a unique X display number — with network_mode:host all
      # containers share the same abstract Unix socket namespace, so display :99
      # in container A conflicts with :99 in container B.
      # Formula: port 8080 -> :99, port 8081 -> :100, etc.
      DISPLAY: ":{{ (_inst_port | int) - 8080 + 99 }}"

    volumes:
      - "{{ _inst_data_dir }}/cache:/root/.cache"
      - "{{ _inst_data_dir }}/config:/root/.config"
      - "{{ _inst_data_dir }}/logs:/tmp/logs"

    healthcheck:
      test: ["CMD", "curl", "-fs", "--max-time", "5", "http://127.0.0.1:{{ _inst_port }}/"]
      interval: "{{ neko_healthcheck_interval }}"
      timeout: "{{ neko_healthcheck_timeout }}"
      retries: {{ neko_healthcheck_retries }}
      start_period: 30s

    cpus: "{{ _inst_cpu_limit }}"
    mem_limit: "{{ _inst_memory_limit }}"
    memswap_limit: "{{ _inst_memory_limit }}"

    logging:
      driver: "{{ neko_log_driver }}"
      options:
        max-size: "{{ neko_log_max_size }}"
        max-file: "{{ neko_log_max_file }}"
        labels: "service=neko,instance={{ _inst_name }}"

    labels:
      service: "neko"
      neko_instance: "{{ _inst_name }}"
      neko_email: "{{ _inst_email }}"
      role: "neko_runtime"
      adr: "0380"

    security_opt:
      - "no-new-privileges:true"
    stop_grace_period: 10s
    stop_signal: SIGTERM
