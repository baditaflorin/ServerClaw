{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("n8n") }}

  n8n:
    image: {{ n8n_image }}
    container_name: {{ n8n_container_name }}
    restart: unless-stopped
    network_mode: {{ n8n_network_mode }}
{% if n8n_network_mode != 'host' %}
    ports:
      - "{{ n8n_port }}:5678"
{% endif %}
    env_file:
      - {{ n8n_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
