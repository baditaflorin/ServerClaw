N8N_IMAGE={{ n8n_image }}
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST={{ n8n_database_host }}
DB_POSTGRESDB_PORT={{ n8n_database_port }}
DB_POSTGRESDB_DATABASE={{ n8n_database_name }}
DB_POSTGRESDB_USER={{ n8n_database_user }}
DB_POSTGRESDB_PASSWORD={{ lookup('ansible.builtin.file', n8n_database_password_local_file) | trim }}
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}
N8N_HOST={{ n8n_public_hostname }}
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_PROXY_HOPS={{ n8n_proxy_hops }}
N8N_EDITOR_BASE_URL={{ n8n_public_base_url }}
WEBHOOK_URL={{ n8n_public_base_url }}/
N8N_SECURE_COOKIE={{ 'true' if n8n_secure_cookie | bool else 'false' }}
N8N_PUBLIC_API_DISABLED={{ 'false' if n8n_enable_public_api | bool else 'true' }}
N8N_PUBLIC_API_SWAGGERUI_DISABLED={{ 'true' if n8n_disable_swagger_ui | bool else 'false' }}
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
GENERIC_TIMEZONE={{ n8n_timezone }}
