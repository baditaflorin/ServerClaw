{% macro cpu_query(bucket, object_name, host_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and r._field == "cpu") |> map(fn: (r) => ({ r with _value: float(v: r._value) * 100.0 }))
{%- endmacro %}
{% macro ratio_query(bucket, object_name, host_name, value_field, max_field) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and (r._field == "{{ value_field }}" or r._field == "{{ max_field }}")) |> pivot(rowKey: ["_time"], columnKey: ["_field"], valueColumn: "_value") |> map(fn: (r) => ({ _time: r._time, _value: if exists r.{{ max_field }} and float(v: r.{{ max_field }}) > 0.0 then (float(v: r.{{ value_field }}) / float(v: r.{{ max_field }})) * 100.0 else 0.0 }))
{%- endmacro %}
{% macro throughput_query(bucket, object_name, host_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and (r._field == "netin" or r._field == "netout")) |> derivative(unit: 1s, nonNegative: true)
{%- endmacro %}
{% macro load_query(bucket, host_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "cpustat" and r.object == "nodes" and r.host == "{{ host_name }}" and r._field == "avg1")
{%- endmacro %}
{% macro uptime_query(bucket, object_name, host_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and r._field == "uptime")
{%- endmacro %}
{% macro nginx_field_query(bucket, host_name, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "nginx" and r.host == "{{ host_name }}" and r._field == "{{ field_name }}")
{%- endmacro %}
{% macro nginx_rate_query(bucket, host_name, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "nginx" and r.host == "{{ host_name }}" and r._field == "{{ field_name }}") |> derivative(unit: 1s, nonNegative: true)
{%- endmacro %}
{% macro docker_build_field_query(bucket, host_name, field_name, status_name=None) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "docker_builds" and r.host == "{{ host_name }}" and r._field == "{{ field_name }}"{% if status_name is not none %} and r.status == "{{ status_name }}"{% endif %}) |> group(columns: ["_measurement", "_field", "host"])
{%- endmacro %}
{% macro docker_build_query(bucket, host_name, status_name=None) -%}
{{ docker_build_field_query(bucket, host_name, "count", status_name) }}
{%- endmacro %}
{% macro docker_build_total_query(bucket, host_name, status_name=None) -%}
{{ docker_build_query(bucket, host_name, status_name) }} |> sum()
{%- endmacro %}
{% macro docker_build_window_query(bucket, host_name, status_name=None) -%}
{{ docker_build_query(bucket, host_name, status_name) }} |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)
{%- endmacro %}
{% macro docker_build_duration_query(bucket, host_name, status_name=None) -%}
{{ docker_build_field_query(bucket, host_name, "duration_ms", status_name) }}
{%- endmacro %}
{% macro docker_build_duration_average_query(bucket, host_name, status_name=None) -%}
{{ docker_build_duration_query(bucket, host_name, status_name) }} |> mean()
{%- endmacro %}
{% macro docker_build_duration_last_query(bucket, host_name, status_name=None) -%}
{{ docker_build_duration_query(bucket, host_name, status_name) }} |> last()
{%- endmacro %}
{% macro docker_build_duration_window_query(bucket, host_name, status_name=None) -%}
{{ docker_build_duration_query(bucket, host_name, status_name) }} |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)
{%- endmacro %}
{% macro docker_container_field_query(bucket, host_name, measurement_name, field_name, extra_filter=None) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "{{ measurement_name }}" and r.host == "{{ host_name }}" and r._field == "{{ field_name }}"{% if extra_filter is not none %} and {{ extra_filter }}{% endif %})
{%- endmacro %}
{% macro docker_container_count_query(bucket, host_name) -%}
{{ docker_container_field_query(bucket, host_name, "docker_container_status", "uptime_ns") }} |> group(columns: ["container_name"]) |> last() |> keep(columns: ["container_name"]) |> distinct(column: "container_name") |> count(column: "container_name")
{%- endmacro %}
{% macro docker_container_health_count_query(bucket, host_name, health_status_name) -%}
{{ docker_container_field_query(bucket, host_name, "docker_container_health", "health_status") }} |> group(columns: ["container_name"]) |> last() |> filter(fn: (r) => r._value == "{{ health_status_name }}") |> group() |> count()
{%- endmacro %}
{% macro docker_container_cpu_query(bucket, host_name) -%}
{{ docker_container_field_query(bucket, host_name, "docker_container_cpu", "usage_percent", 'r.cpu == "cpu-total"') }}
{%- endmacro %}
{% macro docker_container_cpu_total_query(bucket, host_name) -%}
{{ docker_container_cpu_query(bucket, host_name) }} |> group(columns: ["container_name"]) |> last() |> group() |> sum()
{%- endmacro %}
{% macro docker_container_memory_usage_query(bucket, host_name) -%}
{{ docker_container_field_query(bucket, host_name, "docker_container_mem", "usage") }}
{%- endmacro %}
{% macro docker_container_memory_total_query(bucket, host_name) -%}
{{ docker_container_memory_usage_query(bucket, host_name) }} |> group(columns: ["container_name"]) |> last() |> group() |> sum()
{%- endmacro %}
{% macro docker_container_network_query(bucket, host_name) -%}
from(bucket: "{{ bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "docker_container_net" and r.host == "{{ host_name }}" and (r._field == "rx_bytes" or r._field == "tx_bytes")) |> derivative(unit: 1s, nonNegative: true)
{%- endmacro %}
{% macro docker_container_snapshot_query(bucket, host_name) -%}
status = from(bucket: "{{ bucket }}")
  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)
  |> filter(fn: (r) => r._measurement == "docker_container_status" and r.host == "{{ host_name }}" and (r._field == "uptime_ns" or r._field == "pid" or r._field == "exitcode"))
  |> group(columns: ["container_name", "_field"])
  |> last()
  |> keep(columns: ["container_name", "container_image", "container_status", "container_version", "_field", "_value"])

health = from(bucket: "{{ bucket }}")
  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)
  |> filter(fn: (r) => r._measurement == "docker_container_health" and r.host == "{{ host_name }}" and (r._field == "health_status" or r._field == "failing_streak"))
  |> group(columns: ["container_name", "_field"])
  |> last()
  |> keep(columns: ["container_name", "container_image", "container_status", "container_version", "_field", "_value"])

union(tables: [status, health])
  |> pivot(rowKey: ["container_name", "container_image", "container_status", "container_version"], columnKey: ["_field"], valueColumn: "_value")
  |> map(fn: (r) => ({
    Container: r.container_name,
    Image: r.container_image,
    Status: r.container_status,
    Version: r.container_version,
    Health: if exists r.health_status then r.health_status else "no-healthcheck",
    HealthFailures: if exists r.failing_streak then r.failing_streak else 0,
    PID: if exists r.pid then r.pid else 0,
    ExitCode: if exists r.exitcode then r.exitcode else 0,
    UptimeHours: if exists r.uptime_ns then float(v: r.uptime_ns) / 3600000000000.0 else 0.0
  }))
  |> keep(columns: ["Container", "Image", "Status", "Version", "Health", "HealthFailures", "PID", "ExitCode", "UptimeHours"])
  |> sort(columns: ["Container"])
{%- endmacro %}
{% macro drift_summary_query(bucket, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: -30d) |> filter(fn: (r) => r._measurement == "platform_drift_summary" and r.environment == "production" and r._field == "{{ field_name }}") |> last()
{%- endmacro %}
{% macro backup_restore_summary_query(bucket, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: -30d) |> filter(fn: (r) => r._measurement == "backup_restore_verification_summary" and r.environment == "production" and r._field == "{{ field_name }}") |> last()
{%- endmacro %}
{% macro security_posture_summary_query(bucket, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: -30d) |> filter(fn: (r) => r._measurement == "platform_security_posture_summary" and r.environment == "production" and r._field == "{{ field_name }}")
{%- endmacro %}
{% macro security_posture_host_query(bucket, field_name) -%}
from(bucket: "{{ bucket }}") |> range(start: -30d) |> filter(fn: (r) => r._measurement == "platform_security_posture_host" and r.environment == "production" and r._field == "{{ field_name }}")
{%- endmacro %}
{% macro timeseries_panel(datasource_name, panel_id, x, y, title, unit, query, min_value=None, max_value=None, width=6, height=8) -%}
{
  "id": {{ panel_id }},
  "type": "timeseries",
  "title": {{ title | to_json }},
  "datasource": {{ datasource_name | to_json }},
  "gridPos": {
    "h": {{ height }},
    "w": {{ width }},
    "x": {{ x }},
    "y": {{ y }}
  },
  "fieldConfig": {
    "defaults": {
      "unit": {{ unit | to_json }}{% if min_value is not none %},
      "min": {{ min_value }}{% endif %}{% if max_value is not none %},
      "max": {{ max_value }}{% endif %}
    },
    "overrides": []
  },
  "options": {
    "legend": {
      "displayMode": "list",
      "placement": "bottom",
      "showLegend": true
    },
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    }
  },
  "targets": [
    {
      "refId": "A",
      "query": {{ query | trim | to_json }}
    }
  ]
}
{%- endmacro %}
{% macro table_panel(datasource_name, panel_id, x, y, title, query, width=12, height=8) -%}
{
  "id": {{ panel_id }},
  "type": "table",
  "title": {{ title | to_json }},
  "datasource": {{ datasource_name | to_json }},
  "gridPos": {
    "h": {{ height }},
    "w": {{ width }},
    "x": {{ x }},
    "y": {{ y }}
  },
  "fieldConfig": {
    "defaults": {},
    "overrides": []
  },
  "options": {
    "cellHeight": "sm",
    "footer": {
      "countRows": false,
      "show": false,
      "reducer": [
        "sum"
      ]
    },
    "showHeader": true,
    "sortBy": [
      {
        "desc": false,
        "displayName": "Container"
      }
    ]
  },
  "targets": [
    {
      "refId": "A",
      "query": {{ query | trim | to_json }}
    }
  ]
}
{%- endmacro %}
{% macro stat_panel(datasource_name, panel_id, x, y, title, unit, query, width=6, height=4, thresholds=None) -%}
{
  "id": {{ panel_id }},
  "type": "stat",
  "title": {{ title | to_json }},
  "datasource": {{ datasource_name | to_json }},
  "gridPos": {
    "h": {{ height }},
    "w": {{ width }},
    "x": {{ x }},
    "y": {{ y }}
  },
  "fieldConfig": {
    "defaults": {
      "unit": {{ unit | to_json }}{% if thresholds is not none %},
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": {{ thresholds | to_json }}
      }{% endif %}
    },
    "overrides": []
  },
  "options": {
    "colorMode": "value",
    "graphMode": "area",
    "justifyMode": "center",
    "orientation": "auto",
    "reduceOptions": {
      "calcs": [
        "lastNotNull"
      ],
      "fields": "",
      "values": false
    },
    "showPercentChange": false,
    "textMode": "auto",
    "wideLayout": true
  },
  "targets": [
    {
      "refId": "A",
      "query": {{ query | trim | to_json }}
    }
  ]
}
{%- endmacro %}
