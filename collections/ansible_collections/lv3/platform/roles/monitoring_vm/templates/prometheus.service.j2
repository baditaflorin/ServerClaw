[Unit]
Description=LV3 Prometheus service
After=network.target

[Service]
Type=simple
User=prometheus
Group=prometheus
ExecStart=/usr/bin/prometheus \
  --config.file={{ monitoring_prometheus_config_file }} \
  --storage.tsdb.path={{ monitoring_prometheus_data_dir }} \
  --storage.tsdb.retention.time={{ monitoring_prometheus_retention_time }} \
  --web.listen-address=127.0.0.1:9090 \
  --web.console.templates=/usr/share/prometheus/consoles \
  --web.console.libraries=/usr/share/prometheus/console_libraries \
  --web.enable-remote-write-receiver \
  --enable-feature={{ monitoring_prometheus_enable_features | join(',') }}
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
