global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: {{ monitoring_otel_resource_cluster }}
    environment: {{ monitoring_otel_resource_environment }}

rule_files:
  - {{ monitoring_prometheus_rules_dir }}/*.yml
alerting:
  alertmanagers:
    - static_configs:
        - targets:
{% for target in monitoring_prometheus_alertmanager_targets %}
            - {{ target }}
{% endfor %}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - 127.0.0.1:9090
        labels:
          service: prometheus

  - job_name: tempo
    metrics_path: /metrics
    static_configs:
      - targets:
          - 127.0.0.1:{{ monitoring_tempo_http_port }}
        labels:
          service: tempo

  - job_name: otelcol-contrib
    metrics_path: /metrics
    static_configs:
      - targets:
          - 127.0.0.1:{{ monitoring_otelcol_metrics_port }}
        labels:
          service: otel-collector

  - job_name: loki-canary
    metrics_path: /metrics
    static_configs:
      - targets:
          - 127.0.0.1:{{ monitoring_loki_canary_metrics_port }}
        labels:
          service: loki-canary
          assurance_dimension: log-queryability

  - job_name: {{ monitoring_postgres_audit_metrics_job_name }}
    metrics_path: /metrics
    static_configs:
      - targets:
          - {{ monitoring_postgres_audit_metrics_target }}
        labels:
          service: postgres
          component: pgaudit
    metric_relabel_configs:
      - source_labels: [__name__]
        regex: loki_process_custom_(postgres_(audit_events_total|connection_authorized_total|unknown_connection_events_total))
        target_label: __name__
        replacement: $1

  - job_name: netdata
    metrics_path: /api/v1/allmetrics
    params:
      format:
        - prometheus_all_hosts
      source:
        - as-collected
    static_configs:
      - targets:
          - 127.0.0.1:{{ monitoring_netdata_parent_port }}
        labels:
          service: realtime

  - job_name: slo-blackbox
    metrics_path: /probe
    file_sd_configs:
      - files:
          - {{ monitoring_prometheus_slo_targets_file }}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [probe_module]
        target_label: __param_module
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 127.0.0.1:{{ monitoring_blackbox_exporter_port }}

  - job_name: https-tls-blackbox
    metrics_path: /probe
    file_sd_configs:
      - files:
          - {{ monitoring_prometheus_https_tls_targets_file }}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [probe_module]
        target_label: __param_module
      - source_labels: [probe_hostname]
        target_label: __param_hostname
      - source_labels: [display_url]
        target_label: instance
      - target_label: __address__
        replacement: 127.0.0.1:{{ monitoring_blackbox_exporter_port }}
{% for service_id, service in monitoring_health_probe_catalog.services | dictsort %}
{% for probe_kind in ['liveness', 'readiness'] %}
{% set probe = service[probe_kind] %}
{% if probe.kind in ['http', 'tcp'] %}

  - job_name: {{ service_id }}-{{ probe_kind }}
    metrics_path: /probe
    params:
      module:
{% if probe.kind == 'tcp' %}
        - tcp_connect
{% elif probe.validate_tls is defined and not probe.validate_tls %}
        - http_2xx_insecure
{% else %}
        - http_2xx
{% endif %}
    static_configs:
      - targets:
{% if probe.kind == 'http' %}
          - {{ probe.url }}
{% else %}
          - {{ probe.host }}:{{ probe.port }}
{% endif %}
        labels:
          service: {{ service_id }}
          probe_kind: {{ probe_kind }}
          probe_id: {{ service_id }}-{{ probe_kind }}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - target_label: __address__
        replacement: 127.0.0.1:{{ monitoring_blackbox_exporter_port }}
      - source_labels: [__param_target]
        target_label: instance
{% endif %}
{% endfor %}
{% endfor %}
