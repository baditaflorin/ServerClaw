GITEA__database__DB_TYPE=postgres
GITEA__database__HOST={{ gitea_database_host }}:{{ gitea_database_port }}
GITEA__database__NAME={{ gitea_database_name }}
GITEA__database__USER={{ gitea_database_user }}
GITEA__database__PASSWD=[[ with secret "kv/data/{{ gitea_openbao_secret_path }}" ]][[ .Data.data.GITEA__database__PASSWD ]][[ end ]]
GITEA__server__DOMAIN={{ gitea_public_hostname }}
GITEA__server__ROOT_URL={{ gitea_root_url }}/
GITEA__server__PROTOCOL=http
GITEA__server__HTTP_ADDR=0.0.0.0
GITEA__server__HTTP_PORT=3000
GITEA__service__DISABLE_REGISTRATION=true
GITEA__service__ENABLE_BASIC_AUTHENTICATION=true
GITEA__service__ENABLE_PASSWORD_SIGNIN_FORM=true
GITEA__oauth2_client__ENABLE_AUTO_REGISTRATION=true
GITEA__oauth2_client__ACCOUNT_LINKING=auto
GITEA__oauth2_client__USERNAME=preferred_username
GITEA__oauth2_client__OPENID_CONNECT_SCOPES=openid profile email
GITEA__actions__ENABLED=true
GITEA__security__INSTALL_LOCK=true
GITEA__server__LFS_START_SERVER=true
GITEA__lfs__STORAGE_TYPE=minio
GITEA__lfs__MINIO_ENDPOINT={{ gitea_minio_endpoint }}
GITEA__lfs__MINIO_ACCESS_KEY_ID={{ gitea_minio_access_key_id }}
GITEA__lfs__MINIO_SECRET_ACCESS_KEY=[[ with secret "kv/data/{{ gitea_openbao_secret_path }}" ]][[ .Data.data.GITEA__lfs__MINIO_SECRET_ACCESS_KEY ]][[ end ]]
GITEA__lfs__MINIO_BUCKET={{ gitea_minio_bucket_name }}
GITEA__lfs__MINIO_LOCATION={{ gitea_minio_region }}
GITEA__lfs__MINIO_USE_SSL=false
GITEA__lfs__MINIO_BUCKET_LOOKUP_TYPE=path
GITEA_ADMIN_PASSWORD=[[ with secret "kv/data/{{ gitea_openbao_secret_path }}" ]][[ .Data.data.GITEA_ADMIN_PASSWORD ]][[ end ]]
GITEA_KEYCLOAK_CLIENT_SECRET=[[ with secret "kv/data/{{ gitea_openbao_secret_path }}" ]][[ .Data.data.GITEA_KEYCLOAK_CLIENT_SECRET ]][[ end ]]
GITEA_WEBHOOK_SECRET=[[ with secret "kv/data/{{ gitea_openbao_secret_path }}" ]][[ .Data.data.GITEA_WEBHOOK_SECRET ]][[ end ]]
