services:
  openbao-agent:
    image: {{ superset_openbao_agent_image }}
    container_name: {{ superset_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ superset_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ superset_openbao_agent_dir }}:/openbao-agent:ro
      - {{ superset_env_file | dirname }}:{{ superset_env_file | dirname }}

  superset:
    image: {{ superset_image_name }}:latest
    container_name: {{ superset_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    extra_hosts:
{% for item in superset_public_hostname_overrides %}
      - "{{ item.hostname }}:{{ item.address }}"
{% endfor %}
    env_file:
      - {{ superset_static_env_file }}
      - {{ superset_env_file }}
    ports:
      - "{{ ansible_host }}:{{ superset_internal_port }}:{{ superset_container_port }}"
      - "127.0.0.1:{{ superset_internal_port }}:{{ superset_container_port }}"
    volumes:
      - {{ superset_data_dir }}:/app/superset_home
      - {{ superset_pythonpath_dir }}:/app/pythonpath:ro
      - {{ superset_asset_dir }}:/app/assets:ro
    healthcheck:
      test:
        - CMD
        - /app/.venv/bin/python
        - -c
        - import urllib.request; assert urllib.request.urlopen('http://127.0.0.1:{{ superset_container_port }}/health', timeout=5).read().decode('utf-8').strip() == 'OK'
      interval: 10s
      timeout: 5s
      retries: 24

networks:
  default:
    name: {{ superset_compose_network_name }}
