services:
  openbao-agent:
    image: {{ livekit_openbao_agent_image }}
    container_name: {{ livekit_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ livekit_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ livekit_openbao_agent_dir }}:/openbao-agent:ro
      - {{ livekit_env_file | dirname }}:{{ livekit_env_file | dirname }}

  livekit:
    image: {{ livekit_image }}
    container_name: {{ livekit_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    network_mode: host
    env_file:
      - {{ livekit_env_file }}
    command:
      - --bind
      - {{ livekit_bind_address }}
      - --config
      - /etc/livekit/livekit.yaml
    volumes:
      - {{ livekit_config_file }}:/etc/livekit/livekit.yaml:ro
