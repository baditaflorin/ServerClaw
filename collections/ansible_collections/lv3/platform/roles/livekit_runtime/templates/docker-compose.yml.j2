{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("livekit") }}

  livekit:
    image: {{ livekit_image }}
    container_name: {{ livekit_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    network_mode: host
    env_file:
      - {{ livekit_env_file }}
    command:
      - --bind
      - {{ livekit_bind_address }}
      - --config
      - /etc/livekit/livekit.yaml
    volumes:
      - {{ livekit_config_file }}:/etc/livekit/livekit.yaml:ro
