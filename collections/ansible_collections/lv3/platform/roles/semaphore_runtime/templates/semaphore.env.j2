SEMAPHORE_DB_DIALECT=postgres
SEMAPHORE_DB_HOST={{ semaphore_database_host }}
SEMAPHORE_DB_PORT={{ semaphore_database_port }}
SEMAPHORE_DB_USER={{ semaphore_database_user }}
SEMAPHORE_DB_PASS={{ semaphore_database_password }}
SEMAPHORE_DB={{ semaphore_database_name }}
SEMAPHORE_PORT={{ semaphore_server_port }}
SEMAPHORE_ADMIN={{ semaphore_admin_username }}
SEMAPHORE_ADMIN_PASSWORD={{ semaphore_admin_password }}
SEMAPHORE_ADMIN_NAME={{ semaphore_admin_name }}
SEMAPHORE_ADMIN_EMAIL={{ semaphore_admin_email }}
SEMAPHORE_ACCESS_KEY_ENCRYPTION={{ semaphore_access_key_encryption }}
SEMAPHORE_COOKIE_HASH={{ semaphore_cookie_hash }}
SEMAPHORE_COOKIE_ENCRYPTION={{ semaphore_cookie_encryption }}
SEMAPHORE_DISABLE_UPDATE_CHECK=true
ANSIBLE_HOST_KEY_CHECKING=False
PYTHONUNBUFFERED=1

# Keycloak OIDC Configuration
{% if semaphore_enable_oidc | default(false) %}
SEMAPHORE_OIDC_PROVIDER={{ semaphore_oidc_provider }}
SEMAPHORE_OIDC_ISSUER_URL={{ semaphore_oidc_issuer_url }}
SEMAPHORE_OIDC_CLIENT_ID={{ semaphore_oidc_client_id }}
SEMAPHORE_OIDC_CLIENT_SECRET={{ semaphore_oidc_client_secret }}
SEMAPHORE_OIDC_CALLBACK_URL={{ semaphore_oidc_callback_url }}
SEMAPHORE_OIDC_SCOPES={{ semaphore_oidc_scopes }}
SEMAPHORE_OIDC_AUTO_PROVISION_USER={{ 'true' if semaphore_oidc_auto_provision_user else 'false' }}
{% endif %}
