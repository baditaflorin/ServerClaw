services:
  openbao-agent:
    image: {{ directus_openbao_agent_image }}
    container_name: {{ directus_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ directus_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ directus_openbao_agent_dir }}:/openbao-agent:ro
      - {{ directus_env_file | dirname }}:{{ directus_env_file | dirname }}

  directus:
    image: {{ directus_image }}
    container_name: {{ directus_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    extra_hosts:
{% for item in directus_public_hostname_overrides %}
      - "{{ item.hostname }}:{{ item.address }}"
{% endfor %}
    env_file:
      - {{ directus_env_file }}
    ports:
      - "{{ ansible_host }}:{{ directus_internal_port }}:{{ directus_container_port }}"
      - "127.0.0.1:{{ directus_internal_port }}:{{ directus_container_port }}"
