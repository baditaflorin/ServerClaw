services:
  openbao-agent:
    image: {{ open_webui_openbao_agent_image }}
    container_name: {{ open_webui_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ open_webui_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ open_webui_openbao_agent_dir }}:/openbao-agent:ro
      - {{ open_webui_env_file | dirname }}:{{ open_webui_env_file | dirname }}

  open-webui:
    image: {{ open_webui_image }}
    container_name: {{ open_webui_container_name }}
    restart: unless-stopped
    ports:
      - "{{ open_webui_port }}:8080"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    env_file:
      - {{ open_webui_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    volumes:
      - {{ open_webui_data_dir }}:/app/backend/data
