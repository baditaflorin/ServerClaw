FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /srv/repo

RUN apt-get update \
    && apt-get install -y --no-install-recommends git openssh-client \
    && rm -rf /var/lib/apt/lists/*

COPY . /srv/repo

RUN pip install --no-cache-dir \
    "cryptography>=42.0" \
    "fastapi>=0.115.0" \
    "itsdangerous>=2.2.0" \
    "Jinja2>=3.1.0" \
    "python-multipart>=0.0.9" \
    "PyYAML>=6.0" \
    "uvicorn>=0.30.0"

RUN useradd --create-home --home-dir /srv/repo --shell /usr/sbin/nologin repo \
    && chown -R repo:repo /srv/repo

EXPOSE {{ repo_intake_internal_port }}

USER repo

CMD ["uvicorn", "scripts.repo_intake.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "{{ repo_intake_internal_port }}"]
