services:
  repo-intake:
    build:
      context: {{ repo_intake_build_context_dir }}
      network: host
    image: {{ repo_intake_image }}
    container_name: {{ repo_intake_container_name }}
    restart: unless-stopped
    ports:
      - "{{ repo_intake_internal_port }}:{{ repo_intake_internal_port }}"
    env_file:
      - {{ repo_intake_env_file }}
    volumes:
      - {{ repo_intake_secret_dir }}/coolify/admin-auth.json:/srv/repo/.local/coolify/admin-auth.json:ro
      - {{ repo_intake_secret_dir }}/ssh/bootstrap.id_ed25519:/srv/repo/.local/ssh/bootstrap.id_ed25519:ro
    healthcheck:
      test:
        - CMD
        - python
        - -c
        - import urllib.request; urllib.request.urlopen('http://127.0.0.1:{{ repo_intake_internal_port }}/health', timeout=5)
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
