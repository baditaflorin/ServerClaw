BASE_URL={{ windmill_base_url }}
LV3_WINDMILL_BASE_URL={{ windmill_worker_api_base_url }}
DATABASE_URL={{ windmill_database_dsn }}
SUPERADMIN_SECRET={{ windmill_superadmin_secret }}
WORLD_STATE_DSN={{ windmill_world_state_dsn }}
LV3_NATS_URL={{ windmill_nats_url }}
TF_VAR_proxmox_endpoint={{ windmill_proxmox_api_token_payload.api_url }}
TF_VAR_proxmox_api_token={{ windmill_proxmox_api_token_payload.full_token_id }}={{ windmill_proxmox_api_token_payload.value }}
{% if windmill_nats_username | default('') | length > 0 %}
LV3_NATS_USERNAME={{ windmill_nats_username }}
{% endif %}
{% if windmill_nats_password | default('') | length > 0 %}
LV3_NATS_PASSWORD={{ windmill_nats_password }}
{% endif %}
{% if windmill_ledger_dsn | default('') | trim | length > 0 %}
LV3_LEDGER_DSN={{ windmill_ledger_dsn }}
{% endif %}
{% if windmill_ledger_nats_url | default('') | trim | length > 0 %}
LV3_LEDGER_NATS_URL={{ windmill_ledger_nats_url }}
{% endif %}
