APP_ID={{ ((coolify_root_password ~ ':appid') | hash('sha256') | truncate(24, True, '')) | to_json }}
APP_NAME=Coolify
APP_KEY={{ coolify_app_key | to_json }}
APP_PORT={{ coolify_dashboard_port }}
APP_ENV=production

DB_USERNAME=coolify
DB_PASSWORD={{ coolify_db_password | to_json }}
DB_DATABASE=coolify

REDIS_PASSWORD={{ coolify_redis_password | to_json }}

PUSHER_APP_ID={{ coolify_pusher_app_id | to_json }}
PUSHER_APP_KEY={{ coolify_pusher_app_key | to_json }}
PUSHER_APP_SECRET={{ coolify_pusher_app_secret | to_json }}

ROOT_USERNAME={{ coolify_root_username | to_json }}
ROOT_USER_EMAIL={{ coolify_root_email | to_json }}
ROOT_USER_PASSWORD={{ coolify_root_password | to_json }}

REGISTRY_URL=ghcr.io
