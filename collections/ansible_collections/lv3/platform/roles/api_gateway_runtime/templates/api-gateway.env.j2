KEYCLOAK_JWKS_URL={{ api_gateway_keycloak_jwks_url }}
KEYCLOAK_ISSUER_URL={{ api_gateway_keycloak_issuer_url }}
LV3_GATEWAY_CATALOG_PATH=/config/api-gateway-catalog.json
LV3_GATEWAY_SERVICE_CATALOG_PATH=/config/service-capability-catalog.json
LV3_GATEWAY_WORKFLOW_CATALOG_PATH=/config/workflow-catalog.json
LV3_GATEWAY_PLATFORM_VARS_PATH=/config/platform.yml
LV3_GATEWAY_DRIFT_RECEIPTS_DIR=/data/receipts/drift-reports
LV3_GATEWAY_INCLUDE_UPSTREAM_OPENAPI={{ 'true' if api_gateway_include_upstream_openapi | bool else 'false' }}
{% if api_gateway_nats_url | length > 0 %}
NATS_URL={{ api_gateway_nats_url }}
{% endif %}
{% if api_gateway_deploy_webhook_url | length > 0 %}
LV3_GATEWAY_DEPLOY_WEBHOOK_URL={{ api_gateway_deploy_webhook_url }}
{% endif %}
{% if api_gateway_secret_rotation_webhook_url | length > 0 %}
LV3_GATEWAY_SECRET_ROTATION_WEBHOOK_URL={{ api_gateway_secret_rotation_webhook_url }}
{% endif %}
{% if api_gateway_platform_context_legacy_token is defined and api_gateway_platform_context_legacy_token | length > 0 %}
LV3_GATEWAY_PLATFORM_CONTEXT_LEGACY_TOKEN={{ api_gateway_platform_context_legacy_token }}
{% endif %}
