services:
  openbao-agent:
    image: {{ matrix_synapse_openbao_agent_image }}
    container_name: {{ matrix_synapse_openbao_agent_container_name }}
    user: "0:0"
    environment:
      BAO_SKIP_DROP_ROOT: "true"
    command:
      - agent
      - -config=/openbao-agent/agent.hcl
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test:
        - CMD-SHELL
        - test -s {{ matrix_synapse_env_file }}
      interval: 10s
      timeout: 3s
      retries: 12
    volumes:
      - {{ matrix_synapse_openbao_agent_dir }}:/openbao-agent:ro
      - {{ matrix_synapse_env_file | dirname }}:{{ matrix_synapse_env_file | dirname }}

  matrix-synapse:
    image: {{ matrix_synapse_image }}
    container_name: {{ matrix_synapse_container_name }}
    restart: unless-stopped
    ports:
      - "{{ matrix_synapse_port }}:8008"
    env_file:
      - {{ matrix_synapse_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
    volumes:
      - {{ matrix_synapse_data_dir }}:/data
      - {{ matrix_synapse_mautrix_discord_registration_file }}:/appservices/mautrix-discord-registration.yaml:ro
      - {{ matrix_synapse_mautrix_whatsapp_registration_file }}:/appservices/mautrix-whatsapp-registration.yaml:ro

  mautrix-discord:
    image: {{ matrix_synapse_mautrix_discord_image }}
    container_name: {{ matrix_synapse_mautrix_discord_container_name }}
    restart: unless-stopped
    depends_on:
      - matrix-synapse
    volumes:
      - {{ matrix_synapse_mautrix_discord_dir }}:/data

  mautrix-whatsapp:
    image: {{ matrix_synapse_mautrix_whatsapp_image }}
    container_name: {{ matrix_synapse_mautrix_whatsapp_container_name }}
    restart: unless-stopped
    depends_on:
      - matrix-synapse
    volumes:
      - {{ matrix_synapse_mautrix_whatsapp_dir }}:/data
