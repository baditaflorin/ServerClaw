{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("one_api") }}

  one-api:
    image: {{ one_api_image }}
    container_name: {{ one_api_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
    env_file:
      - {{ one_api_env_file }}
    ports:
      - "{{ one_api_internal_http_port }}:{{ one_api_internal_http_port }}"
