{% from 'compose_macros.j2' import hairpin_hosts, openbao_sidecar, redis_service %}
services:
{{ openbao_sidecar("paperless") }}

{{ redis_service(
  "paperless",
  service_name="broker",
  data_dir_key=None,
  append_only=false,
  healthcheck_retries=12,
  healthcheck_grep="PONG"
) }}

  paperless:
    image: {{ paperless_image }}
    container_name: {{ paperless_container_name }}
    restart: unless-stopped
    depends_on:
      broker:
        condition: service_healthy
      openbao-agent:
        condition: service_healthy
{{ hairpin_hosts() }}
    env_file:
      - {{ paperless_env_file }}
    ports:
      - "{{ ansible_host }}:{{ paperless_internal_port }}:8000"
      - "127.0.0.1:{{ paperless_internal_port }}:8000"
    volumes:
      - {{ paperless_volume_names.data }}:/usr/src/paperless/data
      - {{ paperless_volume_names.media }}:/usr/src/paperless/media
      - {{ paperless_volume_names.export }}:/usr/src/paperless/export
      - {{ paperless_volume_names.consume }}:/usr/src/paperless/consume
    healthcheck:
      test:
        - CMD-SHELL
        - python3 -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/', timeout=10).read()"
      interval: 10s
      timeout: 5s
      retries: 24

volumes:
  {{ paperless_volume_names.data }}:
    name: {{ paperless_volume_names.data }}
  {{ paperless_volume_names.media }}:
    name: {{ paperless_volume_names.media }}
  {{ paperless_volume_names.export }}:
    name: {{ paperless_volume_names.export }}
  {{ paperless_volume_names.consume }}:
    name: {{ paperless_volume_names.consume }}
