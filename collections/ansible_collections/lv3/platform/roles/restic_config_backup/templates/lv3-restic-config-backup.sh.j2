#!/bin/bash
set -euo pipefail

cd {{ restic_config_backup_repo_checkout_host_path }}

primary_script="{{ restic_config_backup_repo_checkout_host_path }}/scripts/restic_config_backup.py"
fallback_script="{{ restic_config_backup_fallback_script_path }}"
script_path="$primary_script"
primary_catalog="{{ restic_config_backup_catalog_repo_path }}"
fallback_catalog="{{ restic_config_backup_runtime_catalog_path }}"
catalog_path="$primary_catalog"

if [ ! -f "$script_path" ] && [ -f "$fallback_script" ]; then
  script_path="$fallback_script"
fi

if [ ! -f "$script_path" ]; then
  echo "restic_config_backup.py is missing from both $primary_script and $fallback_script" >&2
  exit 2
fi

if [ ! -f "$catalog_path" ] && [ -f "$fallback_catalog" ]; then
  catalog_path="$fallback_catalog"
fi

if [ ! -f "$catalog_path" ]; then
  echo "restic-file-backup-catalog.json is missing from both $primary_catalog and $fallback_catalog" >&2
  exit 2
fi

exec python3 "$script_path" \
  --repo-root {{ restic_config_backup_repo_checkout_host_path }} \
  --catalog "$catalog_path" \
  --backup-receipts-dir {{ restic_config_backup_backup_receipts_dir }} \
  --latest-snapshot-receipt {{ restic_config_backup_latest_snapshot_receipt }} \
  --restore-verification-dir {{ restic_config_backup_restore_verification_dir }} \
  --runtime-state-dir {{ restic_config_backup_runtime_state_dir }} \
  --cache-dir {{ restic_config_backup_runtime_cache_dir }} \
  --credential-file {{ restic_config_backup_runtime_credential_file }} \
  --mode backup \
  --triggered-by systemd-timer
