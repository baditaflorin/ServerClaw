{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("flagsmith", cap_add=["IPC_LOCK"], security_opt=["no-new-privileges:true"]) }}

  flagsmith:
    image: {{ flagsmith_runtime_image }}
    container_name: {{ flagsmith_container_name }}
    restart: unless-stopped
    env_file:
      - {{ flagsmith_env_file }}
    environment:
      ACCESS_LOG_LOCATION: {{ flagsmith_access_log_file | to_json }}
      ACCESS_LOG_FORMAT: {{ flagsmith_access_log_format | to_json }}
      GUNICORN_TIMEOUT: "{{ flagsmith_api_timeout_seconds }}"
      GUNICORN_WORKERS: "{{ flagsmith_api_workers }}"
      GUNICORN_THREADS: "{{ flagsmith_api_threads }}"
      GUNICORN_KEEP_ALIVE: "{{ flagsmith_api_keepalive_seconds }}"
    ports:
      - "{{ ansible_host }}:{{ flagsmith_internal_port }}:8000"
      - "127.0.0.1:{{ flagsmith_internal_port }}:8000"
    depends_on:
      openbao-agent:
        condition: service_healthy

  flagsmith-task-processor:
    image: {{ flagsmith_runtime_image }}
    container_name: {{ flagsmith_task_processor_container_name }}
    restart: unless-stopped
    env_file:
      - {{ flagsmith_env_file }}
    environment:
      ACCESS_LOG_LOCATION: {{ flagsmith_access_log_file | to_json }}
      ACCESS_LOG_FORMAT: {{ flagsmith_access_log_format | to_json }}
      TASK_PROCESSOR_SLEEP_INTERVAL_MS: "{{ flagsmith_task_processor_sleep_interval_ms }}"
      TASK_PROCESSOR_GRACE_PERIOD_MS: "{{ flagsmith_task_processor_grace_period_ms }}"
      TASK_PROCESSOR_NUM_THREADS: "{{ flagsmith_task_processor_threads }}"
      TASK_PROCESSOR_QUEUE_POP_SIZE: "{{ flagsmith_task_processor_queue_pop_size }}"
    command:
      - run-task-processor
    depends_on:
      openbao-agent:
        condition: service_healthy
      flagsmith:
        condition: service_started
