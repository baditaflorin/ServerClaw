{% from 'compose_macros.j2' import hairpin_hosts, openbao_sidecar %}
services:
{{ openbao_sidecar("grist") }}

  grist:
    image: {{ grist_image }}
    container_name: {{ grist_container_name }}
    restart: unless-stopped
    depends_on:
      openbao-agent:
        condition: service_healthy
{{ hairpin_hosts() }}
    env_file:
      - {{ grist_static_env_file }}
      - {{ grist_env_file }}
    ports:
      - "{{ ansible_host }}:{{ grist_internal_port }}:8484"
      - "127.0.0.1:{{ grist_internal_port }}:8484"
    volumes:
      - {{ grist_persist_dir }}:/persist
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          node -e "const http=require('node:http'); const req=http.get('http://127.0.0.1:8484/status',
          (res)=>process.exit(res.statusCode===200?0:1)); req.on('error',()=>process.exit(1));
          req.setTimeout(4000,()=>{req.destroy(); process.exit(1);});"
      interval: 10s
      timeout: 5s
      retries: 24
