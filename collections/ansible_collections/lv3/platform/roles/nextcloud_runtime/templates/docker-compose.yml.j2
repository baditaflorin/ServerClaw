{% from 'compose_macros.j2' import openbao_sidecar %}
services:
{{ openbao_sidecar("nextcloud") }}

  nextcloud-redis:
    image: {{ nextcloud_redis_image }}
    container_name: {{ nextcloud_redis_container_name }}
    restart: unless-stopped
    env_file:
      - {{ nextcloud_env_file }}
    command:
      - /bin/sh
      - -c
      - exec redis-server --appendonly yes --requirepass "$$REDIS_HOST_PASSWORD"
    healthcheck:
      test:
        - CMD-SHELL
        - redis-cli -a "$$REDIS_HOST_PASSWORD" ping | grep -q PONG
      interval: 10s
      timeout: 5s
      retries: 12
    volumes:
      - {{ nextcloud_redis_data_dir }}:/data

  nextcloud-app:
    image: {{ nextcloud_image }}
    container_name: {{ nextcloud_container_name }}
    restart: unless-stopped
    ports:
      - "{{ nextcloud_port }}:80"
    env_file:
      - {{ nextcloud_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
      nextcloud-redis:
        condition: service_healthy
    volumes:
      - {{ nextcloud_data_dir }}:/var/www/html

  nextcloud-cron:
    image: {{ nextcloud_image }}
    container_name: {{ nextcloud_cron_container_name }}
    restart: unless-stopped
    entrypoint:
      - /cron.sh
    env_file:
      - {{ nextcloud_env_file }}
    depends_on:
      openbao-agent:
        condition: service_healthy
      nextcloud-app:
        condition: service_started
      nextcloud-redis:
        condition: service_healthy
    volumes:
      - {{ nextcloud_data_dir }}:/var/www/html
