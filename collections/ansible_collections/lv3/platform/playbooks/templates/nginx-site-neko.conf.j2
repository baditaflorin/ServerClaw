# browser.lv3.org — Neko multi-instance remote desktop
# Generated by neko_runtime role — do not edit manually
# Instances: {{ neko_instances | length }}
# Auth: Keycloak via shared oauth2-proxy (ops-portal-oauth client)
# Routing: X-Auth-Request-Email header → per-user container

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Route authenticated user email to their dedicated Neko container.
# Empty string = authenticated Keycloak user but no browser session assigned.
# An empty $neko_backend causes proxy_pass to fail with nginx 500 (content phase,
# after auth), which is caught by error_page 500 = @neko_no_session below.
map $auth_email $neko_backend {
{% for name, inst in neko_instances.items() %}
    "{{ inst.email }}"  "http://{{ hostvars['runtime-comms-lv3'].ansible_host }}:{{ inst.port }}";
{% endfor %}
    default  "";
}

server {
    listen 80;
    server_name browser.lv3.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name browser.lv3.org;

    ssl_certificate     /etc/letsencrypt/live/browser.lv3.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/browser.lv3.org/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer-when-downgrade always;

    # Shared oauth2-proxy passthrough (cookie_domains covers .lv3.org)
    location /oauth2/ {
        proxy_pass http://127.0.0.1:4180;
        proxy_http_version 1.1;
        proxy_set_header Host                    $host;
        proxy_set_header X-Real-IP               $remote_addr;
        proxy_set_header X-Forwarded-For         $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto       $scheme;
        proxy_set_header X-Forwarded-Host        $host;
        proxy_set_header X-Auth-Request-Redirect $scheme://$host$request_uri;
    }

    location = /oauth2/auth {
        internal;
        proxy_pass http://127.0.0.1:4180;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Content-Length    "";
        proxy_pass_request_body off;
    }

    location / {
        # Step 1: Require Keycloak login
        auth_request /oauth2/auth;
        error_page 401 = @oauth2_sign_in;

        # Step 2: Extract authenticated user email from oauth2-proxy
        auth_request_set $auth_email $upstream_http_x_auth_request_email;

        # Step 3: Route to user's container.
        # $neko_backend is evaluated in the content phase (after auth_request_set
        # has populated $auth_email), so the map resolves correctly.
        # When $neko_backend is "" (email not in neko_instances), proxy_pass fails
        # with nginx error 500 — caught below and shown as a 403 HTML page.
        # NOTE: do NOT use an `if` block here — `if` is rewrite-phase and runs
        # before auth_request, so $auth_email would always be "" at that point.
        error_page 500 @neko_no_session;
        error_page 502 503 504 @neko_unavailable;

        proxy_pass              $neko_backend;
        proxy_http_version      1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  $scheme;
        proxy_set_header X-Forwarded-Host   $host;
        proxy_read_timeout    3600s;
        proxy_send_timeout    3600s;
        proxy_connect_timeout   60s;
        proxy_buffering off;
    }

    location @oauth2_sign_in {
        return 302 /oauth2/sign_in?rd=$scheme://$host$request_uri;
    }

    # Shown when authenticated but no Neko instance is assigned to this email.
    # Triggered via error_page 500 from proxy_pass with empty $neko_backend.
    location @neko_no_session {
        default_type text/html;
        return 403 '<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><title>No browser session — browser.lv3.org</title><style>body{font-family:system-ui,sans-serif;max-width:520px;margin:100px auto;padding:0 24px;color:#1a1a2e}h2{color:#e63946}code{background:#f1f1f1;padding:2px 6px;border-radius:3px;font-size:.9em}</style></head><body><h2>No browser session assigned</h2><p>You are signed in, but your account does not have a dedicated browser session on this platform.</p><p>Ask an administrator to add your email to <code>neko_instances</code> in <code>inventory/group_vars/platform.yml</code> and re-run the Neko playbook.</p><p><a href="/oauth2/sign_out">Sign out</a></p></body></html>';
    }

    location @neko_unavailable {
        default_type text/html;
        return 503 '<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><title>Session unavailable — browser.lv3.org</title><style>body{font-family:system-ui,sans-serif;max-width:520px;margin:100px auto;padding:0 24px;color:#1a1a2e}h2{color:#e87040}</style></head><body><h2>Browser session temporarily unavailable</h2><p>Your session container is starting up or restarting. Please try again in a moment.</p><p><a href="/">Retry</a></p></body></html>';
    }
}
