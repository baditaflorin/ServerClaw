{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/service-capability-catalog.schema.json",
  "title": "Service Capability Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "services"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "category",
          "lifecycle_status",
          "vm",
          "exposure"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "observability",
              "security",
              "automation",
              "data",
              "communication",
              "access",
              "infrastructure"
            ]
          },
          "lifecycle_status": {
            "type": "string",
            "enum": ["active", "planned", "retiring"]
          },
          "vm": {
            "type": "string",
            "minLength": 1
          },
          "vmid": {
            "type": "integer",
            "minimum": 1
          },
          "internal_url": {
            "type": "string",
            "minLength": 1
          },
          "public_url": {
            "type": "string",
            "minLength": 1
          },
          "subdomain": {
            "type": "string",
            "minLength": 1
          },
          "exposure": {
            "type": "string",
            "enum": [
              "edge-static",
              "edge-published",
              "informational-only",
              "private-only"
            ]
          },
          "uptime_monitor_name": {
            "type": "string",
            "minLength": 1
          },
          "adr": {
            "type": "string",
            "pattern": "^\\d{4}$"
          },
          "runbook": {
            "type": "string",
            "minLength": 1
          },
          "dashboard_url": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
