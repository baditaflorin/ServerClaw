{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/repo-deploy-base-image-profiles.schema.json",
  "title": "Repo deploy base image profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "profiles"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/repo-deploy-base-image-profiles.schema.json"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "deployment_lane",
        "allowed_build_packs",
        "freshness_hours",
        "bundles"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "deployment_lane": {
          "type": "string",
          "enum": [
            "coolify"
          ]
        },
        "allowed_build_packs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "static",
              "dockerfile",
              "dockercompose",
              "nixpacks"
            ]
          }
        },
        "freshness_hours": {
          "type": "integer",
          "minimum": 1
        },
        "repositories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repository"
          }
        },
        "bundles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/bundle"
          }
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repo",
        "branch",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "concern",
        "images"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "concern": {
          "type": "string",
          "enum": [
            "language_build",
            "runtime_base",
            "common_infrastructure",
            "stateful_service"
          ]
        },
        "images": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/image"
          }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ref"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
