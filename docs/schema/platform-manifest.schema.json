{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/platform-manifest.schema.json",
  "title": "Platform Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "manifest_version",
    "repo_version",
    "platform_version",
    "generated_at",
    "next_refresh_at",
    "environment",
    "identity",
    "health",
    "incidents",
    "maintenance",
    "capabilities",
    "agents",
    "recent_changes",
    "agentic_architecture",
    "data_sources",
    "known_gaps"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/platform-manifest.schema.json"
    },
    "manifest_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "repo_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "platform_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "next_refresh_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": ["production", "staging"]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform_name", "operator", "description", "host_id", "provider"],
      "properties": {
        "platform_name": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "host_id": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "mode", "services"],
      "properties": {
        "summary": {
          "type": "string",
          "enum": ["healthy", "degraded", "critical"]
        },
        "mode": {
          "type": "string",
          "enum": ["repo_evidence", "runtime_slo"]
        },
        "services": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "service_name",
              "status",
              "score",
              "safe_to_act",
              "source",
              "reason",
              "lifecycle_status"
            ],
            "properties": {
              "service_name": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["healthy", "degraded", "critical"]
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "safe_to_act": {
                "type": "boolean"
              },
              "source": {
                "type": "string",
                "enum": ["repo_evidence", "runtime_slo"]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "lifecycle_status": {
                "type": "string",
                "minLength": 1
              },
              "primary_url": {
                "type": "string",
                "minLength": 1
              },
              "maintenance_active": {
                "type": "boolean"
              },
              "last_live_apply": {
                "type": "string",
                "format": "date-time"
              },
              "slo_status": {
                "type": "string",
                "enum": ["healthy", "warning", "critical", "unknown"]
              }
            }
          }
        }
      }
    },
    "incidents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open_count", "items"],
      "properties": {
        "open_count": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "incident_id",
              "service",
              "top_hypothesis",
              "confidence",
              "loop_state",
              "ts_fired"
            ],
            "properties": {
              "incident_id": {
                "type": "string",
                "minLength": 1
              },
              "service": {
                "type": "string",
                "minLength": 1
              },
              "top_hypothesis": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "loop_state": {
                "type": "string",
                "minLength": 1
              },
              "ts_fired": {
                "type": "string",
                "format": "date-time"
              },
              "report_path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_windows", "upcoming_windows"],
      "properties": {
        "active_windows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/maintenanceWindow"
          }
        },
        "upcoming_windows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/maintenanceWindow"
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_workflows", "automation_eligible_runbooks"],
      "properties": {
        "available_workflows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "description",
              "tags",
              "risk_class",
              "automation_eligible",
              "agent_trust_required",
              "execution_class",
              "live_impact",
              "budget",
              "runbook"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "risk_class": {
                "type": "string",
                "enum": ["LOW", "MEDIUM", "HIGH"]
              },
              "automation_eligible": {
                "type": "boolean"
              },
              "agent_trust_required": {
                "type": "string",
                "enum": ["T1", "T2", "T3"]
              },
              "execution_class": {
                "type": "string",
                "minLength": 1
              },
              "live_impact": {
                "type": "string",
                "minLength": 1
              },
              "runbook": {
                "type": "string",
                "minLength": 1
              },
              "budget": {
                "$ref": "#/$defs/workflowBudget"
              }
            }
          }
        },
        "automation_eligible_runbooks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "agent_trust_required", "steps", "path"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "agent_trust_required": {
                "type": "string",
                "enum": ["T1", "T2", "T3"]
              },
              "steps": {
                "type": "integer",
                "minimum": 0
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "workflow_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registered"],
      "properties": {
        "registered": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "agent_id",
              "trust_tier",
              "description",
              "status",
              "principal",
              "owner"
            ],
            "properties": {
              "agent_id": {
                "type": "string",
                "minLength": 1
              },
              "trust_tier": {
                "type": "string",
                "enum": ["T1", "T2", "T3"]
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "minLength": 1
              },
              "principal": {
                "type": "string",
                "minLength": 1
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "source_identity_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "recent_changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["last_version", "deployed_at", "summary", "release_notes_url"],
      "properties": {
        "last_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "deployed_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "release_notes_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agentic_architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview", "entry_points", "pipeline", "autonomous_loop"],
      "properties": {
        "overview": {
          "type": "string",
          "minLength": 1
        },
        "entry_points": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["component", "endpoint", "adr"],
            "properties": {
              "component": {
                "type": "string",
                "minLength": 1
              },
              "endpoint": {
                "type": "string",
                "minLength": 1
              },
              "adr": {
                "type": "string",
                "pattern": "^\\d{4}$"
              }
            }
          }
        },
        "pipeline": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "autonomous_loop": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "data_sources": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adr", "title", "status", "implementation_status", "path"],
        "properties": {
          "adr": {
            "type": "string",
            "pattern": "^\\d{4}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "implementation_status": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "workflowBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_duration_seconds",
        "max_steps",
        "max_concurrent_instances",
        "max_touched_hosts",
        "max_restarts",
        "max_rollback_depth",
        "escalation_action"
      ],
      "properties": {
        "max_duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1
        },
        "max_concurrent_instances": {
          "type": "integer",
          "minimum": 1
        },
        "max_touched_hosts": {
          "type": "integer",
          "minimum": 0
        },
        "max_restarts": {
          "type": "integer",
          "minimum": 0
        },
        "max_rollback_depth": {
          "type": "integer",
          "minimum": 0
        },
        "escalation_action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "maintenanceWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_id", "service_id", "description", "starts_at", "duration_minutes"],
      "properties": {
        "window_id": {
          "type": "string",
          "minLength": 1
        },
        "service_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "starts_at": {
          "type": "string",
          "format": "date-time"
        },
        "ends_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
