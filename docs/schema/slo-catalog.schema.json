{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/slo-catalog.schema.json",
  "title": "SLO Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "review_note", "slos"],
  "properties": {
    "$schema": {
      "const": "docs/schema/slo-catalog.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "review_note": {
      "type": "string"
    },
    "slos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "service_id",
          "indicator",
          "objective_percent",
          "window_days",
          "target_url",
          "probe_module",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "service_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "indicator": {
            "type": "string",
            "enum": ["availability", "latency"]
          },
          "objective_percent": {
            "type": "number",
            "minimum": 0.01,
            "maximum": 99.999
          },
          "latency_threshold_ms": {
            "type": "integer",
            "minimum": 1
          },
          "window_days": {
            "type": "integer",
            "minimum": 1
          },
          "target_url": {
            "type": "string",
            "pattern": "^https?://.+"
          },
          "probe_module": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
