{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/capability-contract-catalog.schema.json",
  "title": "Capability Contract Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "capabilities"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/capability-contract-catalog.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability"
      }
    }
  },
  "$defs": {
    "namedEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failureMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "acceptable_degradation",
        "operator_response"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "acceptable_degradation": {
          "type": "string",
          "minLength": 1
        },
        "operator_response": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "migrationExpectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_formats",
        "import_requirements",
        "fallback_behaviour"
      ],
      "properties": {
        "export_formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "import_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallback_behaviour": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "currentSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_name",
        "service_id",
        "selection_adr",
        "runbook",
        "notes"
      ],
      "properties": {
        "product_name": {
          "type": "string",
          "minLength": 1
        },
        "service_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "selection_adr": {
          "type": "string",
          "pattern": "^\\d{4}$"
        },
        "runbook": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "summary",
        "scope",
        "owner",
        "review_cadence",
        "required_outcomes",
        "service_guarantees",
        "canonical_inputs",
        "canonical_outputs",
        "security_expectations",
        "audit_expectations",
        "observability_requirements",
        "portability_constraints",
        "migration_expectations",
        "failure_modes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "critical_shared_surface"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "review_cadence": {
          "type": "string",
          "enum": [
            "quarterly",
            "semiannual",
            "annual"
          ]
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "service_guarantees": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonical_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/namedEntry"
          }
        },
        "canonical_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/namedEntry"
          }
        },
        "security_expectations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "audit_expectations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "observability_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "portability_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "migration_expectations": {
          "$ref": "#/$defs/migrationExpectations"
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/failureMode"
          }
        },
        "current_selection": {
          "$ref": "#/$defs/currentSelection"
        }
      }
    }
  }
}
