{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/subdomain-exposure-registry.schema.json",
  "title": "Canonical Publication Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "zone_name", "publications", "summary"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0"
    },
    "zone_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fqdn",
          "environment",
          "status",
          "owner_adr",
          "publication",
          "assertions",
          "evidence_plan",
          "adapter",
          "live_tracking_expected"
        ],
        "properties": {
          "fqdn": {
            "type": "string",
            "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
          },
          "service_id": {
            "type": ["string", "null"]
          },
          "environment": {
            "type": "string",
            "enum": ["production", "staging"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "reserved", "retiring"]
          },
          "owner_adr": {
            "type": "string",
            "pattern": "^\\d{4}$"
          },
          "publication": {
            "type": "object",
            "additionalProperties": false,
            "required": ["delivery_model", "access_model", "audience"],
            "properties": {
              "delivery_model": {
                "type": "string",
                "enum": ["shared-edge", "informational-edge", "private-network"]
              },
              "access_model": {
                "type": "string",
                "enum": ["open", "platform-sso", "upstream-auth", "private-network"]
              },
              "audience": {
                "type": "string",
                "enum": ["public", "operator", "private-network"]
              }
            }
          },
          "assertions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["publication_class", "environment", "audience", "auth_requirement", "route_target"],
            "properties": {
              "publication_class": {
                "type": "string",
                "enum": ["edge-published", "informational-only", "private-only"]
              },
              "environment": {
                "type": "string",
                "enum": ["production", "staging"]
              },
              "audience": {
                "type": "string",
                "enum": ["public", "operator", "private-network"]
              },
              "auth_requirement": {
                "type": "string",
                "enum": ["none", "edge_oidc", "upstream_auth", "private_network"]
              },
              "route_target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["service_id", "kind", "source", "target", "target_port"],
                "properties": {
                  "service_id": {
                    "type": ["string", "null"]
                  },
                  "kind": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  },
                  "target": {
                    "type": "string"
                  },
                  "target_port": {
                    "type": ["integer", "null"]
                  }
                }
              }
            }
          },
          "evidence_plan": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dns_resolution", "dns_zone", "http_auth", "private_route", "tls"],
            "properties": {
              "dns_resolution": {
                "type": "boolean"
              },
              "dns_zone": {
                "type": "boolean"
              },
              "http_auth": {
                "type": "boolean"
              },
              "private_route": {
                "type": "boolean"
              },
              "tls": {
                "type": "boolean"
              }
            }
          },
          "adapter": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dns", "routing", "edge_auth", "repo_route_metadata", "tls"],
            "properties": {
              "dns": {
                "type": "object",
                "additionalProperties": false,
                "required": ["target", "record_type", "records", "managed", "visibility", "zone_expected"],
                "properties": {
                  "target": {
                    "type": "string"
                  },
                  "target_port": {
                    "type": ["integer", "null"]
                  },
                  "record_type": {
                    "type": "string",
                    "enum": ["A", "AAAA", "CNAME"]
                  },
                  "records": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["type", "value"],
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["A", "AAAA", "CNAME"]
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "managed": {
                    "type": "boolean"
                  },
                  "visibility": {
                    "type": "string",
                    "enum": ["public", "tailnet"]
                  },
                  "zone_expected": {
                    "type": "boolean"
                  }
                }
              },
              "routing": {
                "type": "object",
                "additionalProperties": false,
                "required": ["mode", "source"],
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": ["edge", "dns-only"]
                  },
                  "source": {
                    "type": "string",
                    "enum": ["service_topology", "public_edge_extra_sites", "public_edge_apex", "dns-only"]
                  },
                  "kind": {
                    "type": ["string", "null"]
                  }
                }
              },
              "edge_auth": {
                "type": "object",
                "additionalProperties": false,
                "required": ["provider", "unauthenticated_paths", "unauthenticated_prefix_paths"],
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": ["none", "oauth2_proxy"]
                  },
                  "unauthenticated_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "unauthenticated_prefix_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "repo_route_service_id": {
                "type": ["string", "null"]
              },
              "repo_route_metadata": {
                "type": "object"
              },
              "tls": {
                "type": "object",
                "additionalProperties": false,
                "required": ["provider", "auto_renew"],
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": ["letsencrypt", "step-ca", "none"]
                  },
                  "cert_path": {
                    "type": "string"
                  },
                  "auto_renew": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "live_tracking_expected": {
            "type": "boolean"
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_total",
        "active_total",
        "active_public_total",
        "active_private_total",
        "planned_total",
        "shared_edge_total",
        "platform_sso_total"
      ],
      "properties": {
        "catalog_total": {"type": "integer", "minimum": 0},
        "active_total": {"type": "integer", "minimum": 0},
        "active_public_total": {"type": "integer", "minimum": 0},
        "active_private_total": {"type": "integer", "minimum": 0},
        "planned_total": {"type": "integer", "minimum": 0},
        "shared_edge_total": {"type": "integer", "minimum": 0},
        "platform_sso_total": {"type": "integer", "minimum": 0}
      }
    }
  }
}
