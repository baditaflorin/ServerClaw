{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lv3.org/schema/governed-tool-call-audit-event.json",
  "title": "LV3 Governed Tool Call Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ts",
    "tool",
    "category",
    "transport",
    "actor_class",
    "outcome",
    "correlation_id",
    "arguments",
    "summary"
  ],
  "properties": {
    "ts": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "category": {
      "type": "string",
      "enum": [
        "observe",
        "report",
        "execute",
        "approve"
      ]
    },
    "transport": {
      "type": "string",
      "minLength": 1
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "human_operator",
        "service",
        "service_identity",
        "agent",
        "break_glass"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "rejected"
      ]
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "arguments": {
      "type": "object"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object"
    }
  }
}
