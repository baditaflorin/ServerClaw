{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/gate-bypass-waiver-receipt.schema.json",
  "title": "Gate Bypass Waiver Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_at",
    "bypass",
    "source",
    "branch",
    "commit",
    "waiver"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "bypass": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string",
      "minLength": 1
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_code",
        "reason_summary",
        "detail",
        "impacted_lanes",
        "substitute_evidence",
        "owner",
        "expires_on",
        "remediation_ref"
      ],
      "properties": {
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "reason_summary": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "impacted_lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          }
        },
        "substitute_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "expires_on": {
          "type": "string",
          "format": "date"
        },
        "remediation_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
