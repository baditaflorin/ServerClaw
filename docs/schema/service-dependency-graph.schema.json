{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LV3 service dependency graph",
  "type": "object",
  "required": [
    "schema_version",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "service",
          "name",
          "vm",
          "tier"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "service": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "vm": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "integer",
            "minimum": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "adr": {
            "type": "string",
            "pattern": "^\\d{4}$"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "type",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "hard",
              "soft",
              "startup_only",
              "reads_from"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
