{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/workbench-information-architecture.schema.json",
  "title": "Workbench Information Architecture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "lanes",
    "service_category_defaults",
    "service_overrides",
    "workflow_defaults",
    "workflow_overrides",
    "runbook_defaults",
    "runbook_overrides",
    "pages",
    "workbench_surfaces"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/workbench-information-architecture.schema.json"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "lanes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/laneDefinition"
      }
    },
    "service_category_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation",
        "communication",
        "data",
        "infrastructure",
        "observability",
        "security",
        "access"
      ],
      "properties": {
        "automation": {
          "$ref": "#/$defs/navigationContract"
        },
        "communication": {
          "$ref": "#/$defs/navigationContract"
        },
        "data": {
          "$ref": "#/$defs/navigationContract"
        },
        "infrastructure": {
          "$ref": "#/$defs/navigationContract"
        },
        "observability": {
          "$ref": "#/$defs/navigationContract"
        },
        "security": {
          "$ref": "#/$defs/navigationContract"
        },
        "access": {
          "$ref": "#/$defs/navigationContract"
        }
      }
    },
    "service_overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/serviceOverride"
      }
    },
    "workflow_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic",
        "mutation"
      ],
      "properties": {
        "diagnostic": {
          "$ref": "#/$defs/navigationContract"
        },
        "mutation": {
          "$ref": "#/$defs/navigationContract"
        }
      }
    },
    "workflow_overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowOverride"
      }
    },
    "runbook_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic",
        "mutation"
      ],
      "properties": {
        "diagnostic": {
          "$ref": "#/$defs/navigationContract"
        },
        "mutation": {
          "$ref": "#/$defs/navigationContract"
        }
      }
    },
    "runbook_overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runbookOverride"
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pageDefinition"
      }
    },
    "workbench_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workbenchSurface"
      }
    }
  },
  "$defs": {
    "entityId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "laneId": {
      "type": "string",
      "enum": [
        "start",
        "observe",
        "change",
        "learn",
        "recover"
      ]
    },
    "laneDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "question"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/laneId"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "navigationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_lane",
        "secondary_lanes",
        "next_success_lane",
        "next_failure_lane"
      ],
      "properties": {
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "secondary_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/laneId"
          },
          "uniqueItems": true
        },
        "next_success_lane": {
          "$ref": "#/$defs/laneId"
        },
        "next_failure_lane": {
          "$ref": "#/$defs/laneId"
        }
      }
    },
    "serviceOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_id",
        "primary_lane",
        "secondary_lanes",
        "next_success_lane",
        "next_failure_lane"
      ],
      "properties": {
        "service_id": {
          "$ref": "#/$defs/entityId"
        },
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "secondary_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/laneId"
          },
          "uniqueItems": true
        },
        "next_success_lane": {
          "$ref": "#/$defs/laneId"
        },
        "next_failure_lane": {
          "$ref": "#/$defs/laneId"
        }
      }
    },
    "workflowOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_id",
        "primary_lane",
        "secondary_lanes",
        "next_success_lane",
        "next_failure_lane"
      ],
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/entityId"
        },
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "secondary_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/laneId"
          },
          "uniqueItems": true
        },
        "next_success_lane": {
          "$ref": "#/$defs/laneId"
        },
        "next_failure_lane": {
          "$ref": "#/$defs/laneId"
        }
      }
    },
    "runbookOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runbook_id",
        "primary_lane",
        "secondary_lanes",
        "next_success_lane",
        "next_failure_lane"
      ],
      "properties": {
        "runbook_id": {
          "$ref": "#/$defs/entityId"
        },
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "secondary_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/laneId"
          },
          "uniqueItems": true
        },
        "next_success_lane": {
          "$ref": "#/$defs/laneId"
        },
        "next_failure_lane": {
          "$ref": "#/$defs/laneId"
        }
      }
    },
    "pageDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "surface",
        "route",
        "section_id",
        "fragment",
        "nav_label",
        "nav_visible",
        "nav_order",
        "primary_lane",
        "secondary_lanes",
        "next_success_lane",
        "next_failure_lane"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/entityId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "$ref": "#/$defs/entityId"
        },
        "route": {
          "type": "string",
          "pattern": "^/"
        },
        "section_id": {
          "$ref": "#/$defs/entityId"
        },
        "fragment": {
          "$ref": "#/$defs/entityId"
        },
        "nav_label": {
          "type": "string",
          "minLength": 1
        },
        "nav_visible": {
          "type": "boolean"
        },
        "nav_order": {
          "type": "integer",
          "minimum": 1
        },
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "secondary_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/laneId"
          },
          "uniqueItems": true
        },
        "next_success_lane": {
          "$ref": "#/$defs/laneId"
        },
        "next_failure_lane": {
          "$ref": "#/$defs/laneId"
        }
      }
    },
    "surfaceRole": {
      "type": "string",
      "enum": [
        "home",
        "product_native",
        "reference",
        "task"
      ]
    },
    "surfaceAudience": {
      "type": "string",
      "enum": [
        "admin",
        "operator",
        "viewer"
      ]
    },
    "workbenchSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "url",
        "role",
        "role_description",
        "primary_lane",
        "audience"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/entityId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "role": {
          "$ref": "#/$defs/surfaceRole"
        },
        "role_description": {
          "type": "string",
          "minLength": 1
        },
        "primary_lane": {
          "$ref": "#/$defs/laneId"
        },
        "audience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surfaceAudience"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
