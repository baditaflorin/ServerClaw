{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/preview-environment-profiles.schema.json",
  "title": "Preview environment profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "default_base_domain",
    "default_ephemeral_policy",
    "network_pool",
    "profiles"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "default_base_domain": {
      "type": "string",
      "minLength": 1
    },
    "default_ephemeral_policy": {
      "type": "string",
      "minLength": 1
    },
    "network_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bridge",
        "gateway",
        "cidr",
        "network",
        "ip_range"
      ],
      "properties": {
        "bridge": {
          "type": "string",
          "minLength": 1
        },
        "gateway": {
          "type": "string",
          "minLength": 1
        },
        "cidr": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "network": {
          "type": "string",
          "minLength": 1
        },
        "ip_range": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "ttl_hours",
          "service_subset",
          "members"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "ttl_hours": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "service_subset": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "template",
                "resources"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$"
                },
                "template": {
                  "type": "string",
                  "minLength": 1
                },
                "resources": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "cores",
                    "memory_mb",
                    "disk_gb"
                  ],
                  "properties": {
                    "cores": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "memory_mb": {
                      "type": "integer",
                      "minimum": 512
                    },
                    "disk_gb": {
                      "type": "integer",
                      "minimum": 8
                    }
                  }
                },
                "roles_under_test": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "ansible_vars": {
                  "type": "object"
                },
                "smoke_checks": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/check"
                  }
                },
                "synthetic_checks": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/check"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "oneOf": [
        {
          "required": [
            "command"
          ]
        },
        {
          "required": [
            "url"
          ]
        },
        {
          "required": [
            "port"
          ]
        }
      ]
    }
  }
}
