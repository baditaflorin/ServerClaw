{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/stage-smoke-suites.schema.json",
  "title": "Stage Smoke Suites",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "suites"],
  "properties": {
    "$schema": {
      "const": "docs/schema/stage-smoke-suites.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "service_id",
          "environment",
          "description",
          "runner",
          "mode",
          "targets"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "service_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "environment": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "runner": {
            "type": "string",
            "enum": ["integration_suite"]
          },
          "mode": {
            "type": "string",
            "enum": ["gate", "nightly", "all", "destructive"]
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "required_service_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
