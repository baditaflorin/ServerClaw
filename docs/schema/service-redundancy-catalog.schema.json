{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/service-redundancy-catalog.schema.json",
  "title": "Service Redundancy Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "platform",
    "services"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/service-redundancy-catalog.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_domain_count",
        "max_supported_tier",
        "notes"
      ],
      "properties": {
        "failure_domain_count": {
          "type": "integer",
          "minimum": 1
        },
        "max_supported_tier": {
          "type": "string",
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3"
          ]
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/serviceRedundancy"
      },
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    }
  },
  "$defs": {
    "serviceRedundancy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "recovery_objective",
        "backup_sources",
        "standby"
      ],
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3"
          ]
        },
        "recovery_objective": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rto_minutes",
            "rpo_minutes"
          ],
          "properties": {
            "rto_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "rpo_minutes": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "backup_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "standby": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "location",
            "failover_trigger",
            "failback_method"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "none",
                "cold",
                "warm",
                "active"
              ]
            },
            "location": {
              "type": "string",
              "minLength": 1
            },
            "failover_trigger": {
              "type": "string",
              "minLength": 1
            },
            "failback_method": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
