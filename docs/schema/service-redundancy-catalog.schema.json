{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/service-redundancy-catalog.schema.json",
  "title": "Service Redundancy Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "platform",
    "services"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/service-redundancy-catalog.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_domain_count",
        "max_supported_tier",
        "notes",
        "rehearsal_gate"
      ],
      "properties": {
        "failure_domain_count": {
          "type": "integer",
          "minimum": 1
        },
        "max_supported_tier": {
          "type": "string",
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3"
          ]
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rehearsal_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tiers"
          ],
          "properties": {
            "tiers": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "R1",
                "R2",
                "R3"
              ],
              "properties": {
                "R1": {
                  "$ref": "#/$defs/rehearsalPolicy"
                },
                "R2": {
                  "$ref": "#/$defs/rehearsalPolicy"
                },
                "R3": {
                  "$ref": "#/$defs/rehearsalPolicy"
                }
              }
            }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/serviceRedundancy"
      },
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    }
  },
  "$defs": {
    "serviceRedundancy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "recovery_objective",
        "backup_sources",
        "standby"
      ],
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3"
          ]
        },
        "recovery_objective": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rto_minutes",
            "rpo_minutes"
          ],
          "properties": {
            "rto_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "rpo_minutes": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "backup_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "standby": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "location",
            "failover_trigger",
            "failback_method"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "none",
                "cold",
                "warm",
                "active"
              ]
            },
            "location": {
              "type": "string",
              "minLength": 1
            },
            "failover_trigger": {
              "type": "string",
              "minLength": 1
            },
            "failback_method": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "notes": {
          "type": "string"
        },
        "rehearsal": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "proofs"
          ],
          "properties": {
            "policies": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "R1": {
                  "$ref": "#/$defs/rehearsalPolicy"
                },
                "R2": {
                  "$ref": "#/$defs/rehearsalPolicy"
                },
                "R3": {
                  "$ref": "#/$defs/rehearsalPolicy"
                }
              }
            },
            "proofs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/rehearsalProof"
              }
            }
          }
        }
      }
    },
    "rehearsalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exercise",
        "freshness_window_days"
      ],
      "properties": {
        "exercise": {
          "type": "string",
          "minLength": 1
        },
        "freshness_window_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rehearsalProof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proves_tier",
        "result",
        "performed_on",
        "exercise",
        "trigger",
        "target_environment",
        "duration_minutes",
        "observed_rto_seconds",
        "observed_data_loss",
        "health_verification",
        "rollback_result",
        "evidence_ref"
      ],
      "properties": {
        "proves_tier": {
          "type": "string",
          "enum": [
            "R1",
            "R2",
            "R3"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "partial",
            "fail"
          ]
        },
        "performed_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "exercise": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "target_environment": {
          "type": "string",
          "minLength": 1
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "observed_rto_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "observed_data_loss": {
          "type": "string",
          "minLength": 1
        },
        "health_verification": {
          "type": "string",
          "minLength": 1
        },
        "rollback_result": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
