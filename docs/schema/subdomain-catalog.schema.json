{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/subdomain-catalog.schema.json",
  "title": "Subdomain Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "subdomains"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "subdomains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fqdn",
          "environment",
          "status",
          "exposure",
          "target",
          "owner_adr",
          "tls"
        ],
        "properties": {
          "fqdn": {
            "type": "string",
            "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
          },
          "service_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "environment": {
            "type": "string",
            "enum": ["production", "staging"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "reserved", "retiring"]
          },
          "exposure": {
            "type": "string",
            "enum": ["edge-published", "informational-only", "private-only"]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "target_port": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "string"
          },
          "owner_adr": {
            "type": "string",
            "pattern": "^\\d{4}$"
          },
          "tls": {
            "type": "object",
            "additionalProperties": false,
            "required": ["provider", "auto_renew"],
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["letsencrypt", "step-ca", "none"]
              },
              "cert_path": {
                "type": "string"
              },
              "auto_renew": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}
