{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/gate-bypass-waiver-catalog.schema.json",
  "title": "Gate Bypass Waiver Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "expiring_soon_days",
    "repeat_after_expiry",
    "reason_codes"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/gate-bypass-waiver-catalog.schema.json"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "expiring_soon_days": {
      "type": "integer",
      "minimum": 1
    },
    "repeat_after_expiry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_after_occurrences",
        "blocker_after_occurrences"
      ],
      "properties": {
        "warning_after_occurrences": {
          "type": "integer",
          "minimum": 1
        },
        "blocker_after_occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reason_codes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "summary",
          "max_expiry_days",
          "allowed_bypasses"
        ],
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "max_expiry_days": {
            "type": "integer",
            "minimum": 1
          },
          "allowed_bypasses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            }
          }
        }
      }
    }
  }
}
