{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/ephemeral-capacity-pools.schema.json",
  "title": "LV3 Ephemeral Capacity Pools",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "defaults",
    "pools"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/ephemeral-capacity-pools.schema.json"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "defaults": {
      "type": "object",
      "required": [
        "max_local_active_leases",
        "protected_capacity_class",
        "spillover_domain",
        "warm_lifetime_minutes"
      ],
      "properties": {
        "max_local_active_leases": {
          "type": "integer",
          "minimum": 1
        },
        "protected_capacity_class": {
          "type": "string"
        },
        "spillover_domain": {
          "type": "string"
        },
        "warm_lifetime_minutes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "pools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "fixture_id",
          "warm_count",
          "refill_target",
          "max_concurrent_leases",
          "allowed_lease_purposes",
          "allowed_placement_classes",
          "ip_addresses",
          "placement_domain",
          "spillover_domain",
          "protected_capacity_class"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "fixture_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "warm_count": {
            "type": "integer",
            "minimum": 0
          },
          "refill_target": {
            "type": "integer",
            "minimum": 0
          },
          "max_concurrent_leases": {
            "type": "integer",
            "minimum": 1
          },
          "allowed_lease_purposes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "fixture",
                "preview",
                "recovery-drill",
                "load-test"
              ]
            }
          },
          "allowed_placement_classes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "fixture",
                "preview",
                "recovery"
              ]
            }
          },
          "ip_addresses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+\\.\\d+/\\d+$"
            }
          },
          "placement_domain": {
            "type": "string"
          },
          "spillover_domain": {
            "type": "string"
          },
          "protected_capacity_class": {
            "type": "string"
          },
          "warm_lifetime_minutes": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
