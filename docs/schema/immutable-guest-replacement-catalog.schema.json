{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/immutable-guest-replacement-catalog.schema.json",
  "title": "Immutable Guest Replacement Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "platform",
    "guests"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/immutable-guest-replacement-catalog.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_exception_rule",
        "notes"
      ],
      "properties": {
        "default_exception_rule": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "guests": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/guestPolicy"
      }
    }
  },
  "$defs": {
    "guestPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "validation_mode",
        "cutover_method",
        "rollback_window_minutes",
        "rollback_method"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "edge",
            "stateful",
            "edge_and_stateful"
          ]
        },
        "validation_mode": {
          "type": "string",
          "enum": [
            "inactive_edge_peer",
            "preview_guest",
            "restore_preview",
            "warm_standby"
          ]
        },
        "cutover_method": {
          "type": "string",
          "minLength": 1
        },
        "rollback_window_minutes": {
          "type": "integer",
          "minimum": 15
        },
        "rollback_method": {
          "type": "string",
          "minLength": 1
        },
        "exception_rule": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
