{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/activation-checklist.schema.json",
  "title": "Activation Checklist Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "stages",
    "progressive_reveal"
  ],
  "properties": {
    "$schema": {
      "const": "docs/schema/activation-checklist.schema.json"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "items"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "title",
                "description",
                "links"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_-]*$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "links": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "label",
                      "type",
                      "value"
                    ],
                    "properties": {
                      "label": {
                        "type": "string",
                        "minLength": 1
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "docs",
                          "portal_anchor",
                          "service",
                          "url"
                        ]
                      },
                      "value": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "progressive_reveal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advanced_stage_id",
        "required_stage_ids",
        "locked_launcher_purposes",
        "locked_service_actions",
        "locked_runbook_execution_classes"
      ],
      "properties": {
        "advanced_stage_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "required_stage_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          }
        },
        "locked_launcher_purposes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "operate",
              "observe",
              "learn",
              "plan",
              "administer"
            ]
          }
        },
        "locked_service_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "deploy",
              "restart",
              "rotate_secret"
            ]
          }
        },
        "locked_runbook_execution_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "diagnostic",
              "mutation",
              "workflow"
            ]
          }
        }
      }
    }
  }
}
