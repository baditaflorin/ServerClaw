{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schema/dependency-graph.schema.json",
  "title": "Dependency Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "nodes", "edges"],
  "properties": {
    "$schema": {
      "const": "docs/schema/dependency-graph.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "service", "vm", "tier"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "service": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "vm": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "integer",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "type", "description"],
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "type": {
            "type": "string",
            "enum": ["hard", "soft", "startup_only", "reads_from"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
