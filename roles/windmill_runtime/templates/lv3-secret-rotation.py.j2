import datetime as dt
import os


SECRET_CATALOG = {{ lookup('ansible.builtin.file', '/Users/live/Documents/GITHUB_PROJECTS/proxmox_florin_server/config/secret-catalog.json') | from_json | to_json }}


def _parse_last_rotated(value):
    if value is None:
        return None
    candidate = value[:-1] + "+00:00" if value.endswith("Z") else value
    parsed = dt.datetime.fromisoformat(candidate)
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


def _entry(secret_id, secret, now):
    last_rotated = _parse_last_rotated(secret.get("last_rotated"))
    if last_rotated is None:
        due = True
        next_due = None
    else:
        next_due_dt = last_rotated + dt.timedelta(
            days=secret["rotation_period_days"] - secret["warning_window_days"]
        )
        due = now >= next_due_dt
        next_due = next_due_dt.isoformat().replace("+00:00", "Z")
    return {
        "secret_id": secret_id,
        "service": secret["service"],
        "risk_level": secret["risk_level"],
        "approval_mode": secret["approval_mode"],
        "command_contract": secret["command_contract"],
        "last_rotated": secret.get("last_rotated"),
        "next_due": next_due,
        "initial_rotation_required": last_rotated is None,
        "due": due,
    }


def main(now_iso: str = ""):
    now = (
        dt.datetime.now(dt.timezone.utc)
        if not now_iso
        else _parse_last_rotated(now_iso)
    )
    entries = [
        _entry(secret_id, secret, now)
        for secret_id, secret in sorted(SECRET_CATALOG["secrets"].items())
    ]
    return {
        "workspace": os.getenv("WM_WORKSPACE"),
        "job_id_present": bool(os.getenv("WM_JOB_ID")),
        "evaluated_at": now.isoformat().replace("+00:00", "Z"),
        "managed_secret_count": len(entries),
        "due_secret_ids": [entry["secret_id"] for entry in entries if entry["due"]],
        "entries": entries,
    }
