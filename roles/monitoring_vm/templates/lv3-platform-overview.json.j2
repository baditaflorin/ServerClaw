{% macro cpu_query(object_name, host_name) -%}
from(bucket: "{{ monitoring_influxdb_bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and r._field == "cpu") |> map(fn: (r) => ({ r with _value: float(v: r._value) * 100.0 }))
{%- endmacro %}
{% macro ratio_query(object_name, host_name, value_field, max_field) -%}
from(bucket: "{{ monitoring_influxdb_bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and (r._field == "{{ value_field }}" or r._field == "{{ max_field }}")) |> pivot(rowKey: ["_time"], columnKey: ["_field"], valueColumn: "_value") |> map(fn: (r) => ({ _time: r._time, _value: if exists r.{{ max_field }} and float(v: r.{{ max_field }}) > 0.0 then (float(v: r.{{ value_field }}) / float(v: r.{{ max_field }})) * 100.0 else 0.0 }))
{%- endmacro %}
{% macro throughput_query(object_name, host_name) -%}
from(bucket: "{{ monitoring_influxdb_bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "system" and r.object == "{{ object_name }}" and r.host == "{{ host_name }}" and (r._field == "netin" or r._field == "netout")) |> derivative(unit: 1s, nonNegative: true)
{%- endmacro %}
{% macro load_query(host_name) -%}
from(bucket: "{{ monitoring_influxdb_bucket }}") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == "cpustat" and r.object == "nodes" and r.host == "{{ host_name }}" and r._field == "avg1")
{%- endmacro %}
{% macro timeseries_panel(panel_id, x, y, title, unit, query, min_value=None, max_value=None) -%}
{
  "id": {{ panel_id }},
  "type": "timeseries",
  "title": {{ title | to_json }},
  "datasource": {{ monitoring_grafana_datasource_name | to_json }},
  "gridPos": {
    "h": 8,
    "w": 6,
    "x": {{ x }},
    "y": {{ y }}
  },
  "fieldConfig": {
    "defaults": {
      "unit": {{ unit | to_json }}{% if min_value is not none %},
      "min": {{ min_value }}{% endif %}{% if max_value is not none %},
      "max": {{ max_value }}{% endif %}
    },
    "overrides": []
  },
  "options": {
    "legend": {
      "displayMode": "list",
      "placement": "bottom",
      "showLegend": true
    },
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    }
  },
  "targets": [
    {
      "refId": "A",
      "query": {{ query | trim | to_json }}
    }
  ]
}
{%- endmacro %}
{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {{ timeseries_panel(1, 0, 0, "Proxmox Host Load Avg (1m)", "short", load_query(host_public_hostname)) }},
    {{ timeseries_panel(2, 6, 0, "Proxmox Host CPU Usage", "percent", cpu_query("nodes", host_public_hostname), 0, 100) }},
    {{ timeseries_panel(3, 12, 0, "Proxmox Host Memory Usage", "percent", ratio_query("nodes", host_public_hostname, "mem", "maxmem"), 0, 100) }},
    {{ timeseries_panel(4, 18, 0, "Proxmox Host Disk Usage", "percent", ratio_query("nodes", host_public_hostname, "disk", "maxdisk"), 0, 100) }}{% for guest in proxmox_guests %},
    {{ timeseries_panel((loop.index0 * 4) + 5, 0, (loop.index0 + 1) * 8, guest.name ~ " CPU Usage", "percent", cpu_query("qemu", guest.name), 0, 100) }},
    {{ timeseries_panel((loop.index0 * 4) + 6, 6, (loop.index0 + 1) * 8, guest.name ~ " Memory Usage", "percent", ratio_query("qemu", guest.name, "mem", "maxmem"), 0, 100) }},
    {{ timeseries_panel((loop.index0 * 4) + 7, 12, (loop.index0 + 1) * 8, guest.name ~ " Disk Usage", "percent", ratio_query("qemu", guest.name, "disk", "maxdisk"), 0, 100) }},
    {{ timeseries_panel((loop.index0 * 4) + 8, 18, (loop.index0 + 1) * 8, guest.name ~ " Network Throughput", "Bps", throughput_query("qemu", guest.name), 0, None) }}{% endfor %}
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lv3",
    "proxmox",
    "guests"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": {{ monitoring_grafana_dashboard_title | to_json }},
  "uid": {{ monitoring_grafana_dashboard_uid | to_json }},
  "version": 1,
  "weekStart": ""
}
