{% import "_grafana_dashboard_macros.j2" as dashboard %}
{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [{% for guest in proxmox_guests %}
    {
      "title": {{ guest.name | to_json }},
      "type": "link",
      "url": {{ ("/d/lv3-vm-" ~ guest.name ~ "/lv3-vm-" ~ guest.name) | to_json }}
    }{% if not loop.last %},{% endif %}{% endfor %}
  ],
  "panels": [
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 1, 0, 0, "Proxmox Host Load Avg (1m)", "short", dashboard.load_query(monitoring_influxdb_bucket, host_public_hostname)) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 2, 6, 0, "Proxmox Host CPU Usage", "percent", dashboard.cpu_query(monitoring_influxdb_bucket, "nodes", host_public_hostname), 0, 100) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 3, 12, 0, "Proxmox Host Memory Usage", "percent", dashboard.ratio_query(monitoring_influxdb_bucket, "nodes", host_public_hostname, "mem", "maxmem"), 0, 100) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 4, 18, 0, "Proxmox Host Disk Usage", "percent", dashboard.ratio_query(monitoring_influxdb_bucket, "nodes", host_public_hostname, "disk", "maxdisk"), 0, 100) }}{% for guest in proxmox_guests %},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, (loop.index0 * 4) + 5, 0, (loop.index0 + 1) * 8, guest.name ~ " CPU Usage", "percent", dashboard.cpu_query(monitoring_influxdb_bucket, "qemu", guest.name), 0, 100) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, (loop.index0 * 4) + 6, 6, (loop.index0 + 1) * 8, guest.name ~ " Memory Usage", "percent", dashboard.ratio_query(monitoring_influxdb_bucket, "qemu", guest.name, "mem", "maxmem"), 0, 100) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, (loop.index0 * 4) + 7, 12, (loop.index0 + 1) * 8, guest.name ~ " Disk Usage", "percent", dashboard.ratio_query(monitoring_influxdb_bucket, "qemu", guest.name, "disk", "maxdisk"), 0, 100) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, (loop.index0 * 4) + 8, 18, (loop.index0 + 1) * 8, guest.name ~ " Network Throughput", "Bps", dashboard.throughput_query(monitoring_influxdb_bucket, "qemu", guest.name), 0, None) }}{% endfor %},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 21, 0, 40, "NGINX Active Connections", "short", dashboard.nginx_field_query(monitoring_influxdb_bucket, "nginx-lv3", "active"), 0, None) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 22, 6, 40, "NGINX Requests Per Second", "reqps", dashboard.nginx_rate_query(monitoring_influxdb_bucket, "nginx-lv3", "requests"), 0, None) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 23, 12, 40, "NGINX Accepts And Handled Per Second", "cps", "from(bucket: \"" ~ monitoring_influxdb_bucket ~ "\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"nginx\" and r.host == \"nginx-lv3\" and (r._field == \"accepts\" or r._field == \"handled\")) |> derivative(unit: 1s, nonNegative: true)", 0, None) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 24, 18, 40, "NGINX Connection States", "short", "from(bucket: \"" ~ monitoring_influxdb_bucket ~ "\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"nginx\" and r.host == \"nginx-lv3\" and (r._field == \"reading\" or r._field == \"writing\" or r._field == \"waiting\"))", 0, None) }},
    {{ dashboard.stat_panel(monitoring_grafana_datasource_name, 25, 0, 48, "Docker Build VM Builds (Selected Range)", "short", dashboard.docker_build_total_query(monitoring_influxdb_bucket, "docker-build-lv3")) }},
    {{ dashboard.stat_panel(monitoring_grafana_datasource_name, 26, 6, 48, "Docker Build VM Avg Build Time", "ms", dashboard.docker_build_duration_average_query(monitoring_influxdb_bucket, "docker-build-lv3")) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 27, 12, 48, "Docker Build VM Builds Over Time", "short", dashboard.docker_build_window_query(monitoring_influxdb_bucket, "docker-build-lv3"), 0, None, 12, 8) }},
    {{ dashboard.timeseries_panel(monitoring_grafana_datasource_name, 28, 0, 56, "Docker Build VM Build Duration Over Time", "ms", dashboard.docker_build_duration_window_query(monitoring_influxdb_bucket, "docker-build-lv3"), 0, None, 24, 8) }}
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lv3",
    "proxmox",
    "guests"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": {{ monitoring_grafana_dashboard_title | to_json }},
  "uid": {{ monitoring_grafana_dashboard_uid | to_json }},
  "version": 2,
  "weekStart": ""
}
