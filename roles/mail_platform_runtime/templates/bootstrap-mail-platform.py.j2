#!/usr/bin/env python3

import json
import sys
import urllib.error
import urllib.parse
import urllib.request
from base64 import b64encode


BASE_URL = "http://127.0.0.1:{{ mail_platform_stalwart_http_port }}"
AUTH_HEADER = "Basic " + b64encode(b"admin:{{ mail_platform_admin_password }}").decode("ascii")
DOMAIN_NAME = "{{ mail_platform_domain }}"
MAILBOX_NAME = "{{ mail_platform_mailbox_localpart }}"
MAILBOX_ADDRESS = "{{ mail_platform_mailbox_address }}"
MAILBOX_PASSWORD = "{{ mail_platform_mailbox_password }}"


def api_request(method, path, body=None):
    data = None
    headers = {
        "Authorization": AUTH_HEADER,
        "Accept": "application/json",
    }
    if body is not None:
        headers["Content-Type"] = "application/json"
        data = json.dumps(body).encode("utf-8")
    request = urllib.request.Request(f"{BASE_URL}{path}", method=method, data=data, headers=headers)
    with urllib.request.urlopen(request, timeout=30) as response:
        return json.loads(response.read().decode("utf-8"))


def principal_names(principal_type):
    response = api_request("GET", f"/api/principal?types={urllib.parse.quote(principal_type)}")
    return {item["name"] for item in response.get("data", {}).get("items", [])}


changed = False

domains = principal_names("domain")
if DOMAIN_NAME not in domains:
    api_request(
        "POST",
        "/api/principal",
        {
            "type": "domain",
            "quota": 0,
            "name": DOMAIN_NAME,
            "description": "LV3 managed mail domain",
            "secrets": [],
            "emails": [],
            "urls": [],
            "memberOf": [],
            "roles": [],
            "lists": [],
            "members": [],
            "enabledPermissions": [],
            "disabledPermissions": [],
            "externalMembers": [],
        },
    )
    changed = True

accounts = principal_names("individual")
if MAILBOX_NAME not in accounts:
    api_request(
        "POST",
        "/api/principal",
        {
            "type": "individual",
            "quota": 0,
            "name": MAILBOX_NAME,
            "description": "LV3 managed server mailbox",
            "secrets": [MAILBOX_PASSWORD],
            "emails": [MAILBOX_ADDRESS],
            "urls": [],
            "memberOf": [],
            "roles": ["user"],
            "lists": [],
            "members": [],
            "enabledPermissions": [],
            "disabledPermissions": [],
            "externalMembers": [],
        },
    )
    changed = True

print("changed" if changed else "ok")
