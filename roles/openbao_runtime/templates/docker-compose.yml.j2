services:
  openbao:
    image: {{ openbao_image }}
    container_name: {{ openbao_container_name }}
    user: "0:0"
    command:
      - server
      - -config=/openbao/config
    restart: unless-stopped
    ports:
      - "{{ openbao_http_bind_address }}:{{ openbao_http_port }}:8200"
    volumes:
      - {{ openbao_config_dir }}:/openbao/config
      - {{ openbao_data_dir }}:/openbao/data
      - {{ openbao_log_dir }}:/openbao/logs
