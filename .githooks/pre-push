#!/usr/bin/env bash

set -euo pipefail

# Ensure Homebrew-managed tools (uv, uvx) are on PATH.
# Git hooks run in a non-interactive, non-login shell that does not source
# ~/.zprofile or ~/.zshrc, so /opt/homebrew/bin is not automatically added
# on Apple Silicon Macs (arm64). /usr/local/bin is checked as a fallback
# for Intel Macs or manual installations.
for _hb_path in /opt/homebrew/bin /usr/local/bin; do
  if [[ -x "$_hb_path/uv" && ":$PATH:" != *":$_hb_path:"* ]]; then
    export PATH="$_hb_path:$PATH"
  fi
done
unset _hb_path

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [[ "${SKIP_REMOTE_GATE:-0}" == "1" ]]; then
  echo "validation gate: skipping remote gate because SKIP_REMOTE_GATE=1"
  bypass_args=(
    --bypass skip_remote_gate
    --source pre-push-hook
    --reason-code "${GATE_BYPASS_REASON_CODE:-}"
    --detail "${GATE_BYPASS_DETAIL:-${GATE_BYPASS_REASON:-}}"
    --substitute-evidence "${GATE_BYPASS_SUBSTITUTE_EVIDENCE:-}"
    --remediation-ref "${GATE_BYPASS_REMEDIATION_REF:-}"
  )
  if [[ -n "${GATE_BYPASS_IMPACTED_LANES:-}" ]]; then
    bypass_args+=( --impacted-lane "${GATE_BYPASS_IMPACTED_LANES}" )
  else
    bypass_args+=( --impacted-lane remote-pre-push-gate )
  fi
  if [[ -n "${GATE_BYPASS_OWNER:-}" ]]; then
    bypass_args+=( --owner "${GATE_BYPASS_OWNER}" )
  fi
  if [[ -n "${GATE_BYPASS_EXPIRES_ON:-}" ]]; then
    bypass_args+=( --expires-on "${GATE_BYPASS_EXPIRES_ON}" )
  fi
  python3 scripts/log_gate_bypass.py "${bypass_args[@]}"
  exit 0
fi

echo "validation gate: validating canonical NATS topics"
uv run --with pyyaml python scripts/validate_nats_topics.py --validate

echo "validation gate: running remote pre-push gate"
scripts/remote_exec.sh pre-push-gate --local-fallback
