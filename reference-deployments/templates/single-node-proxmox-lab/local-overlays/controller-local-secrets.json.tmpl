{
  "schema_version": "1.0.0",
  "secrets": {
    "bootstrap_ssh_private_key": {
      "kind": "file",
      "path": "{{ sample_overlay_root }}/ssh/bootstrap_ed25519",
      "origin": "provided_or_generated_externally",
      "status": "planned",
      "description": "Sample private key path for the reference deployment bootstrap user.",
      "dependencies": [
        "inventory/hosts.yml",
        "docs/runbooks/reference-deployment-samples.md"
      ]
    },
    "proxmox_api_token_payload": {
      "kind": "file",
      "path": "{{ sample_overlay_root }}/proxmox-api/automation-token.json",
      "origin": "generated_by_repo",
      "status": "planned",
      "description": "Sample Proxmox automation token path used by local wrappers.",
      "dependencies": [
        "config/api-publication.json",
        "docs/runbooks/reference-deployment-samples.md"
      ]
    },
    "dns_provider_api_token": {
      "kind": "env",
      "name": "REFERENCE_DNS_API_TOKEN",
      "origin": "provided_externally",
      "status": "planned",
      "description": "Sample environment variable for the replaceable DNS provider API token.",
      "dependencies": [
        "config/reference-provider-profiles.yaml"
      ]
    }
  }
}
